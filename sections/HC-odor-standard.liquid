<style>

  .hc-odor-standard-section {
    padding-top: 6rem;
    padding-bottom: 6rem;
    padding-left: 3rem;
    padding-right: 3rem;
    background-color: #f9fafb;
}

  .hc-odor-standard-container {
    max-width: {{ section.settings.hc_page_width }}px;
    margin: 0 auto;
  }

  .hc-odor-standard-header {
    text-align: center;
    margin-bottom: 4rem;
}

  .hc-odor-standard-label {
    font-size: 10.5px;
    font-size: 0.75rem;
    line-height: 1.2;
    letter-spacing: 0.2em;
    color: #b45309;
    font-weight: 700;
    margin-bottom: 2rem;
}

  .hc-odor-standard-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.2;
}

  .hc-odor-cards-wrapper {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 14px;
}

  .hc-odor-card {
    background: rgb(255, 255, 255);
    padding: 21px;
    border: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    gap: 21px;
    width: 100%;
    max-width: 900px;
}

  .hc-odor-card.hc-highlighted {
    border: 2px solid #c17a5c;
    padding: 28px;
    width: 100%;
    max-width: 1050px;
}

  .hc-odor-card-rating {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 700;
    color: #9ca3af;
}

.hc-odor-card.hc-highlighted .hc-odor-card-rating {
    color: #b45309;
    font-size: 2.25rem;
    text-align: center;
}

  {% comment %} .hc-odor-card-number {
    font-size: 32px;
    font-weight: 700;
    color: #c17a5c;
  } {% endcomment %}

  .hc-odor-card-content {
    flex: 1;
  }


.hc-odor-card-heading {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 4px;
}

  .hc-odor-card-description {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.3;
}

  @media (max-width: 768px) {
    .hc-odor-standard-title {
      font-size: 26px;
    }

    .hc-odor-card {
    flex-direction: column;
}

    
  }
</style>

<div class="hc-odor-standard-section">
  <div class="hc-odor-standard-container">
    <div class="hc-odor-standard-header">
      <p class="hc-odor-standard-label">{{ section.settings.hc_top_label }}</p>
      <h2 class="hc-odor-standard-title">{{ section.settings.hc_main_title }}</h2>
    </div>

    <div class="hc-odor-cards-wrapper">
      {% for block in section.blocks %}
        <div class="hc-odor-card {% if block.settings.hc_is_highlighted %}hc-highlighted{% endif %}" {{ block.shopify_attributes }}>
          <div class="hc-odor-card-rating">
            {{ block.settings.hc_rating_text }}
            {% if block.settings.hc_is_highlighted %}
              <div class="hc-odor-card-number">{{ block.settings.hc_rating_number }}</div>
            {% endif %}
          </div>
          <div class="hc-odor-card-content">
            <h3 class="hc-odor-card-heading">{{ block.settings.hc_card_title }}</h3>
            <p class="hc-odor-card-description">{{ block.settings.hc_card_description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "HC Odor Standard",
  "settings": [
    {
      "type": "range",
      "id": "hc_page_width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Page Width",
      "default": 900
    },
    {
      "type": "text",
      "id": "hc_top_label",
      "label": "Top Label",
      "default": "THE STANDARD"
    },
    {
      "type": "richtext",
      "id": "hc_main_title",
      "label": "Main Title",
    }
  ],
  "blocks": [
    {
      "type": "hc_odor_card",
      "name": "Odor Card",
      "settings": [
        {
          "type": "text",
          "id": "hc_rating_text",
          "label": "Rating Text",
          "default": "SPR 1-3"
        },
        {
          "type": "text",
          "id": "hc_rating_number",
          "label": "Rating Number (for highlighted)",
          "default": "10"
        },
        {
          "type": "text",
          "id": "hc_card_title",
          "label": "Card Title",
          "default": "BASIC ODOR CONTROL"
        },
        {
          "type": "textarea",
          "id": "hc_card_description",
          "label": "Card Description",
          "default": "Cotton, Polyester, Likenra, Bamboo. Handles only fresh sweat."
        },
        {
          "type": "checkbox",
          "id": "hc_is_highlighted",
          "label": "Highlight This Card",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC Odor Standard",
      "blocks": [
        {
          "type": "hc_odor_card",
          "settings": {
            "hc_rating_text": "SPR 1-3",
            "hc_card_title": "BASIC ODOR CONTROL",
            "hc_card_description": "Cotton, Polyester, Likenra, Bamboo. Handles only fresh sweat.",
            "hc_is_highlighted": false
          }
        },
        {
          "type": "hc_odor_card",
          "settings": {
            "hc_rating_text": "SPR 4-6",
            "hc_card_title": "MODERATE ODOR CONTROL",
            "hc_card_description": "Silver-infused clothing. Handles bacteria but fails on oil/urea.",
            "hc_is_highlighted": false
          }
        },
        {
          "type": "hc_odor_card",
          "settings": {
            "hc_rating_text": "SPR",
            "hc_rating_number": "10",
            "hc_card_title": "FULL ODOR SPECTRUM",
            "hc_card_description": "Hercléon. Neutralizes all 5 odor types instantly.",
            "hc_is_highlighted": true
          }
        }
      ]
    }
  ]
}
{% endschema %}