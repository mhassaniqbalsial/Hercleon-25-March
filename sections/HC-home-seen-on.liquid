            "publication_name": "Wonderful Engineering"
          }
        },
        {
          "type": "publication",
          "settings": {
            "publication_name": "Men's Journal"
          }
        },
        {
          "type": "publication",
          "settings": {
            "publication_name": "Gear Junkie"
          }
        },
        {
          "type": "publication",
          "settings": {
            "publication_name": "CNN"
          }
        },
        {
          "type": "publication",
