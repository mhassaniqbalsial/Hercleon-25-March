<style>
/* ==========================================================
   Pack Selector — pack-selector.css
   ========================================================== */

   .ps {
    box-sizing: border-box;
}

.ps *,
.ps *::before,
.ps *::after {
    box-sizing: inherit;
}

.ps__inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
}

.ps__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    align-items: start;
}

@media (max-width: 860px) {
    .ps__layout {
        grid-template-columns: 1fr;
        gap: 14px;
    }
}

/* ==========================================================
   GALLERY — vertical thumbs left, main image right
   ========================================================== */
.ps__gallery {
    position: sticky;
    top: 80px;
    container-type: inline-size;
}

@media (max-width: 860px) {
    .ps__gallery {
        position: static;
    }
}

.ps__gallery-inner {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 10px;
    align-items: start;
}

/* ── Vertical thumb column ── */
.ps__thumbs {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 72px;
    height: 0;
    min-height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    scrollbar-color: #ccc transparent;
