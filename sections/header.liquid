<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --color-background: {{ section.settings.color_background.rgb }};
    --color-foreground: {{ section.settings.color_text.rgb }};
    --color-transparent: {{ section.settings.transparent_color_text.rgb }};
    --color-localization: {{ section.settings.color_localization.rgb }};
  }
  
  .hercleon-header-tabs {
    padding: 0.75rem 0;
    background: #050505;
    min-height: 42px;
}

  .hercleon-header-tabs-inner {
    display: flex;
    align-items: center;
    gap: 1.75rem;
}
  
  .hercleon-header-tabs .tab-button {
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    color: #6b7280;
}

  
  .hercleon-header-tabs .tab-button.active::before {
    content: '';
    position: absolute;
    left: -10px;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    background: #b45309;
    border-radius: 9999px;
  }
  
  .hercleon-header-tabs .tab-button:hover {
    opacity: 0.8;
  }
  .hercleon-header-tabs a.tab-button {
    text-decoration: none;
  }
  
  /* HerLab text span */
  .herlab-text-span {
    margin-left: 0.5rem;
    color: #b45309;
    font-size: 1rem;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
}
  
  /* Menu switching */
  .header-content-wrapper[data-tab="hercleon"] .default-menu {
    display: flex !important;
  }
  
  .header-content-wrapper[data-tab="hercleon"] .herlab-menu {
    display: none !important;
  }
  
  .header-content-wrapper[data-tab="herclabs"] .default-menu {
    display: none !important;
  }
  
  .header-content-wrapper[data-tab="herclabs"] .herlab-menu {
    display: flex !important;
  }
  
  /* LABS text visibility */
  .header-content-wrapper[data-tab="hercleon"] .herlab-text-span {
    display: none !important;
  }
  
  .header-content-wrapper[data-tab="herclabs"] .herlab-text-span {
    display: inline-block !important;
  }
  
  /* Section visibility based on active tab */
  .hc-featured-collection-hercleon {
    display: block !important;
  }
  
  .hc-featured-collection-herclabs {
    display: none !important;
  }
  
  body[data-active-tab="herclabs"] .hc-featured-collection-hercleon {
    display: none !important;
  }
  
  body[data-active-tab="herclabs"] .hc-featured-collection-herclabs {
    display: block !important;
  } 
  @media screen and (max-width: 768px) {
    .herlab-text-span {
      font-size: 0.875rem;
    }
  }
</style>

{%- liquid
  assign header_layout = section.settings.header_layout
  assign main_menu = section.settings.menu
  assign herlab_menu = section.settings.hercleon_lab_menu
  assign link_count = main_menu.links.size

  if header_layout == 'center-split'
    assign link_count = link_count | divided_by: 2
  endif

  assign main_menu_class = 'lg:justify-start'
  case header_layout
    when 'center-split'
      assign main_menu_class = 'lg:justify-end'

    when 'center'
      assign main_menu_class = 'lg:justify-center'
  endcase

  assign show_toggle = false
  if header_layout == 'center'
    assign show_toggle = true
  endif

  render 'header-drawer', section: section
-%}

{%- liquid
  assign product_template_suffix = ''
  if template.name == 'product' and template.suffix != blank
    assign product_template_suffix = template.suffix
  endif
-%}
{%- comment -%} Header Tabs {%- endcomment -%}
{%- if product_template_suffix == 'hercleon' -%}
  {%- comment -%} Product template hercleon: Hercleon active, HercLabs links to homepage with herclabs {%- endcomment -%}
  <div id="{{ section.settings.section_id }}" class="hercleon-header-tabs hercleon-header-tabs--product-hercleon" data-section-id="tabs-{{ section.id }}" data-product-template="hercleon">
    <div class="page-width page-width--full">
      <div class="hercleon-header-tabs-inner">
        <span class="tab-button active">HercLéon</span>
        <a href="/?tab=herlabs" class="tab-button">HercLabs</a>
      </div>
    </div>
  </div>
{%- elsif product_template_suffix == 'herclabs' -%}
  {%- comment -%} Product template herclab: HercLabs active, Hercleon links to homepage with hercleon {%- endcomment -%}
  <div id="{{ section.settings.section_id }}" class="hercleon-header-tabs hercleon-header-tabs--product-herclab" data-section-id="tabs-{{ section.id }}" data-product-template="herclab">
    <div class="page-width page-width--full">
      <div class="hercleon-header-tabs-inner">
        <a href="/?tab=hercleon" class="tab-button">HercLéon</a>
        <span class="tab-button active">HercLabs</span>
      </div>
    </div>
  </div>
{%- else -%}
  {%- comment -%} Default: interactive tabs with JS {%- endcomment -%}
  <div id="{{ section.settings.section_id }}" class="hercleon-header-tabs" data-section-id="tabs-{{ section.id }}">
    <div class="page-width page-width--full">
      <div class="hercleon-header-tabs-inner">
        <button class="tab-button active" data-tab="hercleon" data-section="{{ section.id }}">HercLéon</button>
        <button class="tab-button" data-tab="herclabs" data-section="{{ section.id }}">HercLabs</button>
      </div>
    </div>
  </div>
{%- endif -%}
{%- if product_template_suffix == 'hercleon' -%}
  <script>document.body.setAttribute('data-active-tab','hercleon');try{sessionStorage.setItem('hercleon-active-tab','hercleon');}catch(e){}</script>
{%- elsif product_template_suffix == 'herclabs' -%}
  <script>document.body.setAttribute('data-active-tab','herclabs');try{sessionStorage.setItem('hercleon-active-tab','herclabs');}catch(e){}</script>
{%- endif -%}

<div class="header-content-wrapper" data-tab="{% if product_template_suffix == 'herclabs' %}herclabs{% else %}hercleon{% endif %}" data-wrapper="{{ section.id }}">
<header data-section-id="{{ section.id }}" class="header header--{{ header_layout }} mobile:header--{{ section.settings.logo_position_mobile }} page-width{% if section.settings.full_width %} page-width--full{% endif %} section{% if section.settings.rounded %} section--rounded{% endif %} section--padding grid items-center z-20 relative w-full"{% if section.settings.sticky_header_type != 'none' %} is="sticky-header" data-sticky-type="{{ section.settings.sticky_header_type }}"{% else %} is="custom-header"{% endif %}>
  {%- liquid
    render 'header-icons', section: section, show_search: true, show_hamburger: true, show_toggle: show_toggle, context: 'start'

    if header_layout != 'center-left' and header_layout != 'center-split'
      render 'header-logo', logo_h1: section.settings.logo_h1, section: section
    endif

    if header_layout == 'center'
      render 'header-icons', section: section, show_search: true, show_account: true, show_cart: true, show_hamburger: true, context: 'end'
    endif
  -%}
  
  <div class="header__navigation hidden lg:flex lg:gap-5 {{ main_menu_class }} default-menu"{% if header_layout == 'center' %} id="MenuToggle"{% endif %} data-menu="hercleon">
    <nav class="header__menu hidden lg:flex" role="navigation" aria-label="Primary">
      {%- render 'header-nav-desktop', section: section, main_menu: main_menu, limit: link_count, context: 'start' -%}
    </nav>
  </div>
  
  {%- if herlab_menu != blank -%}
    <div class="header__navigation hidden lg:flex lg:gap-5 {{ main_menu_class }} herlab-menu"{% if header_layout == 'center' %} id="MenuToggle"{% endif %} data-menu="herclabs">
      <nav class="header__menu hidden lg:flex" role="navigation" aria-label="Primary">
        {%- render 'header-nav-desktop', section: section, main_menu: herlab_menu, limit: herlab_menu.links.size, context: 'start' -%}
      </nav>
    </div>
  {%- endif -%}

  {%- liquid
    if header_layout == 'center-left' or header_layout == 'center-split'
      render 'header-logo', logo_h1: section.settings.logo_h1, section: section
    endif
  -%}
  
  {%- if header_layout == 'center-split' -%}
    <div class="header__navigation header__navigation--split hidden lg:flex lg:gap-5 lg:justify-start default-menu" data-menu="hercleon">
      <nav class="header__menu hidden lg:flex" role="navigation" aria-label="Secondary">
        {%- render 'header-nav-desktop', section: section, main_menu: main_menu, offset: link_count, context: 'end' -%}
      </nav>
    </div>
    {%- if herlab_menu != blank -%}
      <div class="header__navigation header__navigation--split hidden lg:flex lg:gap-5 lg:justify-start herlab-menu" data-menu="herclabs">
        <nav class="header__menu hidden lg:flex" role="navigation" aria-label="Secondary">
          {%- render 'header-nav-desktop', section: section, main_menu: herlab_menu, offset: link_count, context: 'end' -%}
        </nav>
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- liquid
    if header_layout != 'center'
      render 'header-icons', section: section, show_search: true, show_account: true, show_cart: true, show_hamburger: true, context: 'end'
    endif
  -%}

  {%- if section.settings.rounded -%}
    {%- render 'corner', dir: 'bottom', border: true, prefix: 'header' -%}
  {%- else -%}
    <span class="header__cutout cutout opacity-0 absolute left-0 top-100 w-full pointer-events-none"></span>
  {%- endif -%}
</header>
</div>

{%- if section.settings.hover_menu -%}
  <span class="overlay opacity-0 z-1 fixed left-0 w-full pointer-events-none"></span>
{%- else -%}
  <overlay-element class="overlay opacity-0 z-1 fixed left-0 w-full pointer-events-none"></overlay-element>
{%- endif -%}

{%- if request.design_mode -%}
  <script>
    document.documentElement.style.setProperty('--header-height', document.getElementById('shopify-section-{{ section.id }}').getBoundingClientRect().height.toFixed(1) + 'px');
  </script>
{%- endif -%}

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const herclabsCollectionHandle = {{ section.settings.herclabs_collection_handle | json }};
    const tabButtons = document.querySelectorAll(`[data-section="${sectionId}"]`);
    const wrapper = document.querySelector(`[data-wrapper="${sectionId}"]`);
    
    if (!tabButtons.length || !wrapper) return;
    
    function switchTab(tabName) {
      // Update button states
      tabButtons.forEach(btn => {
        if (btn.getAttribute('data-tab') === tabName) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
      
      // Update wrapper attribute to trigger CSS changes
      wrapper.setAttribute('data-tab', tabName);
      
      // Update body data attribute for section visibility
      document.body.setAttribute('data-active-tab', tabName);
      
      // Persist so HercLabs stays active when navigating to product/other pages
      try { sessionStorage.setItem('hercleon-active-tab', tabName); } catch (e) {}
      
      // Find and toggle menus
      const defaultMenus = wrapper.querySelectorAll('[data-menu="hercleon"]');
      const herlabMenus = wrapper.querySelectorAll('[data-menu="herclabs"]');
      
      // Find and toggle LABS text span
      const labsSpans = document.querySelectorAll('.herlab-text-span');
      
      if (tabName === 'hercleon') {
        // Show default menu, hide herlab menu and LABS text
        defaultMenus.forEach(menu => {
          menu.style.display = '';
          menu.classList.remove('hidden');
          menu.classList.add('lg:flex');
        });
        herlabMenus.forEach(menu => menu.style.display = 'none');
        labsSpans.forEach(span => span.style.display = 'none');
      } else {
        // Show herlab menu and LABS text, hide default menu
        defaultMenus.forEach(menu => menu.style.display = 'none');
        herlabMenus.forEach(menu => {
          menu.style.display = '';
          menu.classList.remove('hidden');
          menu.classList.add('lg:flex');
        });
        labsSpans.forEach(span => span.style.display = 'inline-block');
      }
    }
    
    tabButtons.forEach(button => {
      button.addEventListener('click', function() {
        const tabName = this.getAttribute('data-tab');
        switchTab(tabName);
      });
    });
    
    // Sync header when tab is changed from mobile drawer
    document.addEventListener('hercleon:switchTab', function(e) {
      if (e.detail && e.detail.tab) switchTab(e.detail.tab);
    });
    
    // Initialize: prefer ?tab= param (from product template links), then HercLabs collection URL, then persisted tab, else HercLeon
    const pathname = window.location.pathname;
    const params = new URLSearchParams(window.location.search);
    const tabParam = params.get('tab');
    var tabFromParam = null;
    if (tabParam === 'herlabs' || tabParam === 'herclabs') {
      tabFromParam = 'herclabs';
      try { sessionStorage.setItem('hercleon-active-tab', 'herclabs'); } catch (e) {}
      try { window.history.replaceState({}, '', pathname || '/'); } catch (e) {}
    } else if (tabParam === 'hercleon') {
      tabFromParam = 'hercleon';
      try { sessionStorage.setItem('hercleon-active-tab', 'hercleon'); } catch (e) {}
      try { window.history.replaceState({}, '', pathname || '/'); } catch (e) {}
    }
    const isHerclabsCollection = herclabsCollectionHandle &&
      (pathname === '/collections/' + herclabsCollectionHandle || pathname.startsWith('/collections/' + herclabsCollectionHandle + '/'));
    const savedTab = (function() { try { return sessionStorage.getItem('hercleon-active-tab'); } catch (e) { return null; } })();
    const initialTab = tabFromParam !== null ? tabFromParam : (isHerclabsCollection ? 'herclabs' : (savedTab === 'herclabs' ? 'herclabs' : 'hercleon'));
    switchTab(initialTab);
  })();
</script> 

