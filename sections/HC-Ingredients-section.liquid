{% comment %}
  HC Ingredients Section
  Displays ingredient features with descriptions and optional image
{% endcomment %}
<div class="hc-ingredients-wrapper">
  <div class="hc-ingredients-container page-width">
    <div class="hc-ingredients-content">
      {% for block in section.blocks %}
        {% if block.type == 'ingredient_item' %}
          <div class="hc-ingredient-block" {{ block.shopify_attributes }}>
            <h3 class="hc-ingredient-title">{{ block.settings.title }}</h3>
            <p class="hc-ingredient-description">{{ block.settings.description }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="hc-ingredients-image-wrapper">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1500 | image_tag }}
      {% else %}
        <div class="hc-image-placeholder">
          <p class="hc-placeholder-text">{{ section.settings.placeholder_text }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>
<style>
  .hc-ingredients-wrapper {
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .hc-ingredients-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.gap }}px;
    align-items: start;
  }

  .hc-ingredients-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hc-ingredient-block {
    padding: 21px 0 0px;
    margin-top: 42px;
    border-top: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
  }

  .hc-ingredient-title {
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 700;
    margin-bottom: 0.5rem;
} 

  .hc-ingredient-description {
    font-size: 14px;
    color: #4b5563;
    line-height: 1.6;
}

  .hc-ingredients-image-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.image_background }};
    border-radius: {{ section.settings.image_border_radius }}px;
    overflow: hidden;
    height: 100%;
  }
  .hc-ingredients-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .hc-ingredient-block:first-child {
    margin-top: 0px;
  }
  .hc-image-placeholder {
    width: 100%;
    padding: 60px 20px;
    text-align: center;
    background-color: #f5f5f5;
  }
  .hc-placeholder-text {
    font-size: 14px;
    color: #999;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  @media (max-width: 768px) {
    .hc-ingredients-container {
      grid-template-columns: 1fr;
      gap: 42px;
    }
    .hc-ingredients-image-wrapper {
      min-height: 400px;
    }

  }
</style>
{% schema %}
{
  "name": "HC Ingredients Section",
  "tag": "section",
  "class": "hc-ingredients-section",
  "settings": [
    {
      "type": "header",
      "content": "Container Settings"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap Between Content and Image",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Color Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Border Settings"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border Width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Typography Settings"
    },
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Ingredients"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Image Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Border Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder Text (if no image)",
      "default": "[MICROSCOPIC FIBER ANALYSIS]"
    }
  ],
  "blocks": [
    {
      "type": "ingredient_item",
      "name": "Ingredient Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "COPPER (CU+)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "The primary antimicrobial agent. Lyses cell walls and destroys DNA."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC Ingredients",
      "blocks": [
        {
          "type": "ingredient_item",
          "settings": {
            "title": "COPPER (CU+)",
            "description": "The primary antimicrobial agent. Lyses cell walls and destroys DNA."
          }
        },
        {
          "type": "ingredient_item",
          "settings": {
            "title": "ZINC (ZN)",
            "description": "Provides broad-spectrum protection against fungus and skin irritants."
          }
        },
        {
          "type": "ingredient_item",
          "settings": {
            "title": "BAMBOO CHARCOAL",
            "description": "The porous structure absorbs moisture and traps odors physically."
          }
        },
        {
          "type": "ingredient_item",
          "settings": {
            "title": "MICRO-MODAL",
            "description": "Derived from Beechwood trees. Provides the softness and temperature regulation."
          }
        }
      ]
    }
  ]
}
{% endschema %}