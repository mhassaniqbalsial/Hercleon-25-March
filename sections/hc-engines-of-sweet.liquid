<section
  class="hc-eng-of-sweet"
  style="
    --hc-eng-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --hc-eng-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hc-eng-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --hc-eng-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
  "
>
  <div class="hc-eng-of-sweet__container">

    {%- comment -%} Section header {%- endcomment -%}
    <div class="hc-eng-of-sweet__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hc-eng-of-sweet__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h2 class="hc-eng-of-sweet__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.subtext != blank -%}
        <p class="hc-eng-of-sweet__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Cards grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="hc-eng-of-sweet__grid">
        {%- for block in section.blocks -%}
          <div
            class="hc-eng-of-sweet__card hc-eng-of-sweet__card--{{ block.settings.color_theme }}"
            {{ block.shopify_attributes }}
          >
            <div class="hc-eng-of-sweet__card-accent" aria-hidden="true"></div>

            {%- if block.settings.icon != blank -%}
              <span class="hc-eng-of-sweet__card-icon" aria-hidden="true">
                {{ block.settings.icon }}
              </span>
            {%- endif -%}

            <h3 class="hc-eng-of-sweet__card-title">{{ block.settings.title }}</h3>

            {%- if block.settings.subtitle != blank -%}
              <p class="hc-eng-of-sweet__card-subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}

            {%- if block.settings.body != blank -%}
              <p class="hc-eng-of-sweet__card-body">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .hc-eng-of-sweet {
    background-color: #fff;
    padding-top: var(--hc-eng-pt-mobile);
    padding-bottom: var(--hc-eng-pb-mobile);
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media (min-width: 768px) {
    .hc-eng-of-sweet {
      padding-left: 3rem;
      padding-right: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-eng-of-sweet {
      padding-top: var(--hc-eng-pt-desktop);
      padding-bottom: var(--hc-eng-pb-desktop);
    }
  }

  /* Container */
  .hc-eng-of-sweet__container {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Header */
  .hc-eng-of-sweet__header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .hc-eng-of-sweet__eyebrow {
    display: block;
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #B45309;
    margin-bottom: 1.5rem;
  }

  .hc-eng-of-sweet__heading {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #050505;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hc-eng-of-sweet__heading {
      font-size: 3.75rem;
    }
  }

  .hc-eng-of-sweet__subtext {
    font-size: 1.25rem;
    color: #6b7280;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.75;
  }

  /* Grid */
  .hc-eng-of-sweet__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .hc-eng-of-sweet__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card base */
  .hc-eng-of-sweet__card {
    position: relative;
    overflow: hidden;
    padding: 2.5rem;
    border-radius: 1.5rem;
    border-width: 1px;
    border-style: solid;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .hc-eng-of-sweet__card:hover {
    box-shadow: 0 20px 40px -8px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }

  /* Card decorative accent — quarter circle top-right */
  .hc-eng-of-sweet__card-accent {
    position: absolute;
    top: 0;
    right: 0;
    width: 8rem;
    height: 8rem;
    border-bottom-left-radius: 9999px;
    opacity: 0.5;
    z-index: 0;
    transition: transform 0.3s ease;
  }

  .hc-eng-of-sweet__card:hover .hc-eng-of-sweet__card-accent {
    transform: scale(1.1);
  }

  /* Card content z-index */
  .hc-eng-of-sweet__card-icon,
  .hc-eng-of-sweet__card-title,
  .hc-eng-of-sweet__card-subtitle,
  .hc-eng-of-sweet__card-body {
    position: relative;
    z-index: 1;
  }

  .hc-eng-of-sweet__card-icon {
    display: block;
    font-size: 3rem;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .hc-eng-of-sweet__card-title {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .hc-eng-of-sweet__card-subtitle {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .hc-eng-of-sweet__card-body {
    font-size: 0.875rem;
    color: #4b5563;
    line-height: 1.75;
    margin: 0;
  }

  /* Blue theme */
  .hc-eng-of-sweet__card--blue {
    background-color: #eff6ff;
    border-color: #dbeafe;
  }

  .hc-eng-of-sweet__card--blue .hc-eng-of-sweet__card-accent {
    background-color: #bfdbfe;
  }

  .hc-eng-of-sweet__card--blue .hc-eng-of-sweet__card-title {
    color: #1e3a8a;
  }

  .hc-eng-of-sweet__card--blue .hc-eng-of-sweet__card-subtitle {
    color: #1d4ed8;
  }

  /* Orange theme */
  .hc-eng-of-sweet__card--orange {
    background-color: #fff7ed;
    border-color: #fed7aa;
  }

  .hc-eng-of-sweet__card--orange .hc-eng-of-sweet__card-accent {
    background-color: #fdba74;
  }

  .hc-eng-of-sweet__card--orange .hc-eng-of-sweet__card-title {
    color: #7c2d12;
  }

  .hc-eng-of-sweet__card--orange .hc-eng-of-sweet__card-subtitle {
    color: #c2410c;
  }

  /* Purple theme */
  .hc-eng-of-sweet__card--purple {
    background-color: #faf5ff;
    border-color: #e9d5ff;
  }

  .hc-eng-of-sweet__card--purple .hc-eng-of-sweet__card-accent {
    background-color: #d8b4fe;
  }

  .hc-eng-of-sweet__card--purple .hc-eng-of-sweet__card-title {
    color: #581c87;
  }

  .hc-eng-of-sweet__card--purple .hc-eng-of-sweet__card-subtitle {
    color: #7e22ce;
  }
</style>

{% schema %}
{
  "name": "HC Engines Sweet",
  "tag": "section",
  "class": "hc-eng-of-sweet-section",
  "settings": [
    {
      "type": "header",
      "content": "Header Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "The Source"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The 3 Engines of Sweat"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Humans are the sweatiest primates on earth. We have three distinct types of sweat glands, each with a completely different job."
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Spacing — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Sweat Gland Card",
      "settings": [
        {
          "type": "select",
          "id": "color_theme",
          "label": "Color Theme",
          "options": [
            { "value": "blue",   "label": "Blue"   },
            { "value": "orange", "label": "Orange" },
            { "value": "purple", "label": "Purple" }
          ],
          "default": "blue"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "💧"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Eccrine Glands"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "The Cooling System"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body Text",
          "default": "Located all over your body. They produce a clear, odorless fluid that is 99% water and 1% salt. Their only job is to keep you from overheating. Bacteria don't care about this sweat."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC Engines Sweet",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "color_theme": "blue",
            "icon": "💧",
            "title": "Eccrine Glands",
            "subtitle": "The Cooling System",
            "body": "Located all over your body. They produce a clear, odorless fluid that is 99% water and 1% salt. Their only job is to keep you from overheating. Bacteria don't care about this sweat."
          }
        },
        {
          "type": "card",
          "settings": {
            "color_theme": "orange",
            "icon": "🥩",
            "title": "Apocrine Glands",
            "subtitle": "The Buffet",
            "body": "Located in your armpits and groin. They produce a thick, milky sweat packed with proteins and lipids (fats). This is the ultimate feast for skin bacteria, leading directly to body odor."
          }
        },
        {
          "type": "card",
          "settings": {
            "color_theme": "purple",
            "icon": "🧬",
            "title": "Apoeccrine Glands",
            "subtitle": "The Hybrid",
            "body": "Developing during puberty, these hybrid glands produce a massive volume of watery sweat but share traits with Apocrine glands. They are the reason teenagers suddenly start smelling."
          }
        }
      ]
    }
  ]
}
{% endschema %}
