{% comment %}
  Vectors Showcase Section
  Shows a grid of vector cards with customizable content
{% endcomment %}

<div class="HC-vectors-section">
  <div class="HC-vectors-container page-width">
    <div class="HC-vectors-grid">
      {% for block in section.blocks %}
        <div class="HC-vector-card" {{ block.shopify_attributes }}>
          <div class="HC-vector-content">
            {% if block.settings.vector_label != blank %}
              <div class="HC-vector-label">{{ block.settings.vector_label }}</div>
            {% endif %}
            
            {% if block.settings.vector_title != blank %}
              <h3 class="HC-vector-title">{{ block.settings.vector_title }}</h3>
            {% endif %}
            
            {% if block.settings.vector_description != blank %}
              <p class="HC-vector-description">{{ block.settings.vector_description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .HC-vectors-section {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .HC-vectors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(245px, 1fr));
    gap: {{ section.settings.grid_gap }}px;
  }

  .HC-vector-card {
    background-color: {{ section.settings.card_background }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    padding: {{ section.settings.card_padding }}px;
    transition: all 0.3s ease;
    width: auto;
    height: auto;
    display: flex;
    flex-direction: column;
  }

  .HC-vector-card:hover {
    transform: translateY({{ section.settings.hover_lift }}px);
    border-color: {{ section.settings.card_border_hover_color }};
  }

  .HC-vector-content {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.content_gap }}px;
  }

  .HC-vector-label {
    font-size: 0.75rem;
    line-height: 1.3;
    color: #b45309;
    font-weight: 700;
    text-transform: uppercase;
}

  .HC-vector-title {
    color: {{ section.settings.title_color }};
    font-weight: {{ section.settings.title_font_weight }};
    text-transform: uppercase;
  }

  .HC-vector-title {
    font-size: 22px;
    font-size: 1.5rem;
    line-height: 1.4;
    color: #ffffff;
    font-weight: 700;
}

  .HC-vector-card:hover .HC-vector-title {
    color: #B45309;
  }

  .HC-vector-description {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #6b7280;
}

  @media (max-width: 768px) {
    .HC-vectors-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .HC-vectors-section {
      padding: {{ section.settings.mobile_padding_top }}px 0 {{ section.settings.mobile_padding_bottom }}px;
    }
  }

  @media (max-width: 480px) {
    .HC-vectors-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "HC Science Of Smell",
  "tag": "section",
  "class": "HC-vectors-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap Between Cards",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "card_border_hover_color",
      "label": "Card Border Hover Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Card Border Width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card Padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "hover_lift",
      "label": "Hover Lift Effect",
      "min": -10,
      "max": 0,
      "step": 1,
      "unit": "px",
      "default": -3
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content Gap",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "vector_card",
      "name": "Vector Card",
      "settings": [
        {
          "type": "text",
          "id": "vector_label",
          "label": "Label",
          "default": "VECTOR 01"
        },
        {
          "type": "text",
          "id": "vector_title",
          "label": "Title",
          "default": "BACTERIA"
        },
        {
          "type": "textarea",
          "id": "vector_description",
          "label": "Description",
          "default": "Microbes feeding on sweat proteins."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC Science Of Smell",
      "blocks": [
        {
          "type": "vector_card",
          "settings": {
            "vector_label": "VECTOR 01",
            "vector_title": "BACTERIA",
            "vector_description": "Microbes feeding on sweat proteins."
          }
        },
        {
          "type": "vector_card",
          "settings": {
            "vector_label": "VECTOR 02",
            "vector_title": "FUNGUS",
            "vector_description": "Yeast/mold in damp fibers."
          }
        },
        {
          "type": "vector_card",
          "settings": {
            "vector_label": "VECTOR 03",
            "vector_title": "BODY OILS",
            "vector_description": "Lipid oxidation (rancidity)."
          }
        },
        {
          "type": "vector_card",
          "settings": {
            "vector_label": "VECTOR 04",
            "vector_title": "ENVIRONMENT",
            "vector_description": "Smoke, food, pollution absorption."
          }
        },
        {
          "type": "vector_card",
          "settings": {
            "vector_label": "VECTOR 05",
            "vector_title": "VOCS",
            "vector_description": "Stress hormones and volatile compounds."
          }
        }
      ]
