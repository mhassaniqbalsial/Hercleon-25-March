{% comment %}
  Tab Content Section - Overview
  
  This section is controlled by the hc-product-tabs-nav section
  It will only display when its tab_id matches the active tab

  # Get the active tab from body attribute (will be set by JavaScript)
  # For initial render, default to first tab if this section's tab_id is empty
{% endcomment %}

{%- liquid
  
  assign current_tab = section.settings.tab_id
  
  assign should_render = false
  if current_tab == blank
    assign should_render = true
  endif
-%}

{%- style -%}
  .hc-tab-content-section {
    display: none;
    opacity: 0;
    animation: hc-tab-fade-in 0.4s ease forwards;
  }

  .hc-tab-content-section.hc-tab-content-section--visible {
    display: block;
  }

  .hc-tab-content-highlights {
    overflow: visible;
  }

  @keyframes hc-tab-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .hc-no-specific-mod-section {
    padding: 6rem 0;
    text-align: center;
    background: #f9fafb;
    border-bottom: 1px solid #000;
  }
  .hc-no-specific-mod-text {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875rem;
    text-transform: uppercase;
    color: #6b7280;
    margin: 0;
  }

{%- endstyle -%} 

<div 
