          {%- when 'comfort-sweat-absorbed' -%}
            {% render 'comfort-fit-sweat', block: block %}
          {%- when 'comfort-softness' -%}
            {% render 'comfort-fit-softness', block: block %}
          {%- when 'durability-lifespan' -%}
            {% render 'durability-lifespan', block: block %}
          {%- when 'durability-laundry' -%}
            {% render 'durability-laundry', block: block %}
          {%- when 'durability-investment' -%}
            {% render 'durability-investment', block: block %}
          {%- when 'briefing-washing' -%}
