{% comment %}
  HC OS Fashion Future Section
  Class prefix: hc-os-fashion-future-
{% endcomment %}

{%- liquid
  assign pt_mobile = section.settings.padding_top_mobile | default: 128
  assign pb_mobile = section.settings.padding_bottom_mobile | default: 128
  assign pt_desktop = section.settings.padding_top_desktop | default: 128
  assign pb_desktop = section.settings.padding_bottom_desktop | default: 128
-%}
{%- style -%}
  .hc-os-fashion-future {
    padding-top: {{ pt_mobile }}px;
    padding-bottom: {{ pb_mobile }}px;
    padding-left: 24px;
    padding-right: 24px;
    background-color: #000;
    color: #fff;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-future {
      padding-top: {{ pt_desktop }}px;
      padding-bottom: {{ pb_desktop }}px;
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  .hc-os-fashion-future__inner {
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .hc-os-fashion-future__heading {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 3rem;
    line-height: 1.2;
    color: #ffffff;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-future__heading {
      font-size: 3.75rem;
    }
  }

  .hc-os-fashion-future__buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-future__buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  .hc-os-fashion-future__btn {
    display: inline-block;
    width: 100%;
    padding: 1rem 2.5rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    text-decoration: none;
    border: 2px solid transparent;
    min-width: 200px;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-future__btn {
      width: auto;
    }
  }

  .hc-os-fashion-future__btn--primary {
    background-color: #fff;
    color: #000;
    border-color: #fff;
  }

  .hc-os-fashion-future__btn--primary:hover {
    background-color: #B45309;
    color: #fff;
    border-color: #B45309;
  }

  .hc-os-fashion-future__btn--secondary {
    background-color: transparent;
    color: #fff;
    border-color: #fff;
  }

  .hc-os-fashion-future__btn--secondary:hover {
    background-color: #fff;
    color: #000;
  }
{%- endstyle -%}

<section class="hc-os-fashion-future" id="{{ section.id }}">
  <div class="hc-os-fashion-future__inner">
    <h2 class="hc-os-fashion-future__heading">
      {{ section.settings.heading | default: 'Experience the Future of Clothing' }}
    </h2>
    <div class="hc-os-fashion-future__buttons">
      {%- if section.settings.primary_button_label != blank -%}
        <a href="{{ section.settings.primary_button_link | default: '#' }}" class="hc-os-fashion-future__btn hc-os-fashion-future__btn--primary">
          {{ section.settings.primary_button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_button_label != blank -%}
        <a href="{{ section.settings.secondary_button_link | default: '#' }}" class="hc-os-fashion-future__btn hc-os-fashion-future__btn--secondary">
          {{ section.settings.secondary_button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HC OS Future",
  "tag": "section",
  "class": "shopify-section--hc-os-fashion-future",
  "settings": [
    {
      "type": "header",
      "content": "Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top desktop",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom desktop",
      "default": 128
    },
    {
      "type": "header",
      "content": "Padding (Mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 128
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Experience the Future of Clothing"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop Shirts"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Explore the Science"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "HC OS Future"
    }
  ]
}
{% endschema %}
