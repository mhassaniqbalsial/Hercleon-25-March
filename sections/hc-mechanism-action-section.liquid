{% comment %}
  Mechanism of Action Section with Lab Results and Variable Length Progress Bars with Arrows
  All classes prefixed with HC
{% endcomment %}

<section class="HC-mechanism-section" 
  id="HC-mechanism-{{ section.id }}"
  style="
  background-color: {{ section.settings.background_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
">
  <div class="HC-mechanism-container">
    <div class="HC-mechanism-grid">
      
      {%- comment -%} Left Side - Mechanism of Action {%- endcomment -%}
      <div class="HC-mechanism-content">
        <h2 class="HC-mechanism-title">
          {{ section.settings.section_title }}
        </h2>

        <div class="HC-mechanism-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'mechanism_item' -%}
              <div class="HC-mechanism-item HC-animate-item" {{ block.shopify_attributes }}>
                <div class="HC-mechanism-number">
                  {{ block.settings.number }}
                </div>
                <div class="HC-mechanism-details">
                  <h3 class="HC-mechanism-item-title">
                    {{ block.settings.title }}
                  </h3>
                  <p class="HC-mechanism-description"> 
                    {{ block.settings.description }}
                  </p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Right Side - Lab Results {%- endcomment -%}
      <div class="HC-lab-results" style="
        background-color: {{ section.settings.lab_bg_color }};
      ">
        <div class="HC-lab-header HC-animate-item">
          {{ section.settings.lab_results_header }}
        </div>

        <div class="HC-lab-items">
          {%- for block in section.blocks -%}
            {%- if block.type == 'lab_result' -%}
              <div class="HC-lab-item HC-animate-item" data-progress="{{ block.settings.progress_percentage }}" {{ block.shopify_attributes }}>
                <div class="HC-lab-item-content">
                  <span class="HC-lab-bacteria">
                    {{ block.settings.bacteria_name }} 
                  </span>
                  <span class="HC-lab-reduction" style="
                    color: {{ section.settings.reduction_color }};
                    font-size: {{ section.settings.reduction_size }}px;
                  ">
                    {{ block.settings.reduction_percentage }}
                  </span>
                </div>
                <div class="HC-progress-bar-container">
                  <div class="HC-progress-bar-fill" style="background-color: {{ section.settings.divider_color }};">
                    <div class="HC-progress-arrow" style="border-left-color: {{ section.settings.divider_color }};"></div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  #HC-mechanism-{{ section.id }} {
    width: 100%;
    position: relative;
  }

  #HC-mechanism-{{ section.id }} .HC-mechanism-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    align-items: stretch;
    border-top: 1px solid #000000;
    border-bottom: 1px solid #9ca3af;
  }

  #HC-mechanism-{{ section.id }} .HC-mechanism-content {
    padding: 6rem;
  }

  .HC-mechanism-title {
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 2rem;
}

.HC-lab-bacteria {
    font-family: var(--font-heading-family);
    color: #fff;
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 700;
}

  #HC-mechanism-{{ section.id }} .HC-mechanism-list {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  #HC-mechanism-{{ section.id }} .HC-mechanism-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    opacity: 0;
    transform: translateY(30px);
  }

  #HC-mechanism-{{ section.id }} .HC-mechanism-item.HC-visible {
    opacity: 1;
    transform: translateY(0);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #HC-mechanism-{{ section.id }} .HC-mechanism-item:nth-child(1).HC-visible { 
    transition-delay: 0.1s; 
  }
  #HC-mechanism-{{ section.id }} .HC-mechanism-item:nth-child(2).HC-visible { 
    transition-delay: 0.2s; 
  }
  #HC-mechanism-{{ section.id }} .HC-mechanism-item:nth-child(3).HC-visible { 
    transition-delay: 0.3s; 
  }

  #HC-mechanism-{{ section.id }} .HC-mechanism-number {
    flex-shrink: 0;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    color: #b45309;
  }

  #HC-mechanism-{{ section.id }} .HC-mechanism-details {
    flex: 1;
  }

  .HC-mechanism-item-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .HC-mechanism-description {
    font-size: 0.875rem;
    line-height: 1.3;
    color: #666666;
}

  #HC-mechanism-{{ section.id }} .HC-lab-results {
    padding: 6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

 .HC-lab-header {
  color: #b45309;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 2rem;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item {
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateX(-40px);
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item.HC-visible {
    opacity: 1;
    transform: translateX(0);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(1).HC-visible { 
    transition-delay: 0.3s; 
  }
  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(2).HC-visible { 
    transition-delay: 0.5s; 
  }
  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(3).HC-visible { 
    transition-delay: 0.7s; 
  }

 .HC-lab-item-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0px 0 7px;
    margin-top: 40px;
  }

  .HC-lab-item:first-child .HC-lab-item-content {
    margin-top: 0px;
  }

.HC-lab-reduction {
  font-size: 16px;
  line-height: 1.2;
  color: #b45309;
}

  /* Progress Bar with Arrow Styling */
  #HC-mechanism-{{ section.id }} .HC-progress-bar-container {
    position: relative;
    height: 4px;
    width: 100%;
    overflow: visible;
    background: #1f2937;
  }

  #HC-mechanism-{{ section.id }} .HC-progress-bar-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    transform-origin: left center;
  }

  /* Arrow at the end of progress bar */
  #HC-mechanism-{{ section.id }} .HC-progress-arrow {
    position: absolute;
    right: -8px;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 10px solid;
    opacity: 0;
  }

  /* Progress bar animations with variable widths */
  #HC-mechanism-{{ section.id }} .HC-lab-item.HC-visible .HC-progress-bar-fill {
    animation: HC-progressBarGrow 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item.HC-visible .HC-progress-arrow {
    animation: HC-arrowAppear 0.3s ease-out forwards;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(1).HC-visible .HC-progress-bar-fill {
    animation-delay: 0.4s;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(1).HC-visible .HC-progress-arrow {
    animation-delay: 1.7s;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(2).HC-visible .HC-progress-bar-fill {
    animation-delay: 0.6s;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(2).HC-visible .HC-progress-arrow {
    animation-delay: 1.9s;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(3).HC-visible .HC-progress-bar-fill {
    animation-delay: 0.8s;
  }

  #HC-mechanism-{{ section.id }} .HC-lab-item:nth-child(3).HC-visible .HC-progress-arrow {
    animation-delay: 2.1s;
  }

  @keyframes HC-progressBarGrow {
    0% {
      width: 0%;
    }
    100% {
      width: var(--progress-width, 100%);
    }
  }

  @keyframes HC-arrowAppear {
    0% {
      opacity: 0;
      transform: translateY(-50%) translateX(-10px);
    }
    100% {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
  }

  @media (max-width: 1024px) {
    #HC-mechanism-{{ section.id }} .HC-lab-results {
    padding: 3.75rem;
  
  }
  #HC-mechanism-{{ section.id }} .HC-mechanism-content {
    padding: 3.75rem;
  }
}

  @media (max-width: 991px) {
    #HC-mechanism-{{ section.id }} .HC-mechanism-grid {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    #HC-mechanism-{{ section.id }} .HC-mechanism-content,
    #HC-mechanism-{{ section.id }} .HC-lab-results {
      padding: 3rem;
    }
  }

  @media (max-width: 767px) {

    #HC-mechanism-{{ section.id }} .HC-lab-title {
      font-size: 22px !important;
      margin-bottom: 30px;
    }

    #HC-mechanism-{{ section.id }} .HC-progress-arrow {
      right: -6px;
      border-top: 5px solid transparent;
      border-bottom: 5px solid transparent;
      border-left: 8px solid;
    }
  }
</style>

<script>
(function() {
  const sectionId = 'HC-mechanism-{{ section.id }}';
  const section = document.getElementById(sectionId);
  
  if (!section) return;

  const observerConfig = {
    root: null,
    rootMargin: '-50px',
    threshold: 0.15
  };

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('HC-visible');
        
        // Set custom progress width for each lab item
        if (entry.target.classList.contains('HC-lab-item')) {
          const progressPercentage = entry.target.getAttribute('data-progress');
          if (progressPercentage) {
            const progressBar = entry.target.querySelector('.HC-progress-bar-fill');
            if (progressBar) {
              progressBar.style.setProperty('--progress-width', progressPercentage + '%');
            }
          }
        }
        
        observer.unobserve(entry.target);
      }
    });
  }, observerConfig);

  function initHCAnimations() {
    const animatedElements = section.querySelectorAll('.HC-animate-item');
    animatedElements.forEach(function(element) {
      observer.observe(element);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHCAnimations);
  } else {
    initHCAnimations();
  }

  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        setTimeout(initHCAnimations, 100);
      }
    });
    
    document.addEventListener('shopify:section:reorder', function() {
      setTimeout(initHCAnimations, 100);
    });
  }

  setTimeout(function() {
    const sectionRect = section.getBoundingClientRect();
    const isInViewport = sectionRect.top < window.innerHeight && sectionRect.bottom > 0;
    
    if (isInViewport) {
      const animatedElements = section.querySelectorAll('.HC-animate-item');
      animatedElements.forEach(function(element) {
        element.classList.add('HC-visible');
        
        if (element.classList.contains('HC-lab-item')) {
          const progressPercentage = element.getAttribute('data-progress');
          if (progressPercentage) {
            const progressBar = element.querySelector('.HC-progress-bar-fill');
            if (progressBar) {
              progressBar.style.setProperty('--progress-width', progressPercentage + '%');
            }
          }
        }
      });
    }
  }, 100);

})();
</script>

