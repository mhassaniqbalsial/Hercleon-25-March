{% comment %}
  HC OS Fashion Benefits Section
  Class prefix: hc-os-fashion-benifits
{% endcomment %}

{% style %}
  .hc-os-fashion-benifits {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: #F5F5F5;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-benifits {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .hc-os-fashion-benifits__inner {
    max-width: 1480px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-benifits__inner {
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  .hc-os-fashion-benifits__header {
    text-align: center;
    margin-bottom: 96px;
  }

  .hc-os-fashion-benifits__title {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
    line-height: 1.2;
    color: #111827;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-benifits__title {
      font-size: 3.75rem;
    }
  }

  .hc-os-fashion-benifits__subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #6b7280;
  }

  .hc-os-fashion-benifits__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 768px) {
    .hc-os-fashion-benifits__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .hc-os-fashion-benifits__card {
    background-color: #ffffff;
    padding: 42px;
    border: 1px solid #e5e7eb;
  }

  .hc-os-fashion-benifits__card-number {
    display: block;
    font-size: 2.25rem;
    font-weight: 700;
    color: #B45309;
    margin-bottom: 24px;
    line-height: 1.2;
  }

 .hc-os-fashion-benifits__card-title {
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
    line-height: 1.3;
    color: #111827;
}

  .hc-os-fashion-benifits__card-text {
    color: #4b5563;
    font-weight: 300;
    line-height: 1.625;
  }
{% endstyle %}

<section class="hc-os-fashion-benifits" id="section-{{ section.id }}">
  <div class="hc-os-fashion-benifits__inner">
    <div class="hc-os-fashion-benifits__header">
      <h2 class="hc-os-fashion-benifits__title">{{ section.settings.heading | default: 'The Smell-Proof Breakthrough' }}</h2>
      <p class="hc-os-fashion-benifits__subtitle">{{ section.settings.subheading | default: 'A new kind of fiber blend, built from minerals and plants, not chemicals.' }}</p>
    </div>

    <div class="hc-os-fashion-benifits__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'benefit' %}
            <div class="hc-os-fashion-benifits__card" {{ block.shopify_attributes }}>
              <span class="hc-os-fashion-benifits__card-number">{{ block.settings.number | default: '01' }}</span>
              <h3 class="hc-os-fashion-benifits__card-title">{{ block.settings.title | default: 'Discovery' }}</h3>
              <p class="hc-os-fashion-benifits__card-text">{{ block.settings.text | default: 'Understanding the biology of odor. Identifying the 5 odor types. Mapping why every fabric fails.' }}</p>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HC OS Benefits",
  "tag": "section",
  "class": "section-hc-os-fashion-benifits",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Smell-Proof Breakthrough"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A new kind of fiber blend, built from minerals and plants, not chemicals."
    },
    {
      "type": "header",
      "content": "Padding — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 128
    },
    {
      "type": "header",
      "content": "Padding — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Discovery"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Understanding the biology of odor. Identifying the 5 odor types. Mapping why every fabric fails."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC OS Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "number": "01",
            "title": "Discovery",
            "text": "Understanding the biology of odor. Identifying the 5 odor types. Mapping why every fabric fails."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "number": "02",
            "title": "Engineering",
            "text": "Years of testing mineral blends. Understanding how odor molecules bind. Finding the perfect fiber geometry."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "number": "03",
            "title": "Proof",
            "text": "The first shirts worn for days — even weeks — with no odor breakthrough."
          }
        }
      ]
    }
  ]
}
{% endschema %}
