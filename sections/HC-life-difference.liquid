{% comment %}
  HC Real Life Difference Section
  Displays benefits with title, subtitle, and feature cards
{% endcomment %}

<div class="hc-real-life-wrapper">
  <div class="hc-real-life-container">
    
    {% if section.settings.show_heading %}
      <div class="hc-real-life-header">
        <h2 class="hc-real-life-title">{{ section.settings.main_title }}</h2>
        {% if section.settings.subtitle != blank %}
          <p class="hc-real-life-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="hc-real-life-cards">
      {% for block in section.blocks %}
        {% if block.type == 'feature_card' %}
          <div class="hc-feature-card" {{ block.shopify_attributes }}>
            <div class="hc-card-content">
              <h3 class="hc-card-title">{{ block.settings.card_title }}</h3>
              <p class="hc-card-description">{{ block.settings.card_description }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

<style>
  .hc-real-life-wrapper {
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .hc-real-life-container {
    width: 100%;
    max-width: {{ section.settings.page_width }}px;
    padding: 0px 20px;
    margin:0 auto;
  }

  .hc-real-life-header {
    text-align: center;
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
  }

  .hc-real-life-title {
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: {{ section.settings.title_color }};
    margin: 0 0 {{ section.settings.title_margin_bottom }}px 0;
    text-transform: uppercase;
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
    line-height: 1.2;
  }

  .hc-real-life-subtitle {
    font-size: {{ section.settings.subtitle_font_size }}px;
    color: {{ section.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .hc-real-life-cards {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cards_per_row }}, 1fr);
    gap: {{ section.settings.cards_gap }}px;
  }

  .hc-feature-card {
    background-color: {{ section.settings.card_background }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    transition: all {{ section.settings.card_hover_transition }}s ease;
  }

  .hc-feature-card:hover {
    transform: translateY({{ section.settings.card_hover_transform }}px);
  }

  .hc-card-content {
    text-align: {{ section.settings.card_text_align }};
  }

  .hc-card-title {
    font-size: {{ section.settings.card_title_font_size }}px;
    font-weight: {{ section.settings.card_title_font_weight }};
    color: {{ section.settings.card_title_color }};
    margin: 0 0 {{ section.settings.card_title_margin_bottom }}px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .hc-card-description {
    font-size: {{ section.settings.card_description_font_size }}px;
    color: {{ section.settings.card_description_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 992px) {
    .hc-real-life-cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .hc-real-life-title {
      font-size: {{ section.settings.title_font_size | minus: 8 }}px;
    }
  }

  @media (max-width: 576px) {
    .hc-real-life-cards {
      grid-template-columns: 1fr;
    }

    .hc-real-life-title {
      font-size: {{ section.settings.title_font_size | minus: 12 }}px;
    }

    .hc-real-life-subtitle {
      font-size: {{ section.settings.subtitle_font_size | minus: 2 }}px;
    }

    .hc-card-title {
      font-size: {{ section.settings.card_title_font_size | minus: 2 }}px;
    }

    .hc-card-description {
      font-size: {{ section.settings.card_description_font_size | minus: 1 }}px;
    }
  }
</style>

{% schema %}
{
  "name": "HC Real Life Difference",
  "tag": "section",
  "class": "hc-real-life-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading Settings"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show Heading",
      "default": true
    },
    {
      "type": "text",
      "id": "main_title",
      "label": "Main Title",
      "default": "THE REAL-LIFE DIFFERENCE"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "When your clothing doesn't smell, your entire lifestyle opens up. This is the upgrade most people never knew they needed."
    },
    {
      "type": "range",
      "id": "page_width",
      "label": "Page Width",
      "min": 800,
      "max": 1400,
      "step": 10,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "label": "Header Bottom Margin",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Color Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Title Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title Font Size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "900"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "label": "Title Letter Spacing",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "label": "Title Bottom Margin",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Subtitle Typography"
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Subtitle Font Size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Cards Layout"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "label": "Cards Per Row (Desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "cards_gap",
      "label": "Gap Between Cards",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Card Border Width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card Padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "card_text_align",
      "label": "Card Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Card Hover Effects"
    },
    {
      "type": "range",
      "id": "card_hover_transform",
      "label": "Card Hover Move Up",
      "min": -20,
      "max": 0,
      "step": 1,
      "unit": "px",
      "default": -5
    },
    {
      "type": "range",
      "id": "card_hover_transition",
      "label": "Hover Transition Speed",
      "min": 0.1,
      "max": 1,
      "step": 0.1,
      "unit": "s",
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Card Typography"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#ff6b35"
    },
    {
      "type": "range",
      "id": "card_title_font_size",
      "label": "Card Title Font Size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "card_title_font_weight",
      "label": "Card Title Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "card_title_margin_bottom",
      "label": "Card Title Bottom Margin",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "card_description_color",
      "label": "Card Description Color",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "card_description_font_size",
      "label": "Card Description Font Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "TRAVEL"
        },
        {
          "type": "textarea",
          "id": "card_description",
          "label": "Card Description",
          "default": "Travel with half the clothing. Stop worrying about laundry."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC Real Life Difference",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "card_title": "TRAVEL",
            "card_description": "Travel with half the clothing. Stop worrying about laundry."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "card_title": "WORK",
            "card_description": "Go from flight to meeting to dinner without changing."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "card_title": "LIFE",
            "card_description": "Save hours of laundry time and money on replacements."
          }
        }
      ]
    }
  ]
}
{% endschema %}