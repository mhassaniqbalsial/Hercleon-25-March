{% comment %}
  HercLéon Benefits Section - Why People Love Smell-Proof
  Interactive benefits with dynamic content on hover/click
  Uses Shopify blocks and settings for full customization
{% endcomment %}

<section class="hc-people-love-section" style="background-color: {{ section.settings.section_bg }}; border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};">
  <div class="page-width">
    
    {%- comment -%} Section Header {%- endcomment -%}
    <div class="hc-people-love-header">
      {%- if section.settings.section_label != blank -%}
        <span class="hc-people-love-label" style="color: {{ section.settings.accent_color }};">{{ section.settings.section_label }}</span>
      {%- endif -%}
      {%- if section.settings.section_title != blank -%}
        <h2 class="hc-people-love-title">{{ section.settings.section_title }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} Main Grid Layout {%- endcomment -%}
    <div class="hc-people-love-grid">
      
      {%- comment -%} Left Side - Benefits List {%- endcomment -%}
      <div class="hc-people-love-benefits">
        
        {%- for block in section.blocks -%}
          <div class="hc-people-love-benefit {% if forloop.first %}hc-people-love-benefit-active{% endif %}" 
               data-benefit="{{ block.id }}" 
               {{ block.shopify_attributes }}>
            <div class="hc-people-love-benefit-header">
              <h3 class="hc-people-love-benefit-title">{{ block.settings.benefit_title }}</h3>
              <span class="hc-people-love-benefit-number" style="color: {{ section.settings.accent_color }};">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            </div>
            <p class="hc-people-love-benefit-description">{{ block.settings.benefit_subtitle }}</p>
          </div>
        {%- endfor -%}

      </div>

      {%- comment -%} Right Side - Dynamic Content Box {%- endcomment -%}
      <div class="hc-people-love-display" style="border: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};">
        
        {%- for block in section.blocks -%}
          
          {%- comment -%} Content Type: Baggage Comparison {%- endcomment -%}
          {%- if block.settings.content_type == 'baggage' -%}
            <div class="hc-people-love-content {% if forloop.first %}hc-people-love-content-active{% endif %}" data-content="{{ block.id }}">
              <div class="hc-people-love-baggage-box">
                <p class="hc-people-love-baggage-label">{{ block.settings.baggage_label }}</p>
                
                <div class="hc-people-love-baggage-standard">
                  <div class="hc-people-love-baggage-info">
                    <span>{{ block.settings.standard_label }}</span>
                    <span>{{ block.settings.standard_weight }}</span>
                  </div>
                  <div class="hc-people-love-baggage-items">
                    {%- for i in (1..block.settings.standard_items) -%}
                      <div class="hc-people-love-baggage-item"></div>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="hc-people-love-baggage-hercleon">
                  <div class="hc-people-love-baggage-info">
                    <span>{{ block.settings.herc_label }}</span>
                    <span>{{ block.settings.herc_weight }}</span>
                  </div>
                  <div class="hc-people-love-baggage-items">
                    <div class="hc-people-love-baggage-item-herc" style="background-color: {{ section.settings.accent_color }};"></div>
                  </div>
                </div>
              </div>

              <div class="hc-people-love-text-center">
                <p class="hc-people-love-display-title">{{ block.settings.display_title }}</p>
                <p class="hc-people-love-display-description">{{ block.settings.display_description }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Content Type: Micron Count {%- endcomment -%}
          {%- if block.settings.content_type == 'micron' -%}
            <div class="hc-people-love-content {% if forloop.first %}hc-people-love-content-active{% endif %}" data-content="{{ block.id }}">
              <div class="hc-people-love-micron-box">
                <span class="hc-people-love-micron-label">{{ block.settings.micron_label }}</span>
                
                <div class="hc-people-love-micron-bars">
                  {%- if block.settings.show_cotton -%}
                    <div class="hc-people-love-micron-item">
                      <div class="hc-people-love-micron-header">
                        <span class="hc-people-love-micron-name">Cotton</span>
                        <span class="hc-people-love-micron-value">20μm</span>
                      </div>
                      <div class="hc-people-love-micron-bar">
                        <div class="hc-people-love-micron-fill" style="width: 20%; background-color: #d1d5db;"></div>
                      </div>
                    </div>
                  {%- endif -%}

                  {%- if block.settings.show_merino -%}
                    <div class="hc-people-love-micron-item">
                      <div class="hc-people-love-micron-header">
                        <span class="hc-people-love-micron-name">Merino Wool</span>
                        <span class="hc-people-love-micron-value">18μm</span>
                      </div>
                      <div class="hc-people-love-micron-bar">
                        <div class="hc-people-love-micron-fill" style="width: 18%; background-color: #9ca3af;"></div>
                      </div>
                    </div>
                  {%- endif -%}

                  {%- if block.settings.show_cashmere -%}
                    <div class="hc-people-love-micron-item">
                      <div class="hc-people-love-micron-header">
                        <span class="hc-people-love-micron-name">Cashmere</span>
                        <span class="hc-people-love-micron-value">15μm</span>
                      </div>
                      <div class="hc-people-love-micron-bar">
                        <div class="hc-people-love-micron-fill" style="width: 15%; background-color: #6b7280;"></div>
                      </div>
                    </div>
                  {%- endif -%}

                  {%- if block.settings.show_silk -%}
                    <div class="hc-people-love-micron-item">
                      <div class="hc-people-love-micron-header">
                        <span class="hc-people-love-micron-name">Silk</span>
                        <span class="hc-people-love-micron-value">12μm</span>
                      </div>
                      <div class="hc-people-love-micron-bar">
                        <div class="hc-people-love-micron-fill" style="width: 12%; background-color: #4b5563;"></div>
                      </div>
                    </div>
                  {%- endif -%}

                  <div class="hc-people-love-micron-item">
                    <div class="hc-people-love-micron-header">
                      <span class="hc-people-love-micron-name hc-people-love-micron-herc">{{ block.settings.herc_name }}</span>
                      <span class="hc-people-love-micron-value">10μm</span>
                    </div>
                    <div class="hc-people-love-micron-bar">
                      <div class="hc-people-love-micron-fill" style="width: 10%; background-color: {{ section.settings.accent_color }};"></div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="hc-people-love-text-center">
                <p class="hc-people-love-display-title">{{ block.settings.display_title }}</p>
                <p class="hc-people-love-display-description">{{ block.settings.display_description }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Content Type: Stats Grid {%- endcomment -%}
          {%- if block.settings.content_type == 'stats' -%}
            <div class="hc-people-love-content {% if forloop.first %}hc-people-love-content-active{% endif %}" data-content="{{ block.id }}">
              <div class="hc-people-love-stats-grid">
                {%- if block.settings.stat_1_value != blank -%}
                  <div class="hc-people-love-stat-box">
                    <p class="hc-people-love-stat-number">{{ block.settings.stat_1_value }}</p>
                    <p class="hc-people-love-stat-label {% if block.settings.stat_1_highlight %}hc-people-love-stat-label-orange{% endif %}" 
                       {% if block.settings.stat_1_highlight %}style="color: {{ section.settings.accent_color }};"{% endif %}>
                      {{ block.settings.stat_1_label }}
                    </p>
                  </div>
                {%- endif -%}
                
                {%- if block.settings.stat_2_value != blank -%}
                  <div class="hc-people-love-stat-box">
                    <p class="hc-people-love-stat-number">{{ block.settings.stat_2_value }}</p>
                    <p class="hc-people-love-stat-label {% if block.settings.stat_2_highlight %}hc-people-love-stat-label-orange{% endif %}"
                       {% if block.settings.stat_2_highlight %}style="color: {{ section.settings.accent_color }};"{% endif %}>
                      {{ block.settings.stat_2_label }}
                    </p>
                  </div>
                {%- endif -%}
                
                {%- if block.settings.stat_3_value != blank -%}
                  <div class="hc-people-love-stat-box">
                    <p class="hc-people-love-stat-number">{{ block.settings.stat_3_value }}</p>
                    <p class="hc-people-love-stat-label {% if block.settings.stat_3_highlight %}hc-people-love-stat-label-orange{% endif %}"
                       {% if block.settings.stat_3_highlight %}style="color: {{ section.settings.accent_color }};"{% endif %}>
                      {{ block.settings.stat_3_label }}
                    </p>
                  </div>
                {%- endif -%}
                
                {%- if block.settings.stat_4_value != blank -%}
                  <div class="hc-people-love-stat-box">
                    <p class="hc-people-love-stat-number">{{ block.settings.stat_4_value }}</p>
                    <p class="hc-people-love-stat-label {% if block.settings.stat_4_highlight %}hc-people-love-stat-label-orange{% endif %}"
                       {% if block.settings.stat_4_highlight %}style="color: {{ section.settings.accent_color }};"{% endif %}>
                      {{ block.settings.stat_4_label }}
                    </p>
                  </div>
                {%- endif -%}
              </div>

              <div class="hc-people-love-text-center">
                <p class="hc-people-love-display-title">{{ block.settings.display_title }}</p>
                <p class="hc-people-love-display-description">{{ block.settings.display_description }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Content Type: Timeline {%- endcomment -%}
          {%- if block.settings.content_type == 'timeline' -%}
            <div class="hc-people-love-content {% if forloop.first %}hc-people-love-content-active{% endif %}" data-content="{{ block.id }}">
              <div class="hc-people-love-timeline">
                {%- if block.settings.timeline_1_time != blank -%}
                  <div class="hc-people-love-timeline-item">
                    <div class="hc-people-love-timeline-icon" style="background-color: {{ section.settings.accent_color }};">
                      <svg class="hc-people-love-timeline-check" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="hc-people-love-timeline-time">{{ block.settings.timeline_1_time }}</span>
                    <span class="hc-people-love-timeline-text">{{ block.settings.timeline_1_text }}</span>
                  </div>
                {%- endif -%}

                {%- if block.settings.timeline_2_time != blank -%}
                  <div class="hc-people-love-timeline-item">
                    <div class="hc-people-love-timeline-icon" style="background-color: {{ section.settings.accent_color }};">
                      <svg class="hc-people-love-timeline-check" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="hc-people-love-timeline-time">{{ block.settings.timeline_2_time }}</span>
                    <span class="hc-people-love-timeline-text">{{ block.settings.timeline_2_text }}</span>
                  </div>
                {%- endif -%}

                {%- if block.settings.timeline_3_time != blank -%}
                  <div class="hc-people-love-timeline-item">
                    <div class="hc-people-love-timeline-icon" style="background-color: {{ section.settings.accent_color }};">
                      <svg class="hc-people-love-timeline-check" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="hc-people-love-timeline-time">{{ block.settings.timeline_3_time }}</span>
                    <span class="hc-people-love-timeline-text">{{ block.settings.timeline_3_text }}</span>
                  </div>
                {%- endif -%}

                {%- if block.settings.timeline_4_time != blank -%}
                  <div class="hc-people-love-timeline-item">
                    <div class="hc-people-love-timeline-icon" style="background-color: {{ section.settings.accent_color }};">
                      <svg class="hc-people-love-timeline-check" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="hc-people-love-timeline-time">{{ block.settings.timeline_4_time }}</span>
                    <span class="hc-people-love-timeline-text">{{ block.settings.timeline_4_text }}</span>
                  </div>
                {%- endif -%}
              </div>

              <div class="hc-people-love-text-center">
                <p class="hc-people-love-display-title">{{ block.settings.display_title }}</p>
                <p class="hc-people-love-display-description">{{ block.settings.display_description }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Content Type: Comparison {%- endcomment -%}
          {%- if block.settings.content_type == 'comparison' -%}
            <div class="hc-people-love-content {% if forloop.first %}hc-people-love-content-active{% endif %}" data-content="{{ block.id }}">
              <div class="hc-people-love-chores-grid">
                <div class="hc-people-love-chores-standard">
                  <p class="hc-people-love-chores-title">{{ block.settings.standard_title }}</p>
                  <ul class="hc-people-love-chores-list">
                    {%- if block.settings.standard_item_1 != blank -%}<li>{{ block.settings.standard_item_1 }}</li>{%- endif -%}
                    {%- if block.settings.standard_item_2 != blank -%}<li>{{ block.settings.standard_item_2 }}</li>{%- endif -%}
                    {%- if block.settings.standard_item_3 != blank -%}<li>{{ block.settings.standard_item_3 }}</li>{%- endif -%}
                    {%- if block.settings.standard_item_4 != blank -%}<li>{{ block.settings.standard_item_4 }}</li>{%- endif -%}
                    {%- if block.settings.standard_item_5 != blank -%}<li>{{ block.settings.standard_item_5 }}</li>{%- endif -%}
                    {%- if block.settings.standard_item_6 != blank -%}<li>{{ block.settings.standard_item_6 }}</li>{%- endif -%}
                  </ul>
                </div>

                <div class="hc-people-love-chores-herc" style="background-color: {{ section.settings.accent_color }};">
                  <p class="hc-people-love-chores-title">{{ block.settings.herc_title }}</p>
                  <div class="hc-people-love-chores-zero">
                    <p class="hc-people-love-chores-zero-text">{{ block.settings.herc_text }}</p>
                  </div>
                </div>
              </div>

              <div class="hc-people-love-text-center">
                <p class="hc-people-love-display-title">{{ block.settings.display_title }}</p>
                <p class="hc-people-love-display-description">{{ block.settings.display_description }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Content Type: Durability {%- endcomment -%}
          {%- if block.settings.content_type == 'durability' -%}
            <div class="hc-people-love-content {% if forloop.first %}hc-people-love-content-active{% endif %}" data-content="{{ block.id }}">
              <div class="hc-people-love-durability-wrapper">
                <p class="hc-people-love-durability-label" style="color: {{ section.settings.accent_color }};">{{ block.settings.durability_label }}</p>
                <div class="hc-people-love-durability-grid">
                  {%- if block.settings.durability_1_value != blank -%}
                    <div class="hc-people-love-durability-box">
                      <span class="hc-people-love-durability-number">{{ block.settings.durability_1_value }}</span>
                      <span class="hc-people-love-durability-text">{{ block.settings.durability_1_label }}</span>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.durability_2_value != blank -%}
                    <div class="hc-people-love-durability-box">
                      <span class="hc-people-love-durability-number">{{ block.settings.durability_2_value }}</span>
                      <span class="hc-people-love-durability-text">{{ block.settings.durability_2_label }}</span>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.durability_3_value != blank -%}
                    <div class="hc-people-love-durability-box">
                      <span class="hc-people-love-durability-number">{{ block.settings.durability_3_value }}</span>
                      <span class="hc-people-love-durability-text">{{ block.settings.durability_3_label }}</span>
                    </div>
                  {%- endif -%}
                </div>
              </div>

              <div class="hc-people-love-text-center">
                <p class="hc-people-love-display-title">{{ block.settings.display_title }}</p>
                <p class="hc-people-love-display-description">{{ block.settings.display_description }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Content Type: Antibacterial Table {%- endcomment -%}
          {%- if block.settings.content_type == 'table' -%}
            <div class="hc-people-love-content {% if forloop.first %}hc-people-love-content-active{% endif %}" data-content="{{ block.id }}">
              <div class="hc-people-love-table-wrapper">
                <table class="hc-people-love-table">
                  <thead>
                    <tr class="hc-people-love-table-head-row">
                      <th class="hc-people-love-table-th">Material</th>
                      <th class="hc-people-love-table-th hc-people-love-table-hide-mobile">Mechanism</th>
                      <th class="hc-people-love-table-th">Reduction</th>
                      <th class="hc-people-love-table-th hc-people-love-table-align-right">Speed</th>
                    </tr>
                  </thead>
                  <tbody>
                    {%- if block.settings.show_polyester -%}
                      <tr class="hc-people-love-table-row">
                        <td class="hc-people-love-table-td hc-people-love-table-bold">Polyester</td>
                        <td class="hc-people-love-table-td hc-people-love-table-hide-mobile">No antibacterial abilities</td>
                        <td class="hc-people-love-table-td">0%</td>
                        <td class="hc-people-love-table-td hc-people-love-table-align-right">☆☆☆☆☆</td>
                      </tr>
                    {%- endif -%}

                    {%- if block.settings.show_cotton -%}
                      <tr class="hc-people-love-table-row">
                        <td class="hc-people-love-table-td hc-people-love-table-bold">Cotton</td>
                        <td class="hc-people-love-table-td hc-people-love-table-hide-mobile">Minimize moisture availability</td>
                        <td class="hc-people-love-table-td hc-people-love-table-white">5%</td>
                        <td class="hc-people-love-table-td hc-people-love-table-align-right">★☆☆☆☆</td>
                      </tr>
                    {%- endif -%}

                    {%- if block.settings.show_merino -%}
                      <tr class="hc-people-love-table-row hc-people-love-table-row-white">
                        <td class="hc-people-love-table-td hc-people-love-table-bold">Merino Wool</td>
                        <td class="hc-people-love-table-td hc-people-love-table-hide-mobile hc-people-love-table-gray">Resists but doesn't kill</td>
                        <td class="hc-people-love-table-td">30%</td>
                        <td class="hc-people-love-table-td hc-people-love-table-align-right hc-people-love-table-orange" style="color: {{ section.settings.accent_color }};">★☆☆☆☆</td>
                      </tr>
                    {%- endif -%}

                    {%- if block.settings.show_silver -%}
                      <tr class="hc-people-love-table-row hc-people-love-table-row-white">
                        <td class="hc-people-love-table-td hc-people-love-table-bold">Silver-Infused</td>
                        <td class="hc-people-love-table-td hc-people-love-table-hide-mobile hc-people-love-table-gray">Ions kill on contact</td>
                        <td class="hc-people-love-table-td">99.9%</td>
                        <td class="hc-people-love-table-td hc-people-love-table-align-right hc-people-love-table-orange" style="color: {{ section.settings.accent_color }};">★★★☆☆</td>
                      </tr>
                    {%- endif -%}

                    <tr class="hc-people-love-table-row hc-people-love-table-row-herc">
                      <td class="hc-people-love-table-td hc-people-love-table-bold hc-people-love-table-orange" style="color: {{ section.settings.accent_color }};">{{ block.settings.herc_name }}</td>
                      <td class="hc-people-love-table-td hc-people-love-table-hide-mobile hc-people-love-table-opacity">Multi-mineral matrix</td>
                      <td class="hc-people-love-table-td hc-people-love-table-bold">99.9%</td>
                      <td class="hc-people-love-table-td hc-people-love-table-align-right hc-people-love-table-orange" style="color: {{ section.settings.accent_color }};">★★★★★</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <div class="hc-people-love-text-center">
                <p class="hc-people-love-display-title">{{ block.settings.display_title }}</p>
                <p class="hc-people-love-display-description">{{ block.settings.display_description }}</p>
              </div>
            </div>
          {%- endif -%}

        {%- endfor -%}

      </div>
    </div>

  </div>
</section>

<style>
/* Base Section Styles */
.hc-people-love-section { 
  padding-top: 96px;    
  padding-bottom: 96px;
}

/* Header */
.hc-people-love-header {
  margin-bottom: 64px;
  text-align: center;
}

.hc-people-love-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 16px;
  display: block;
}

.hc-people-love-title {
  font-size: 48px;
  font-weight: 700;
  text-transform: uppercase;
  line-height: 1;
  margin: 0;
}

/* Main Grid */
.hc-people-love-grid {
  display: grid;
  grid-template-columns: repeat(1, minmax(0, 1fr));
  gap: 48px;
  align-items: start;
}

/* Benefits List */
.hc-people-love-benefits {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.hc-people-love-benefit {
  padding: 24px 32px;
  cursor: pointer;
  border: 1px solid #e5e7eb;
  background-color: #fff;
  color: #9ca3af;
  transition: all 0.3s ease;
}

.hc-people-love-benefit:hover {
  border-color: #000;
  color: #000;
}

.hc-people-love-benefit-active {
  background-color: #000;
  color: #fff;
  border-color: #000;
  transform: scale(1.02);
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}

.hc-people-love-benefit-active h3.hc-people-love-benefit-title {
  color: #fff;
}

.hc-people-love-benefit-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 8px;
}

.hc-people-love-benefit-title {
  font-size: 20px;
  font-weight: 700;
  text-transform: uppercase;
  margin: 0;
}

.hc-people-love-benefit-number {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.hc-people-love-benefit:hover .hc-people-love-benefit-number,
.hc-people-love-benefit-active .hc-people-love-benefit-number {
  opacity: 1;
}

.hc-people-love-benefit-description {
  font-size: 14px;
  line-height: 1.5;
  max-width: 448px;
  margin: 0;
  display: none;
}

