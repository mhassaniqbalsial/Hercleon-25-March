<script>
document.addEventListener('DOMContentLoaded', function() {
  const benefits = document.querySelectorAll('.hc-people-love-benefit');
  const contents = document.querySelectorAll('.hc-people-love-content');
  
  function isMobile() {
    return window.innerWidth < 1024;
  }
  
  benefits.forEach(benefit => {
    const eventType = isMobile() ? 'click' : 'mouseenter';
    
    benefit.addEventListener(eventType, function() {
      const benefitId = this.getAttribute('data-benefit');
      
      benefits.forEach(b => b.classList.remove('hc-people-love-benefit-active'));
      this.classList.add('hc-people-love-benefit-active');
      
      contents.forEach(c => c.classList.remove('hc-people-love-content-active'));
      
      const activeContent = document.querySelector(`[data-content="${benefitId}"]`);
      if (activeContent) {
        activeContent.classList.add('hc-people-love-content-active');
      }
    });
  });
});
</script>

