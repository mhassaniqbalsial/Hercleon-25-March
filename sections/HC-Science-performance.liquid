{% comment %}
  HC Science Performance Section
  Class prefix: hc-science-performance-
{% endcomment %}

{% style %}
  .hc-science-performance {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media (min-width: 768px) {
    .hc-science-performance {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
{% endstyle %}

<section class="hc-science-performance">
  <div class="hc-science-performance__inner">
    {% if section.settings.heading != blank %}
      <h2 class="hc-science-performance__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="hc-science-performance__table-wrap">
      <table class="hc-science-performance__table">
        <thead>
          <tr class="hc-science-performance__head-row">
            <th class="hc-science-performance__th hc-science-performance__th--feature">{{ section.settings.col_feature | default: 'Feature' }}</th>
            <th class="hc-science-performance__th hc-science-performance__th--highlight">{{ section.settings.col_hercleon | default: 'HercLeón' }}</th>
            <th class="hc-science-performance__th">{{ section.settings.col_merino | default: 'Merino' }}</th>
            <th class="hc-science-performance__th">{{ section.settings.col_silver | default: 'Silver' }}</th>
            <th class="hc-science-performance__th">{{ section.settings.col_cotton | default: 'Cotton' }}</th>
            <th class="hc-science-performance__th">{{ section.settings.col_poly | default: 'Poly' }}</th>
          </tr>
        </thead>
        <tbody class="hc-science-performance__body">
          {% for block in section.blocks %}
            {% if block.type == 'feature_row' %}
              <tr class="hc-science-performance__row" {{ block.shopify_attributes }}>
                <td class="hc-science-performance__cell hc-science-performance__cell--label">{{ block.settings.feature_name }}</td>
                <td class="hc-science-performance__cell hc-science-performance__cell--highlight">
                  <div class="hc-science-performance__dots">
                    {% for i in (1..5) %}<span class="hc-science-performance__dot hc-science-performance__dot--full"></span>{% endfor %}
                  </div>
                </td>
                <td class="hc-science-performance__cell">
                  <div class="hc-science-performance__dots">
                    {% assign count = block.settings.merino_count | default: 0 %}
                    {% for i in (1..5) %}
                      <span class="hc-science-performance__dot {% if i <= count %}hc-science-performance__dot--full{% else %}hc-science-performance__dot--empty{% endif %}"></span>
                    {% endfor %}
                  </div>
                </td>
                <td class="hc-science-performance__cell">
                  <div class="hc-science-performance__dots">
                    {% assign count = block.settings.silver_count | default: 0 %}
                    {% for i in (1..5) %}
                      <span class="hc-science-performance__dot {% if i <= count %}hc-science-performance__dot--full{% else %}hc-science-performance__dot--empty{% endif %}"></span>
                    {% endfor %}
                  </div>
                </td>
                <td class="hc-science-performance__cell">
                  <div class="hc-science-performance__dots">
                    {% assign count = block.settings.cotton_count | default: 0 %}
                    {% for i in (1..5) %}
                      <span class="hc-science-performance__dot {% if i <= count %}hc-science-performance__dot--full{% else %}hc-science-performance__dot--empty{% endif %}"></span>
                    {% endfor %}
                  </div>
                </td>
                <td class="hc-science-performance__cell">
                  <div class="hc-science-performance__dots">
                    {% assign count = block.settings.poly_count | default: 0 %}
                    {% for i in (1..5) %}
                      <span class="hc-science-performance__dot {% if i <= count %}hc-science-performance__dot--full{% else %}hc-science-performance__dot--empty{% endif %}"></span>
                    {% endfor %}
                  </div>
                </td>
              </tr>
            {% elsif block.type == 'rating_row' %}
              <tr class="hc-science-performance__row hc-science-performance__row--rating" {{ block.shopify_attributes }}>
                <td class="hc-science-performance__cell hc-science-performance__cell--rating-label">{{ block.settings.rating_label }}</td>
                <td class="hc-science-performance__cell hc-science-performance__cell--rating-value hc-science-performance__cell-highlight">{{ block.settings.hercleon_rating }}</td>
                <td class="hc-science-performance__cell hc-science-performance__cell--rating-value ">{{ block.settings.merino_rating }}</td>
                <td class="hc-science-performance__cell hc-science-performance__cell--rating-value">{{ block.settings.silver_rating }}</td>
                <td class="hc-science-performance__cell hc-science-performance__cell--rating-value">{{ block.settings.cotton_rating }}</td>
                <td class="hc-science-performance__cell hc-science-performance__cell--rating-value">{{ block.settings.poly_rating }}</td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .hc-science-performance {
    background-color: #000;
    color: #fff;
    overflow: hidden;
    padding-left: 24px;
    padding-right: 24px;
  }

  @media (min-width: 768px) {
    .hc-science-performance {
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  .hc-science-performance__inner {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .hc-science-performance__heading {
    font-size: 1.875rem;
    line-height: 1.2;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
    color: #ffffff;
  }

  .hc-science-performance__table-wrap {
    overflow-x: auto;
  }

  .hc-science-performance__table {
    width: 100%;
    text-align: left;
    border-collapse: collapse;
    min-width: 900px;
  }

  .hc-science-performance__head-row {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.5);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hc-science-performance__th {
    padding: 1.5rem 1rem;
    font-size: 10px;
  }

  .hc-science-performance__th--feature {
    width: 33.333%;
  }

  .hc-science-performance__th--highlight,
  .hc-science-performance__th:not(.hc-science-performance__th--feature) {
    width: 16.666%;
    text-align: center;
  }

  .hc-science-performance__th--highlight {
    color: #B45309;
    font-weight: 700;
    font-size: 1.125rem;
    background: rgba(255, 255, 255, 0.05);
  }

  td.hc-science-performance__cell.hc-science-performance__cell--rating-value.hc-science-performance__cell-highlight {
    font-family: var(--font-heading-family);
    color: #b45309;
}

  .hc-science-performance__body {
    font-size: 0.875rem;
  }

  .hc-science-performance__row {
    border-bottom: 1px solid rgba(0, 0, 0, 0.5);
    transition: background-color 0.2s ease;
  }

  .hc-science-performance__row:hover {
    background-color: rgba(255, 255, 255, 0.05);
  }

  .hc-science-performance__row--rating {
    background: rgba(180, 83, 9, 0.1);
  }

  .hc-science-performance__row--rating:hover {
    background: rgba(180, 83, 9, 0.1);
  }

  .hc-science-performance__cell {
    padding: 1rem;
  }

  .hc-science-performance__cell--label {
    font-size: 0.875rem;
    line-height: 1.2;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #d1d5db;
}

  .hc-science-performance__cell--highlight {
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
  }

  .hc-science-performance__cell:not(.hc-science-performance__cell--label):not(.hc-science-performance__cell--rating-label) {
    text-align: center;
  }

  .hc-science-performance__dots {
    display: flex;
    justify-content: center;
    gap: 4px;
  }

  .hc-science-performance__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hc-science-performance__dot--full {
    background-color: #B45309;
  }

  .hc-science-performance__dot--empty {
    background-color: rgba(255, 255, 255, 0.15);
  }

  .hc-science-performance__cell:not(.hc-science-performance__cell--highlight) .hc-science-performance__dot--full {
    background-color: #fff;
  }

  .hc-science-performance__cell:not(.hc-science-performance__cell--highlight) .hc-science-performance__dot--empty {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .hc-science-performance__cell--rating-label {
    font-size: 0.875rem;
    padding: 1.5rem 1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #B45309;
}

  .hc-science-performance__cell--rating-value {
    padding: 1.5rem 1rem;
    text-align: center;
    font-weight: 700;
    font-size: 1.5rem;
    color: #B45309;
  }

  .hc-science-performance__row--rating .hc-science-performance__cell--rating-value:not(:first-of-type) {
    font-family: var(--font-heading-family);
    color: #6b7280;
    font-size: 1.5rem;
    line-height: 1.2;
}


</style>

{% schema %}
{
  "name": "HC Science Performance",
  "tag": "section",
  "class": "section-hc-science-performance",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Smell-Proof Performance At A Glance"
    },
    {
      "type": "header",
      "content": "Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 96
    },
    {
      "type": "header",
      "content": "Padding (Mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 96
    },
    {
      "type": "header",
      "content": "Table column labels"
    },
    {
      "type": "text",
      "id": "col_feature",
      "label": "Feature column",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "col_hercleon",
      "label": "HercLeón column",
      "default": "HercLeón"
    },
    {
      "type": "text",
      "id": "col_merino",
      "label": "Merino column",
      "default": "Merino"
    },
    {
      "type": "text",
      "id": "col_silver",
      "label": "Silver column",
      "default": "Silver"
    },
    {
      "type": "text",
      "id": "col_cotton",
      "label": "Cotton column",
      "default": "Cotton"
    },
    {
      "type": "text",
      "id": "col_poly",
      "label": "Poly column",
      "default": "Poly"
    }
  ],
  "blocks": [
    {
      "type": "feature_row",
      "name": "Feature row",
      "settings": [
        {
          "type": "text",
          "id": "feature_name",
          "label": "Feature name"
        },
        {
          "type": "range",
          "id": "merino_count",
          "min": 0,
          "max": 5,
          "label": "Merino dots",
          "default": 0
        },
        {
          "type": "range",
          "id": "silver_count",
          "min": 0,
          "max": 5,
          "label": "Silver dots",
          "default": 0
        },
        {
          "type": "range",
          "id": "cotton_count",
          "min": 0,
          "max": 5,
          "label": "Cotton dots",
          "default": 0
        },
        {
          "type": "range",
          "id": "poly_count",
          "min": 0,
          "max": 5,
          "label": "Poly dots",
          "default": 0
        }
      ]
    },
    {
      "type": "rating_row",
      "name": "Overall rating row",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "rating_label",
          "label": "Rating label",
          "default": "Overall SPR™ Rating"
        },
        {
          "type": "text",
          "id": "hercleon_rating",
          "label": "HercLeón rating",
          "default": "9–10"
        },
        {
          "type": "text",
          "id": "merino_rating",
          "label": "Merino rating",
          "default": "1"
        },
        {
          "type": "text",
          "id": "silver_rating",
          "label": "Silver rating",
          "default": "2–3"
        },
        {
          "type": "text",
          "id": "cotton_rating",
          "label": "Cotton rating",
          "default": "0"
        },
        {
          "type": "text",
          "id": "poly_rating",
          "label": "Poly rating",
          "default": "0"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC Science Performance",
      "blocks": [
        { "type": "feature_row", "settings": { "feature_name": "5 Odor Types", "merino_count": 1, "silver_count": 1, "cotton_count": 0, "poly_count": 0 } },
        { "type": "feature_row", "settings": { "feature_name": "Odor Longevity", "merino_count": 2, "silver_count": 2, "cotton_count": 0, "poly_count": 0 } },
        { "type": "feature_row", "settings": { "feature_name": "Bacteria Control", "merino_count": 2, "silver_count": 2, "cotton_count": 0, "poly_count": 0 } },
        { "type": "feature_row", "settings": { "feature_name": "Oil/Sebum Block", "merino_count": 0, "silver_count": 0, "cotton_count": 0, "poly_count": 1 } },
        { "type": "feature_row", "settings": { "feature_name": "Stress Odor Control", "merino_count": 0, "silver_count": 0, "cotton_count": 0, "poly_count": 0 } },
        { "type": "feature_row", "settings": { "feature_name": "Embedded Odor", "merino_count": 0, "silver_count": 0, "cotton_count": 0, "poly_count": 0 } },
        { "type": "feature_row", "settings": { "feature_name": "Moisture Mgmt", "merino_count": 3, "silver_count": 2, "cotton_count": 2, "poly_count": 4 } },
        { "type": "feature_row", "settings": { "feature_name": "Softness", "merino_count": 4, "silver_count": 2, "cotton_count": 2, "poly_count": 1 } },
        { "type": "feature_row", "settings": { "feature_name": "Durability", "merino_count": 2, "silver_count": 2, "cotton_count": 3, "poly_count": 5 } },
        { "type": "feature_row", "settings": { "feature_name": "Wash Frequency", "merino_count": 2, "silver_count": 2, "cotton_count": 1, "poly_count": 1 } },
        { "type": "rating_row" }
      ]
    }
  ]
}
{% endschema %}
