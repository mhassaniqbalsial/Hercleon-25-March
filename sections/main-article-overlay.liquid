<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .article-overlay-card {
    background-color: var(--article-overlay-bg, #fff);
    padding: var(--sp-8);
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.1);
        max-width: 588px;
    margin: 0 auto;
  }
  .article-overlay-card {
    margin-top: -195px !important;
}
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .article-overlay-card {
      padding: var(--sp-16);
    }
  }
  #shopify-section-{{ section.id }} .article-overlay-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--sp-12);
    padding-bottom: var(--sp-8);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }
  #shopify-section-{{ section.id }} .article-overlay-card__back {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color var(--animation-primary);
    color: #9ca3af;
  }
  #shopify-section-{{ section.id }} a.article-overlay-card__back.reversed-link svg {
    width: 14px;
    height: 14px;
    transition: 0.4s ease;
}

#shopify-section-{{ section.id }} .article-overlay-card__back:hover svg {
    transform: translateX(-6px);
    transition: all 0.4s ease;
}


#shopify-section-{{ section.id }} .article-overlay-card__back:hover,
#shopify-section-{{ section.id }} .article-overlay-card__back:hover a {
    background-size: 0;
}



  #shopify-section-{{ section.id }} .article-overlay-card__back:hover {
    color: rgb(var(--color-foreground));
  }
  #shopify-section-{{ section.id }} .article-overlay-card__date {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-accent, 180 83 9));
  }
  #shopify-section-{{ section.id }} .article-overlay-card__title {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    margin-bottom: var(--sp-12);
  }
  #shopify-section-{{ section.id }} .article-overlay-card__body {
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
    font-size: var(--text-lg);
    line-height: 1.75;
  }
  #shopify-section-{{ section.id }} .article-overlay-card__footer {
    margin-top: var(--sp-16);
    padding-top: var(--sp-12);
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .article-overlay-card__brand {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 600px) {
    #shopify-section-template--25573822529809__main-article .article-overlay-card {
    max-width: 320px;
}
  }
</style>

{%- liquid
  echo 'article.css' | asset_url | stylesheet_tag

  assign number_of_comments = article.comments_count
  if comment.status == 'pending'
    assign number_of_comments = article.comments_count | plus: 1
  endif
-%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <article
    class="article page-width{% if section.settings.narrow %} page-width--narrow{% endif %} relative"
    itemscope
    itemtype="http://schema.org/BlogPosting"
  >
    <div class="article-overlay-card">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'header' -%}
            {%- liquid
              assign date_from_tag = blank
              if block.settings.date_tag_prefix != blank
                for tag in article.tags
                  if tag contains block.settings.date_tag_prefix
                    assign date_from_tag = tag | remove: block.settings.date_tag_prefix | strip
                    break
                  endif
                endfor
              elsif article.tags.size > 0
                assign date_from_tag = article.tags.first
              endif
            -%}
            <div class="article-overlay-card__header" {{ block.shopify_attributes }}>
              <a
                href="{{ blog.url }}"
                class="article-overlay-card__back reversed-link"
                aria-label="{{ blog.title | escape }}"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="w-4 h-4 group-hover:-translate-x-1 transition-transform"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path>
                </svg>
                <span>
                  {{- block.settings.back_label | default: 'Back to' }}
                  {{ blog.title -}}
                </span>
              </a>
              <span class="article-overlay-card__date" itemprop="datePublished">
                {%- if date_from_tag != blank -%}
                  {{ date_from_tag }}
                {%- elsif article.published_at -%}
                  {{ article.published_at | time_tag: format: 'date' }}
                {%- endif -%}
              </span>
            </div>
          {%- when 'title' -%}
            <h1
              class="article-overlay-card__title heading {{ block.settings.title_size }}"
              itemprop="headline"
              {{ block.shopify_attributes }}
            >
              {{ article.title }}
            </h1>
          {%- when 'description' -%}
            <div
              class="article-overlay-card__body rte text-base md:text-lg"
              itemprop="articleBody"
              {{ block.shopify_attributes }}
            >
              {{ article.content }}
            </div>
          {%- when 'footer_brand' -%}
            <div class="article-overlay-card__footer" {{ block.shopify_attributes }}>
              <span class="article-overlay-card__brand heading">
                {{- block.settings.footer_brand | default: shop.name -}}
              </span>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </article>
</div>

{%- assign card_block_types = 'header,title,description,footer_brand' | split: ',' -%}
{%- assign has_other_blocks = false -%}
{%- for block in section.blocks -%}
  {%- unless card_block_types contains block.type -%}
    {%- assign has_other_blocks = true -%}
    {%- break -%}
  {%- endunless -%}
{%- endfor -%}
{%- if section.blocks.size > 0 and has_other_blocks -%}
  <div class="comments-section section{% if section.settings.rounded %} section--rounded relative{% endif %}">
    <div class="page-width{% if section.settings.narrow %} page-width--narrow{% endif %} relative grid gap-8">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {%- render block -%}

          {%- when 'spacing' -%}
            <empty-element
              class="block spacing-section{% if block.settings.height_mobile == 0 %} hidden lg:block{% endif %}{% if block.settings.height == 0 %} lg:hidden{% endif %}"
              style="--spacing-height-desktop: {{ block.settings.height }}px;--spacing-height-mobile: {{ block.settings.height_mobile }}px;"
              {{ block.shopify_attributes }}
            ></empty-element>

          {%- when 'share' -%}
            <div class="flex flex-wrap items-center justify-between" {{ block.shopify_attributes }}>
              {%- liquid
                assign article_url = request.origin | append: article.url
                render 'social-sharing', section_id: section.id, share_id: article.id, share_label: block.settings.share_label, share_title: article.title, share_link: article_url, share_image: article.image
              -%}

              {%- if block.settings.show_comments -%}
                <span class="comment-count inline-flex gap-2 text-xs">
                  {%- render 'icon', icon: 'comment', size: 'xs', class: 'stroke-1' -%}
                  <a class="reversed-link" href="#comments">
                    {{- 'blogs.comments.with_count' | t: count: number_of_comments -}}
                    <span class="sr-only">{{ 'blogs.article.comments_context' | t: title: article.title }}</span>
                  </a>
                </span>
              {%- endif -%}
            </div>

          {%- when 'next_previous_posts' -%}
            {%- if blog.next_article or blog.previous_article -%}
              <ul class="grid md:grid-cols-2 gap-5" {{ block.shopify_attributes }}>
                {%- if blog.previous_article -%}
                  <li class="article-card flex gap-5">
                    {%- render 'icon', icon: 'arrow-left', class: 'transform shrink-0' -%}
                    <div class="flex flex-col gap-3 grow">
                      {%- if block.settings.show_date or block.settings.show_comments or block.settings.show_author -%}
                        <ul class="article-card__top flex flex-wrap gap-4">
                          {%- if block.settings.show_date -%}
                            <li class="inline-flex gap-2 text-xs relative">
                              {%- render 'icon', icon: 'calendar', size: 'xs', class: 'stroke-1' -%}
                              {{- blog.previous_article.published_at | time_tag: format: 'date' -}}
                            </li>
                          {%- endif -%}

                          {%- if block.settings.show_comments -%}
                            <li class="inline-flex gap-2 text-xs relative">
                              {%- render 'icon', icon: 'comment', size: 'xs', class: 'stroke-1' -%}
                              <a class="reversed-link" href="{{ blog.previous_article.url }}#comments">
                                {{- 'blogs.comments.with_count' | t: count: blog.previous_article.comments_count -}}
                                <span class="sr-only">
                                  {{- 'blogs.article.comments_context' | t: title: blog.previous_article.title -}}
                                </span>
                              </a>
                            </li>
                          {%- endif -%}

                          {%- if block.settings.show_author -%}
                            <li class="italic text-xs relative">
                              {%- capture author -%}<span class="font-medium not-italic">{{ blog.previous_article.author }}</span>{%- endcapture -%}
                              {{- 'blogs.article.written_by_html' | t: author: author -}}
                            </li>
                          {%- endif -%}
                        </ul>
                      {%- endif -%}
                      <p>
                        <a
                          class="article-card__title heading reversed-link text-lg-2xl leading-tight tracking-tight"
                          href="{{ blog.previous_article.url }}"
                        >
                          {{- blog.previous_article.title -}}
                        </a>
                      </p>
                    </div>
                  </li>
                {%- endif -%}

                {%- if blog.next_article -%}
                  <li class="article-card flex gap-5">
                    <div class="flex flex-col gap-3 grow">
                      {%- if block.settings.show_date or block.settings.show_comments or block.settings.show_author -%}
                        <ul class="article-card__top flex flex-wrap gap-4">
                          {%- if block.settings.show_date -%}
                            <li class="inline-flex gap-2 text-xs relative">
                              {%- render 'icon', icon: 'calendar', size: 'xs', class: 'stroke-1' -%}
                              {{- blog.next_article.published_at | time_tag: format: 'date' -}}
                            </li>
                          {%- endif -%}

                          {%- if block.settings.show_comments -%}
                            <li class="inline-flex gap-2 text-xs relative">
                              {%- render 'icon', icon: 'comment', size: 'xs', class: 'stroke-1' -%}
                              <a class="reversed-link" href="{{ blog.next_article.url }}#comments">
                                {{- 'blogs.comments.with_count' | t: count: blog.next_article.comments_count -}}
                                <span class="sr-only">
                                  {{- 'blogs.article.comments_context' | t: title: blog.next_article.title -}}
                                </span>
                              </a>
                            </li>
                          {%- endif -%}

                          {%- if block.settings.show_author -%}
                            <li class="italic text-xs relative">
                              {%- capture author -%}<span class="font-medium not-italic">{{ blog.next_article.author }}</span>{%- endcapture -%}
                              {{- 'blogs.article.written_by_html' | t: author: author -}}
                            </li>
                          {%- endif -%}
                        </ul>
                      {%- endif -%}
                      <p>
                        <a
                          class="article-card__title heading reversed-link text-lg-2xl leading-tight tracking-tight"
                          href="{{ blog.next_article.url }}"
                        >
                          {{- blog.next_article.title -}}
                        </a>
                      </p>
                    </div>
                    {%- render 'icon', icon: 'arrow-right', class: 'transform shrink-0' -%}
                  </li>
                {%- endif -%}
              </ul>
            {%- endif -%}

          {%- when 'comments' -%}
            {%- if blog.comments_enabled? -%}
              <div class="comments-wrapper grid gap-5 md:gap-12">
                {%- paginate article.comments by 5 -%}
                  {%- if number_of_comments > 0 -%}
                    <div class="flex flex-col gap-5 md:gap-12">
                      <h3 class="heading lg:text-3xl text-2xl leading-none tracking-tight text-center md:text-left">
                        {{- 'blogs.comments.with_count' | t: count: number_of_comments -}}
                      </h3>

                      <ul class="grid gap-5">
                        {%- if comment.status == 'pending' -%}
                          <li id="Comment-{{ comment.id }}" class="comment-card">
                            {%- render 'article-comment',
                              comment: comment,
                              show_gravatar: block.settings.show_gravatar
                            -%}
                          </li>
                        {%- endif -%}

                        {%- for comment in article.comments -%}
                          <li id="Comment-{{ comment.id }}" class="comment-card">
                            {%- render 'article-comment',
                              comment: comment,
                              show_gravatar: block.settings.show_gravatar
                            -%}
                          </li>
                        {%- endfor -%}
                      </ul>

                      {%- liquid
                        if paginate.pages > 1
                          render 'pagination', paginate: paginate, hash: '#comments'
                        endif
                      -%}
                    </div>
                  {%- endif -%}

                  <div id="comments">
                    {%- form 'new_comment', article, class: 'new-comment grid gap-8' -%}
                      {%- liquid
                        if form.errors
                          assign form_errors = form.errors | default_errors
                          render 'alert', status: 'error', content: form_errors
                        endif

                        if form.posted_successfully?
                          if blog.moderated?
                            assign success_message = 'blogs.comments.success_moderated' | t
                          else
                            assign success_message = 'blogs.comments.success' | t
                          endif
                          render 'alert', status: 'success', content: success_message
                        endif
                      -%}

                      <div class="grid gap-2">
                        <h3 class="heading lg:text-3xl text-2xl leading-none tracking-tight">
                          {{ 'blogs.comments.title' | t }}
                        </h3>
                        {%- if blog.moderated? -%}
                          <p class="text-sm">{{ 'blogs.comments.moderated' | t }}</p>
                        {%- endif -%}
                      </div>
                      <div class="grid gap-3d5 md:gap-4">
                        <div class="grid md:grid-cols-2 gap-3d5 md:gap-4">
                          <div class="field">
                            <input
                              required
                              class="input is-floating"
                              type="text"
                              name="comment[author]"
                              id="CommentAuthor"
                              value="{{ form.author }}"
                              placeholder="{{ 'blogs.comments.name' | t | escape }}"
                              autocapitalize="words"
                            >
                            <label class="label is-floating" for="CommentAuthor">{{ 'blogs.comments.name' | t }}</label>
                          </div>
                          <div class="field">
                            <input
                              required
                              class="input is-floating"
                              type="email"
                              name="comment[email]"
                              id="CommentEmail"
                              value="{{ form.email }}"
                              placeholder="{{ 'blogs.comments.email' | t | escape }}"
                              autocorrect="off"
                              autocapitalize="off"
                            >
                            <label class="label is-floating" for="CommentEmail">{{ 'blogs.comments.email' | t }}</label>
                          </div>
                        </div>
                        <div class="field">
                          <textarea
                            required
                            class="textarea is-floating"
                            name="comment[body]"
                            id="CommentBody"
                            placeholder=" "
                            rows="5"
                          >{{ form.body }}</textarea>
                          <label class="label is-floating" for="CommentBody">{{ 'blogs.comments.message' | t }}</label>
                        </div>
                        <div class="field">
                          <button type="submit" class="button button--primary button--fixed" is="hover-button">
                            <span class="btn-fill" data-fill></span>
                            <span class="btn-text">{{ 'blogs.comments.post' | t }}</span>
                          </button>
                        </div>
                        {%- comment -%}
                          Remove the following three lines of code to remove the note
                          about being protected by Google's reCAPTCHA service.
                          By removing it, the small reCAPTCHA widget will appear in the
                          bottom right corner of the page.
                        {%- endcomment -%}
                        <div class="rte text-sm">
                          {%- comment %}theme-check-disable TranslationKeyExists{%- endcomment %}
                          {{- 'shopify.online_store.spam_detection.disclaimer_html' | t -}}
                          {%- comment %}theme-check-enable TranslationKeyExists{%- endcomment %}
                        </div>
                      </div>
                    {%- endform -%}
                  </div>
                {%- endpaginate -%}
              </div>
            {%- endif -%}

          {%- when 'liquid' -%}
            {%- if block.settings.liquid != blank -%}
              <div class="rte" {{ block.shopify_attributes }}>
                {{- block.settings.liquid -}}
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<script type="application/ld+json">
  {{- article | structured_data -}}
</script>

