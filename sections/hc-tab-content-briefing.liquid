{% comment %}
  Tab Content Section - Briefing
  
  This section is controlled by the hc-product-tabs-nav section
{% endcomment %}

{%- liquid
  assign current_tab = section.settings.tab_id
  assign should_render = false
  if current_tab == blank
    assign should_render = true
  endif
-%}

{%- style -%}
  .hc-tab-content-section {
    display: none;
    opacity: 0;
    animation: hc-tab-fade-in 0.4s ease forwards;
  }

  .hc-tab-content-section.hc-tab-content-section--visible {
    display: block;
  } 

  @keyframes hc-tab-fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 1024px) {
    .hc-tab-content-briefing__list .hc-travel-pack-block__grid {
      flex-direction: row-reverse;
    }
  }

{%- endstyle -%}

<div 
  class="hc-tab-content-section hc-tab-content-briefing {% if should_render %}hc-tab-content-section--visible{% endif %}"
  data-tab-id="{{ section.settings.tab_id }}"
  data-section-id="{{ section.id }}"
>
  <div class="hc-tab-content-briefing">

    {%- if section.blocks.size > 0 -%}
      <div class="hc-tab-content-briefing__list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
          {%- when 'types-of-odor' -%}
            {% render 'odor-types-of-odor', block: block %}
          {%- when 'speak' -%}
            {% render 'odor-speak', block: block %}
          {%- when 'bacteria' -%}
            {% render 'odor-bacteria', block: block %}
          {%- when 'travel-pack' -%}
            {% render 'travel-pack', block: block %}
          {%- when 'travel-clothes' -%}
            {% render 'travel-clothes', block: block %}
          {%- when 'travel-chore' -%}
            {% render 'travel-chore', block: block %}
          {%- when 'stay-fresh' -%}
            {% render 'briefing-stay-fresh', block: block %}
          {%- when 'comfort-sweat-absorbed' -%}
            {% render 'comfort-fit-sweat', block: block %}
          {%- when 'comfort-softness' -%}
            {% render 'comfort-fit-softness', block: block %}
          {%- when 'durability-lifespan' -%}
            {% render 'durability-lifespan', block: block %}
          {%- when 'durability-laundry' -%}
            {% render 'durability-laundry', block: block %}
          {%- when 'durability-investment' -%}
            {% render 'durability-investment', block: block %}
          {%- when 'briefing-washing' -%}
            {% render 'briefing-washing', block: block %}
          {%- when 'soft-cashmere' -%}
            {% render 'highlights-soft-cashmere', block: block %}
          {%- when 'built-to-last' -%}
            {% render 'highlights-built-to-last', block: block %}
          {%- when 'travel-with-less-clothing' -%}
            {% render 'highlights-travel-with-less-clothing', block: block %}
          {%- when 'exp-laundry' -%}
            {% render 'highlights-exp-laundary', block: block %}
          {%- when 'backups-needed' -%}
            {% render 'hc-backups-needed', block: block %}
          {%- when 'moisture-control' -%}
            {% render 'hc-moisture-control', block: block %}
          {%- when 'build-to-last' -%}
            {% render 'hc-build-to-last', block: block %}
          {%- when 'intelligent-investment' -%}
            {% render 'hc-intelligent-investment', block: block %}
          {%- when 'cleaner-planet' -%}
            {% render 'hc-cleaner-planet', block: block %}
          {%- when 'over-consumption' -%}
            {% render 'hc-over-consumption', block: block %}
        {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

