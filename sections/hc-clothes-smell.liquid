<section
  {% if section.settings.story_anchor_id != blank %}id="{{ section.settings.story_anchor_id | strip }}"{% endif %}
  class="hc-clothes-smell"
  style="
    --hc-cs-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --hc-cs-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hc-cs-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --hc-cs-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
  "
>
  <div class="hc-clothes-smell__container">

    {%- if section.settings.eyebrow != blank -%}
      <span class="hc-clothes-smell__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="hc-clothes-smell__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.story_content != blank -%}
      <div class="hc-clothes-smell__story">
        {{ section.settings.story_content }}
      </div>
    {%- endif -%}

    {%- if section.settings.show_mission_card -%}
      <div
        {% if section.settings.mission_anchor_id != blank %}id="{{ section.settings.mission_anchor_id | strip }}"{% endif %}
        class="hc-clothes-smell__mission"
      >
        {%- if section.settings.mission_eyebrow != blank -%}
          <span class="hc-clothes-smell__mission-eyebrow">{{ section.settings.mission_eyebrow }}</span>
        {%- endif -%}

        {%- if section.settings.mission_heading_line1 != blank or section.settings.mission_heading_line2 != blank -%}
          <h3 class="hc-clothes-smell__mission-heading">
            {%- if section.settings.mission_heading_line1 != blank -%}
              <span class="hc-clothes-smell__mission-heading-line">{{ section.settings.mission_heading_line1 }}</span>
            {%- endif -%}
            <br class="hc-clothes-smell__mission-heading-br" aria-hidden="true">
            {%- if section.settings.mission_heading_line2 != blank -%}
              <span class="hc-clothes-smell__mission-heading-line">{{ section.settings.mission_heading_line2 }}</span>
            {%- endif -%}
          </h3>
        {%- endif -%}

        <div class="hc-clothes-smell__mission-rule" aria-hidden="true"></div>

        {%- if section.settings.beliefs_label != blank -%}
          <span class="hc-clothes-smell__beliefs-label">{{ section.settings.beliefs_label }}</span>
        {%- endif -%}

        <div class="hc-clothes-smell__beliefs">
          {%- if section.settings.belief_1 != blank -%}
            <p class="hc-clothes-smell__belief">{{ section.settings.belief_1 | newline_to_br }}</p>
          {%- endif -%}
          {%- if section.settings.belief_2 != blank -%}
            <p class="hc-clothes-smell__belief">{{ section.settings.belief_2 | newline_to_br }}</p>
          {%- endif -%}
          {%- if section.settings.belief_3 != blank -%}
            <p class="hc-clothes-smell__belief hc-clothes-smell__belief--accent">{{ section.settings.belief_3 | newline_to_br }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.footer_note != blank -%}
      <p class="hc-clothes-smell__footer">{{ section.settings.footer_note }}</p>
    {%- endif -%}

  </div>
</section>

<style>
  .hc-clothes-smell {
    background-color: #f9fafb;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
    padding-top: var(--hc-cs-pt-mobile);
    padding-bottom: var(--hc-cs-pb-mobile);
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media (min-width: 768px) {
    .hc-clothes-smell {
      padding-left: 3rem;
      padding-right: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-clothes-smell {
      padding-top: var(--hc-cs-pt-desktop);
      padding-bottom: var(--hc-cs-pb-desktop);
    }
  }

  .hc-clothes-smell__container {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .hc-clothes-smell__eyebrow {
    display: block;
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #B45309;
    margin-bottom: 1.5rem;
  }

  .hc-clothes-smell__heading {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #111827;
    margin-bottom: 3rem;
    line-height: 1.15;
  }

  @media (min-width: 768px) {
    .hc-clothes-smell__heading {
      font-size: 3rem;
    }
  }

  .hc-clothes-smell__story {
    font-size: 1.25rem;
    font-weight: 300;
    color: #4b5563;
    line-height: 1.75;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
    text-align: left;
  }

  .hc-clothes-smell__story > * + * {
    margin-top: 2rem;
  }

  .hc-clothes-smell__story p {
    margin: 0;
  }

  .hc-clothes-smell__story strong {
    font-weight: 500;
    color: #000;
  }

  .hc-clothes-smell__mission {
    background-color: #fff;
    padding: 2rem;
    border-radius: 1rem;
    border: 1px solid #f3f4f6;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    margin-top: 3rem;
    margin-bottom: 3rem;
    text-align: center;
    width: 100%;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .hc-clothes-smell__mission {
      padding: 4rem;
    }
  }

  .hc-clothes-smell__mission-eyebrow {
    display: block;
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #B45309;
    margin-bottom: 1.5rem;
  }

  .hc-clothes-smell__mission-heading {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 3rem;
    line-height: 1.15;
  }

  @media (min-width: 768px) {
    .hc-clothes-smell__mission-heading {
      font-size: 3rem;
    }
  }

  .hc-clothes-smell__mission-heading-br {
    display: none;
  }

  @media (min-width: 768px) {
    .hc-clothes-smell__mission-heading-br {
      display: block;
    }
  }

  .hc-clothes-smell__mission-rule {
    width: 6rem;
    height: 1px;
    background-color: #d1d5db;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 3rem;
  }

  .hc-clothes-smell__beliefs-label {
    display: block;
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .hc-clothes-smell__beliefs {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .hc-clothes-smell__belief {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    line-height: 1.375;
    margin: 0;
  }

  @media (min-width: 768px) {
    .hc-clothes-smell__belief {
      font-size: 1.875rem;
    }
  }

  .hc-clothes-smell__belief--accent {
    font-style: italic;
    color: #B45309;
    text-transform: uppercase;
  }

  .hc-clothes-smell__footer {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
    font-family: monospace;
    font-size: 0.875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.75;
    color: #6b7280;
  }
</style>

{% schema %}
{
  "name": "HC Clothes Smell",
  "tag": "section",
  "class": "hc-clothes-smell-section",
  "settings": [
    {
      "type": "header",
      "content": "Anchors (for jump links)"
    },
    {
      "type": "text",
      "id": "story_anchor_id",
      "label": "Story section HTML id",
      "default": "story",
      "info": "No spaces. Used as id on this section for in-page links."
    },
    {
      "type": "text",
      "id": "mission_anchor_id",
      "label": "Mission card HTML id",
      "default": "mission",
      "info": "No spaces. Placed on the white mission card."
    },
    {
      "type": "header",
      "content": "Story — intro"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Iceland, 2017"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why do clothes smell?"
    },
    {
      "type": "richtext",
      "id": "story_content",
      "label": "Story body",
      "default": "<p>A few months before the trip, Wen, our founder, lost his mom.</p><p>He needed to get away. So he packed a backpack — just a few pieces of clothing — and flew to Iceland.</p><p>He wasn't there to be productive. He was there to breathe, to be somewhere completely different, and hopefully, to feel something other than grief for a little while. His friends were there too, and they wanted to go out — explore, party, live. He wanted that too. More than they probably knew.</p><p>But Iceland had other plans.</p><p>Within days, some of his clothes started smelling. Not subtly — noticeably. The strange thing was, other pieces were completely fine. Same backpack, same trip, same person wearing them. Why were some clothes unbearable after a single wear while others stayed fresh?</p><p>He didn't have a good answer. And he didn't have a laundromat either — their hostel didn't have one, and if you've spent time in Iceland, you already know they're not exactly on every corner. So he did what anyone would do: reached for the cologne, leaned on the deodorant, and tried to convince himself it wasn't that bad.</p><p>It was that bad.</p><p>One by one, evenings he'd planned to spend out with friends became evenings spent in — not because he wanted to, but because he couldn't shake the self-consciousness of knowing he didn't smell great. It sounds small. But when you've traveled thousands of miles to feel alive again, being sidelined by a t-shirt is its own particular kind of defeat.</p><p>On the way home, somewhere over the Atlantic, the question finally crystallized:</p><p><strong>Why do clothes smell? And do they actually have to?</strong></p><p>It felt almost too simple. But he couldn't let it go. Back home, he started digging — into bacteria, enzymes, airflow, material science, fiber construction. He tested yarns, fabrics, and treatments. He failed a lot. He learned more. Two years later, what started as a question on a grief trip to Iceland had become something he hadn't expected:</p><p><strong>A mission. A company. A reason to keep going.</strong></p>"
    },
    {
      "type": "header",
      "content": "Mission card"
    },
    {
      "type": "checkbox",
      "id": "show_mission_card",
      "label": "Show mission card",
      "default": true
    },
    {
      "type": "text",
      "id": "mission_eyebrow",
      "label": "Mission eyebrow",
      "default": "Our Mission"
    },
    {
      "type": "text",
      "id": "mission_heading_line1",
      "label": "Mission heading — line 1 (before line break on desktop)",
      "default": "To free humanity through"
    },
    {
      "type": "text",
      "id": "mission_heading_line2",
      "label": "Mission heading — line 2",
      "default": "the power of our fibers."
    },
    {
      "type": "text",
      "id": "beliefs_label",
      "label": "Beliefs label",
      "default": "Our Beliefs"
    },
    {
      "type": "textarea",
      "id": "belief_1",
      "label": "Belief 1 (line break = new line)",
      "default": "Clothes are costing us more than money.\nThey're costing us time, space, energy,\npeace of mind, and our freedom.\nWorse of all, they're destroying our planet."
    },
    {
      "type": "textarea",
      "id": "belief_2",
      "label": "Belief 2 (line break = new line)",
      "default": "The world doesn't need more clothes.\nIt needs better ones, clothes that do more with less.\nLess washing. Less waste. Less weight on the planet."
    },
    {
      "type": "textarea",
      "id": "belief_3",
      "label": "Belief 3 (accent style)",
      "default": "Every thing we make is a step toward that world."
    },
    {
      "type": "header",
      "content": "Footer note"
    },
    {
      "type": "textarea",
      "id": "footer_note",
      "label": "Closing line",
      "default": "Together, our mission and beliefs became the foundation of HercLeón."
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Spacing — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 128
    }
  ],
  "presets": [
    {
      "name": "HC Clothes Smell"
    }
  ]
}
{% endschema %}
