{% comment %}
  Hercleon Hero Section
{% endcomment %}

<style>
/* ========================================
   BASE STYLES
   ======================================== */

.hc-home-hero-section {
    background-color: #050505;
    color: #ffffff;
}

.hc-home-hero-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    min-height: 90vh;
}

/* ========================================
   STATUS BAR
   ======================================== */
.hc-home-hero-status-bar {
    padding: 12px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
}

.hc-home-hero-status-label {
  color: rgba(255, 255, 255, 0.7);
  text-transform: uppercase;
  font-weight: 400;
}

.hc-home-hero-status-value {
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    font-weight: 600;
}

/* ========================================
   CONTENT AREA
   ======================================== */
.hc-home-hero-content {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 20px 40px;
    margin-top: auto;
}

.hc-home-hero-content-inner {
  position: relative;
  width: 100%;
  {% comment %} max-width: 1400px; {% endcomment %}
  margin: 0 auto;
  z-index: 2;
}

/* ========================================
   HEADING
   ======================================== */
.hc-home-hero-heading-wrapper {
    position: relative;
    margin-bottom: 32px;
    max-width: 760px;
}

.hc-home-hero-heading {
    font-size: 8rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -5.6px;
    text-transform: uppercase;
    color: #ffffff;
}

/* ========================================
   DESCRIPTION
   ======================================== */

.hc-home-hero-description-wrapper {
    position: relative;
    margin-bottom: 32px;
    max-width: 612px;
}

.hc-home-hero-description p {
    font-size: 1rem;
    line-height: 1.4;
    color: #D1D5DB;
    font-weight: 400;
    min-height: 97.97px;
}

/* Tab-specific hero text (HercLeon vs HercLabs) */
.hc-home-hero-text-herclabs {
  display: none;
}
body[data-active-tab="herclabs"] .hc-home-hero-text-hercleon {
  display: none;
}
body[data-active-tab="herclabs"] .hc-home-hero-text-herclabs {
  display: block;
}

/* ========================================
   BUTTONS
   ======================================== */
.hc-home-hero-buttons-wrapper {
  position: relative;
}

.hc-home-hero-buttons {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.hc-home-hero-button-container {
  position: relative;
}

.hc-home-hero-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: 1px solid #ffffff;
    background-color: transparent;
    color: #ffffff;
    cursor: pointer;
    transition: all 0.3s ease;
}

.hc-home-hero-button-text {
  position: relative;
  z-index: 1;
}

.hc-home-hero-button-primary {
  background-color: transparent;
  border-color: #ffffff;
  color: #ffffff;
}

.hc-home-hero-button-primary:hover {
  background-color: #ffffff;
  color: #0a1628;
}

.hc-home-hero-button-secondary {
  background-color: #ffffff;
  border-color: #ffffff;
  color: #0a1628;
}

.hc-home-hero-button-secondary:hover {
    background: #b45309;
    color: #ffffff;
}

.hc-home-hero-footer-bar {
    background-color: #f3f4f6;
    color: #000000;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #e5e7eb;
  }
  .hc-home-hero-footer-bar__container {
    max-width: 1800px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  .hc-home-hero-footer-bar__text {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }
  .hc-home-hero-footer-bar__item {
    margin: 0 0.5rem;
  }
  .hc-home-hero-footer-bar__divider {
    margin: 0 0.5rem;
    opacity: 0.3;
  }
  @media (min-width: 768px) {
    .hc-home-hero-footer-bar__text {
      font-size: 0.875rem;
    }
  }

/* ========================================
   RESPONSIVE: 1280px
   ======================================== */
@media (max-width: 1280px) {

.hc-home-hero-heading-wrapper {
    max-width: 600px;
}

  .hc-home-hero-heading {
    font-size: 96px;
  }

  .hc-home-hero-content {
    padding: 50px 40px;
  }
}

/* ========================================
   RESPONSIVE: 1024px
   ======================================== */
@media (max-width: 1024px) {
  .hc-home-hero-heading {
    font-size: 72px;
  }

  .hc-home-hero-heading-wrapper {
    max-width: 440px;
}

  .hc-home-hero-content {
    padding: 40px 32px;
  }

  .hc-home-hero-status-bar {
    padding: 12px 32px;
  }
}

/* ========================================
   RESPONSIVE: 768px
   ======================================== */
@media (max-width: 768px) {
  .hc-home-hero-section {
    min-height: auto;
  }

  .hc-home-hero-wrapper {
    min-height: 85vh;
  }

  .hc-home-hero-status-left,
  .hc-home-hero-status-right {
    width: 100%;
    flex-wrap: wrap;
  }

  .hc-home-hero-heading {
    font-size: 60px;
    letter-spacing: -3px;
}

  .hc-home-hero-heading-wrapper {
    margin-bottom: 32px;
    max-width: 350px;
}

  .hc-home-hero-company-wrapper {
    margin-bottom: 24px;
  }

  .hc-home-hero-description-wrapper {
    margin-bottom: 40px;
  }

  .hc-home-hero-description {
    font-size: 14px;
  }

  .hc-home-hero-buttons {
    gap: 12px;
    width: 100%;
  }

  .hc-home-hero-status-right {
    text-align: end;
}

  .hc-home-hero-button {
    width: 100%;
    min-width: auto;
    padding: 14px 24px;
    font-size: 13px;
  }
  .hc-home-hero-description p {
  font-size: 0.85rem;
  min-height: 117px;
}
}

/* ========================================
   RESPONSIVE: 600px
   ======================================== */
@media (max-width: 600px) {

  .hc-home-hero-status-bar {
    padding: 2px 20px;
    font-size: 10px;
}

  .hc-home-hero-content {
    padding: 20px;
  }

  .hc-home-hero-heading {
    font-size: 56px;
  }
  
  .hc-home-hero-company-wrapper {
    margin-bottom: 20px;
  }

  .hc-home-hero-company-prefix,
  .hc-home-hero-company-name {
    font-size: 12px;
  }

  .hc-home-hero-description-wrapper {
    margin-bottom: 32px;
  }

  .hc-home-hero-description {
    font-size: 13px;
  }

  .hc-home-hero-button {
    padding: 12px 20px;
    font-size: 12px;
  }

    .hc-home-hero-button-container {
    width: calc(50% - 6px);
  }
}

/* ========================================
   RESPONSIVE: 600px
   ======================================== */
@media (max-width: 375px) {
  .hc-home-hero-button {
    padding: 12px;
    font-size: 12px;
  }
}

@media (max-width: 362px) {

  .hc-home-hero-heading {
    font-size: 50px;
  }

  .hc-home-hero-button {
    font-size: 10px;
  }
}

@media (max-width: 330px) {

  .hc-home-hero-heading {
    font-size: 48px;
  }
}

</style>

<section id="{{ section.settings.section_id }}" class="hc-home-hero-section" data-section-id="{{ section.id }}" data-section-type="hero">
  <div class="hc-home-hero-wrapper">
    {%- if section.settings.show_status_bar -%}
    <div class="hc-home-hero-status-bar">
      <div class="hc-home-hero-status-left">
        <div class="hc-home-hero-status-left-inner">
        <span class="hc-home-hero-status-label">MISSION:</span>
        <span class="hc-home-hero-status-value">{{ section.settings.mission_text }}</span>
        </div>
        <div class="hc-home-hero-status-left-inner">
          <span class="hc-home-hero-status-label">STATUS:</span>
          <span class="hc-home-hero-status-value">{{ section.settings.status_text }}</span>
        </div>
      </div>
      <div class="hc-home-hero-status-right">
        <div class="hc-home-hero-status-right-inner">
        <span class="hc-home-hero-status-label">TEMP:</span>
        <span class="hc-home-hero-status-value">{{ section.settings.temp_text }}</span>
        </div>
        <div class="hc-home-hero-status-right-inner">
        <span class="hc-home-hero-status-label">BACTERIA:</span>
        <span class="hc-home-hero-status-value">{{ section.settings.bacteria_text }}</span>
        </div>
      </div>
    </div>
    {%- endif -%}

    <div class="hc-home-hero-content">
      <div class="hc-home-hero-content-inner">
        {%- comment -%} HercLeon tab text {%- endcomment -%}
        <div class="hc-home-hero-text-hercleon">
          {%- if section.settings.heading != blank -%}
          <div class="hc-home-hero-heading-wrapper">
            <h2 class="hc-home-hero-heading">{{ section.settings.heading }}</h2>
          </div>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
          <div class="hc-home-hero-description-wrapper">
            <div class="hc-home-hero-description">{{ section.settings.description }}</div>
          </div>
          {%- endif -%}
        </div>

        {%- comment -%} HercLabs tab text {%- endcomment -%}
        <div class="hc-home-hero-text-herclabs">
          {%- if section.settings.heading_herclabs != blank -%}
          <div class="hc-home-hero-heading-wrapper">
            <h2 class="hc-home-hero-heading">{{ section.settings.heading_herclabs }}</h2>
          </div>
          {%- endif -%}
          {%- if section.settings.description_herclabs != blank -%}
          <div class="hc-home-hero-description-wrapper">
            <div class="hc-home-hero-description">{{ section.settings.description_herclabs }}</div>
          </div>
          {%- endif -%}
        </div>

        {%- if section.settings.show_buttons -%}
        <div class="hc-home-hero-buttons-wrapper">
          <div class="hc-home-hero-buttons">
            {%- if section.settings.button_1_text != blank -%}
            <div class="hc-home-hero-button-container">
              <a href="{{ section.settings.button_1_link }}" class="hc-home-hero-button hc-home-hero-button-primary">
                <span class="hc-home-hero-button-text">{{ section.settings.button_1_text }}</span>
              </a>
            </div>
            {%- endif -%}

            {%- if section.settings.button_2_text != blank -%}
            <div class="hc-home-hero-button-container">
              <a href="{{ section.settings.button_2_link }}" class="hc-home-hero-button hc-home-hero-button-secondary">
                <span class="hc-home-hero-button-text">{{ section.settings.button_2_text }}</span>
              </a>
            </div>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
      </div>
    </div>
    <div class="hc-home-hero-footer-bar">
  <div class="hc-home-hero-footer-bar__container">
    <p class="hc-home-hero-footer-bar__text">
      <span class="hc-home-hero-footer-bar__item">{{ section.settings.stat_one }}</span>
      <span class="hc-home-hero-footer-bar__divider">|</span>
      <span class="hc-home-hero-footer-bar__item">{{ section.settings.stat_two }}</span>
      <span class="hc-home-hero-footer-bar__divider">|</span>
      <span class="hc-home-hero-footer-bar__item">{{ section.settings.stat_three }}</span>
    </p>
  </div>
</div>
  </div>
</section>

{% schema %}
{
  "name": "HC Hero Section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "hc-home-hero-section"
    },
    {
      "type": "header",
      "content": "Status Bar"
    },
    {
      "type": "checkbox",
      "id": "show_status_bar",
      "label": "Show status bar",
      "default": true
    },
    {
      "type": "text",
      "id": "mission_text",
      "label": "Mission text",
      "default": "ODOR NULLIFICATION"
    },
    {
      "type": "text",
      "id": "status_text",
      "label": "Status text",
      "default": "ACTIVE"
    },
    {
      "type": "text",
      "id": "temp_text",
      "label": "Temperature text",
      "default": "REGULATED"
    },
    {
      "type": "text",
      "id": "bacteria_text",
      "label": "Bacteria text",
      "default": "0%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (Hercléon)",
      "default": "THE FUTURE OF CLOTHING."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description (Hercléon)",
      "default": "<p>Clothes were first made for freedom – to let humans wander, cross distances, and explore the unknown.</p><p>Then fashion transformed clothing into something to manage, match, and maintain.</p><p>More about appearance than adventure.</p><p>We believe the future of clothing is found in its past.</p><p>We're here to return clothing to what it was meant to be: functional, low-maintenance, and, above all, freeing.</p><p>Gear you can live in, travel with, and rely on – without stress, baggage, or compromise.</p><p>Life is short. Death is always near.</p><p>And people who are truly living are rare.</p><p>We make clothes for the few who are here to live.</p>"
    },
    {
      "type": "header",
      "content": "Content (HercLabs tab)"
    },
    {
      "type": "text",
      "id": "heading_herclabs",
      "label": "Heading (HercLabs)",
      "default": "DISCOVER WHAT'S NEXT"
    },
    {
      "type": "richtext",
      "id": "description_herclabs",
      "label": "Description (HercLabs)",
      "default": "<p>Welcome to the HercLéon testing ground—a space where curiosity meets craftsmanship. HercLabs is our workshop for designs that don’t fit a single theme, but share a single goal: to solve the friction in your daily life. See what we’re working on today, and what we’re solving for tomorrow.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "checkbox",
      "id": "show_buttons",
      "label": "Show buttons",
      "default": true
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button 1 text",
      "default": "STUDY OUR TECH"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button 2 text",
      "default": "ACQUIRE GEAR"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "text",
      "id": "stat_one",
      "label": "First Statistic",
      "default": "★ 20,000+ Customers"
    },
    {
      "type": "text",
      "id": "stat_two",
      "label": "Second Statistic",
      "default": "In 100+ Countries"
    },
    {
      "type": "text",
      "id": "stat_three",
      "label": "Third Statistic",
      "default": "With 97% Satisfaction Rate"
    }
  ],
  "presets": [
    {
      "name": "HC Hero Section"
    }
  ]
}
{% endschema %}
