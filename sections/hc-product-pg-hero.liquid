{% comment %}
  Hero Section
  Usage: Save as snippet and render with {% render 'hero-section' %}
{% endcomment %}

<div class="hc-product-pg-hero-section">
  <div class="page-width {% if section.settings.full_width %}page-width--full{% endif %}">
    <div class="hc-product-pg-hero-content">
      <!-- Hero Title -->
      <div class="hc-product-pg-hero-title-wrapper">
        <h1 class="hc-product-pg-hero-title">
          {{ section.settings.hero_title | default: "HercShirt: The World's First Smell-Proof Shirt" }}
        </h1>
      </div>
      
      <!-- Version Timeline -->
      <div class="hc-product-pg-hero-timeline">
        <span class="hc-product-pg-hero-timeline-label">Version Timeline</span>
        <div class="hc-product-pg-hero-timeline-items">
          {% for block in section.blocks %}
            <div class="hc-product-pg-hero-timeline-item {% if block.settings.is_current %}hc-product-pg-hero-timeline-item-current{% endif %}">
              <span class="hc-product-pg-hero-timeline-version">{{ block.settings.version }}</span>
              <span class="hc-product-pg-hero-timeline-year">{{ block.settings.year }}</span>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Hero Section */

.hc-product-pg-hero-section {
  padding-top: {{ section.settings.header_desktop_padding_top }}px; 
  padding-bottom: {{ section.settings.header_desktop_padding_bottom }}px;
  background-color: #ffffff;
}

.hc-product-pg-hero-content {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
}

/* Hero Title */
.hc-product-pg-hero-title-wrapper {
  max-width: 72rem;
  width: 100%;
}

.hc-product-pg-hero-title {
  font-size: 2.25rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: -0.05em;
  line-height: 0.95;
  margin: 0;
}

/* Version Timeline */
.hc-product-pg-hero-timeline {
  font-family: var(--font-family-heading);
  text-align: right;
  margin-bottom: 0.25rem;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.hc-product-pg-hero-timeline-label {
  font-size: 0.625rem;
  font-weight: 700;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: block;
  margin-bottom: 0.25rem;
}

.hc-product-pg-hero-timeline-items {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  font-size: 0.75rem;
  font-weight: 700;
  color: #d1d5db;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.hc-product-pg-hero-timeline-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hc-product-pg-hero-timeline-version {
  display: block;
}

.hc-product-pg-hero-timeline-year {
  font-size: 0.5rem;
  font-weight: 400;
  display: block;
}

.hc-product-pg-hero-timeline-item-current {
  color: #B45309;
}

.hc-product-pg-hero-timeline-item-current .hc-product-pg-hero-timeline-version {
  font-size: 1.25rem;
}

.hc-product-pg-hero-timeline-item-current .hc-product-pg-hero-timeline-year {
  font-size: 0.625rem;
  font-weight: 400;
  color: #000000;
}

/* Responsive - Medium screens */
@media (min-width: 768px) {
  .hc-product-pg-hero-title {
    font-size: 3rem;
  }
  
  .hc-product-pg-hero-timeline-item-current .hc-product-pg-hero-timeline-version {
    font-size: 1.5rem;
  }
}

/* Responsive - Large screens */
@media (min-width: 1024px) {
  .hc-product-pg-hero-content {
    flex-direction: row;
    align-items: flex-end;
  }
  
  .hc-product-pg-hero-title {
    font-size: 3rem;
  }
}

/* Responsive - Small screens */
@media (max-width: 767px) {

  .hc-product-pg-hero-section {
    padding-top: {{ section.settings.header_mobile_padding_top }}px;
    padding-bottom: {{ section.settings.header_mobile_padding_bottom }}px;
  }

  .hc-product-pg-hero-timeline-items {
    gap: 0.75rem;
  }
}
</style>

{% schema %}
{
  "name": "HC Product Hero Section",
  "tag": "section",
  "class": "hc-product-pg-hero",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "HercShirt: The World's First Smell-Proof Shirt"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "header_desktop_padding_top",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "header_desktop_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "header_mobile_padding_top",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 128
    },
    {
      "type": "range",
      "id": "header_mobile_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline Version",
      "settings": [
        {
          "type": "text",
          "id": "version",
          "label": "Version Number",
          "default": "1.0"
        },
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2018"
        },
        {
          "type": "checkbox",
          "id": "is_current",
          "label": "Current Version",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC Product Hero Section",
      "blocks": [
        {
          "type": "timeline_item",
          "settings": {
            "version": "1.0",
            "year": "2018"
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "version": "2.0",
            "year": "2019"
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "version": "3.0",
            "year": "2023"
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "version": "4.0",
            "year": "2023"
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "version": "5.0",
            "year": "2026",
            "is_current": true
          }
        }
      ]
    }
  ]
}
{% endschema %}