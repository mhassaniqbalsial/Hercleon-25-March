{% comment %}
  Section: HC OS Fashion Core MC
  Class prefix: hc-os-fashion-core-mc-
{% endcomment %}

{% style %}
  .hc-os-fashion-core-mc {
    padding-top: {{ section.settings.padding_top_mobile | default: 128 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 128 }}px;
  }
  @media (min-width: 768px) {
    .hc-os-fashion-core-mc {
      padding-top: {{ section.settings.padding_top_desktop | default: 128 }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 128 }}px;
    }
  }
{% endstyle %}

<section class="hc-os-fashion-core-mc" id="hc-os-fashion-core-mc-{{ section.id }}">
  <div class="hc-os-fashion-core-mc__container">
    {% if section.settings.heading != blank %}
      <h2 class="hc-os-fashion-core-mc__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="hc-os-fashion-core-mc__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'card' %}
            <div class="hc-os-fashion-core-mc__card" {{ block.shopify_attributes }}>
              <div class="hc-os-fashion-core-mc__card-icon">
                {% case block.settings.icon %}
                  {% when 'freedom' %}
                    <svg class="hc-os-fashion-core-mc__card-icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                    </svg>
                  {% when 'lightness' %}
                    <svg class="hc-os-fashion-core-mc__card-icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                    </svg>
                  {% when 'engineering' %}
                    <svg class="hc-os-fashion-core-mc__card-icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                    </svg>
                  {% when 'longevity' %}
                    <svg class="hc-os-fashion-core-mc__card-icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  {% else %}
                    <svg class="hc-os-fashion-core-mc__card-icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                    </svg>
                {% endcase %}
              </div>
              {% if block.settings.title != blank %}
                <h3 class="hc-os-fashion-core-mc__card-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="hc-os-fashion-core-mc__card-desc">{{ block.settings.text }}</p>
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .hc-os-fashion-core-mc {
    padding-left: 24px;
    padding-right: 24px;
    border-top: 1px solid #f3f4f6;
  }
  @media (min-width: 768px) {
    .hc-os-fashion-core-mc {
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  .hc-os-fashion-core-mc__container {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .hc-os-fashion-core-mc__heading {
    font-size: 1.875rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 6rem;
    text-align: center;
    color: #9ca3af;
  }

  .hc-os-fashion-core-mc__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .hc-os-fashion-core-mc__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .hc-os-fashion-core-mc__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .hc-os-fashion-core-mc__card {
    transition: color 0.2s ease;
  }

  .hc-os-fashion-core-mc__card-icon {
    width: 64px;
    height: 64px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 2rem;
    border: 1px solid #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .hc-os-fashion-core-mc__card:hover .hc-os-fashion-core-mc__card-icon {
    background-color: #000;
  }

  .hc-os-fashion-core-mc__card:hover .hc-os-fashion-core-mc__card-icon-svg {
    color: #ffffff;
}

  .hc-os-fashion-core-mc__card-icon-svg {
    width: 24px;
    height: 24px;
    color: #111827;
  }

  .hc-os-fashion-core-mc__card-title {
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    color: #111827;
  }

  .hc-os-fashion-core-mc__card-desc {
    font-size: 0.875rem;
    color: #6b7280;
    font-weight: 300;
  }
</style>

{% schema %}
{
  "name": "HC OS Beliefs",
  "tag": "section",
  "class": "hc-os-fashion-core-mc-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Core Beliefs"
    },
    {
      "type": "header",
      "content": "Padding (Desktop)"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding top (desktop, px)",
      "default": 128
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom (desktop, px)",
      "default": 128
    },
    {
      "type": "header",
      "content": "Padding (Mobile)"
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile, px)",
      "default": 128
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile, px)",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Belief card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "freedom", "label": "Freedom (compass)" },
            { "value": "lightness", "label": "Lightness (cup)" },
            { "value": "engineering", "label": "Engineering (beaker)" },
            { "value": "longevity", "label": "Longevity (clock)" }
          ],
          "default": "freedom"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Freedom"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Clothing should give you more life, not more chores."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HC OS Beliefs",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "freedom",
            "title": "Freedom",
            "text": "Clothing should give you more life, not more chores."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "lightness",
            "title": "Lightness",
            "text": "Own less, move more, feel clearer."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "engineering",
            "title": "Engineering > Fashion",
            "text": "Better materials > trends."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "longevity",
            "title": "Longevity",
            "text": "What you wear should last years, not months."
          }
        }
      ]
    }
  ]
}
{% endschema %}
