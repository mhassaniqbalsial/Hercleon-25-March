{% comment %}
  Travel - Change of Clothes Block
{% endcomment %}

{%- liquid
  assign bg_color = block.settings.background_color | default: '#000000'
  assign title_color = block.settings.title_color | default: '#ffffff'
-%}
<style>
  .hc-travel-clothes-block--{{ block.id }} {
    border-bottom: 1px solid #000;
    background-color: {{ bg_color }};
    animation: hc-fade-in-up 0.6s ease forwards;
  }
  .hc-travel-clothes-block--{{ block.id }} .hc-travel-clothes-block__title,
  .hc-travel-clothes-block--{{ block.id }} .hc-travel-clothes-block__timeline-label {
    color: {{ title_color }};
  }
  .hc-travel-clothes-block {
    border-bottom: 1px solid #000;
    animation: hc-fade-in-up 0.6s ease forwards;
  }

  .hc-travel-clothes-block__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 60vh;
  }

  .hc-tracel-clothes-eyebrow {
    margin-bottom: 1.5rem; /* mb-6 */
  }

  .hc-tracel-clothes-eyebrow__text {
    font-size: 0.75rem; /* text-xs */
    font-weight: 700; /* font-bold */
    text-transform: uppercase; /* uppercase */
    letter-spacing: 0.2em; /* tracking-[0.2em] */
    color: #B45309; /* text-[#B45309] */
    display: inline-block;
  }

  @media (min-width: 1024px) {
    .hc-travel-clothes-block__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hc-travel-clothes-block__content {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #000;
    order: 1;
  }

  @media (min-width: 768px) {
    .hc-travel-clothes-block__content {
      padding: 6rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-travel-clothes-block__content {
      order: 2;
      border-left: 1px solid #1f2937;
    }
  }

  .hc-travel-clothes-block__title {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .hc-travel-clothes-block__title {
      font-size: 3rem;
    }
  }

  .hc-travel-clothes-block__description {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    max-width: 32rem;
    color: #9ca3af;
    white-space: pre-line;
  }

  .hc-travel-clothes-block__timeline-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    order: 2;
  }

  @media (min-width: 768px) {
    .hc-travel-clothes-block__timeline-wrapper {
      padding: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-travel-clothes-block__timeline-wrapper {
      order: 1;
    }
  }

  .hc-travel-clothes-block__timeline-container {
    width: 100%;
    max-width: 36rem;
  }

  .hc-travel-clothes-block__timeline {
    position: relative;
    border-left: 2px solid #cccccc60;
    padding-left: 2rem;
    margin-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
    color: #ffffff;
  }

  .hc-travel-clothes-block__timeline-item {
    position: relative;
  }

  .hc-travel-clothes-block__timeline-marker {
    position: absolute;
    left: -2.5625rem;
    top: 0.25rem;
    width: 1.25rem;
    height: 1.25rem;
    background-color: #B45309;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hc-travel-clothes-block__timeline-icon {
    width: 0.75rem;
    height: 0.75rem;
    color: #fff;
  }

  .hc-travel-clothes-block__timeline-time {
    font-size: 0.75rem;
    color: #6b7280;
    display: block;
    margin-bottom: 0.25rem;
  }

  .hc-travel-clothes-block__timeline-label {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1.125rem;
  }

  @keyframes hc-fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

@media screen and (max-width: 1024px) {
  .hc-travel-clothes-block__content {
    padding: 32px 20px;
}
.hc-travel-clothes-block__timeline-wrapper {
    padding: 32px 20px;
}
}

</style>

<section class="hc-travel-clothes-block hc-travel-clothes-block--{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="hc-travel-clothes-block__grid">
    
    {%- comment -%} Right Content {%- endcomment -%}
    <div class="hc-travel-clothes-block__content">
      <div class="hc-tracel-clothes-eyebrow">
  <span class="hc-tracel-clothes-eyebrow__text">
    {{ block.settings.eyebrow_text }}
  </span>
</div>
      <h3 class="hc-travel-clothes-block__title">
        {{ block.settings.title | default: 'Who needs a change of clothes?' }}
      </h3>
      <div class="hc-travel-clothes-block__description">
        {{ block.settings.description | default: 'HercFiber stays fresh from the moment you leave...' }}
      </div>
    </div>

    {%- comment -%} Left Timeline {%- endcomment -%}
    <div class="hc-travel-clothes-block__timeline-wrapper">
      <div class="hc-travel-clothes-block__timeline-container">
        <div class="hc-travel-clothes-block__timeline">
          
          {%- comment -%} Timeline Item 1 {%- endcomment -%}
          <div class="hc-travel-clothes-block__timeline-item">
            <div class="hc-travel-clothes-block__timeline-marker">
              <svg class="hc-travel-clothes-block__timeline-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <span class="hc-travel-clothes-block__timeline-time">
              {{ block.settings.time_1 | default: '08:00' }}
            </span>
            <span class="hc-travel-clothes-block__timeline-label">
              {{ block.settings.label_1 | default: 'International Flight' }}
            </span>
          </div>

          {%- comment -%} Timeline Item 2 {%- endcomment -%}
          <div class="hc-travel-clothes-block__timeline-item">
            <div class="hc-travel-clothes-block__timeline-marker">
              <svg class="hc-travel-clothes-block__timeline-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <span class="hc-travel-clothes-block__timeline-time">
              {{ block.settings.time_2 | default: '14:00' }}
            </span>
            <span class="hc-travel-clothes-block__timeline-label">
              {{ block.settings.label_2 | default: 'Client Meeting' }}
            </span>
          </div>

          {%- comment -%} Timeline Item 3 {%- endcomment -%}
          <div class="hc-travel-clothes-block__timeline-item">
            <div class="hc-travel-clothes-block__timeline-marker">
              <svg class="hc-travel-clothes-block__timeline-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <span class="hc-travel-clothes-block__timeline-time">
              {{ block.settings.time_3 | default: '16:00' }}
            </span>
            <span class="hc-travel-clothes-block__timeline-label">
              {{ block.settings.label_3 | default: 'Gym Session' }}
            </span>
          </div>

          {%- comment -%} Timeline Item 4 {%- endcomment -%}
          <div class="hc-travel-clothes-block__timeline-item">
            <div class="hc-travel-clothes-block__timeline-marker">
              <svg class="hc-travel-clothes-block__timeline-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <span class="hc-travel-clothes-block__timeline-time">
              {{ block.settings.time_4 | default: '19:00' }}
            </span>
            <span class="hc-travel-clothes-block__timeline-label">
              {{ block.settings.label_4 | default: 'Dinner Date' }}
            </span>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>
