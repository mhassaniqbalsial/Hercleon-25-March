{% comment %}
  Highlights — Sterile Sleep Environment (bio-static protection)
{% endcomment %}

{%- liquid
  assign sse_bg          = block.settings.bg_color | default: '#ffffff'
  assign sse_text        = block.settings.text_color | default: '#000000'
  assign sse_accent      = block.settings.accent_color | default: '#B45309'
  assign sse_desc        = block.settings.desc_color | default: '#4b5563'
  assign sse_border      = block.settings.border_color | default: '#000000'
  assign sse_card_bg     = block.settings.card_bg_color | default: '#ffffff'
  assign sse_card_border = block.settings.card_border_color | default: '#f3f4f6'
  assign sse_ring_border = block.settings.ring_border_color | default: '#e5e7eb'
  assign is_reversed     = block.settings.reverse_layout
  assign sse_section_id  = block.settings.section_id | default: 'sterile-environment' | handleize
-%}

{%- style -%}
  .hc-sse {
    --hc-sse-bg: {{ sse_bg }};
    --hc-sse-text: {{ sse_text }};
    --hc-sse-accent: {{ sse_accent }};
    --hc-sse-desc: {{ sse_desc }};
    --hc-sse-border: {{ sse_border }};
    --hc-sse-card-bg: {{ sse_card_bg }};
    --hc-sse-card-border: {{ sse_card_border }};
    --hc-sse-ring-border: {{ sse_ring_border }};

    background-color: var(--hc-sse-bg);
    border-bottom: 1px solid #000;
    overflow: visible;
  }

  .hc-sse__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 60vh;
  }

  .hc-sse__text-col {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--hc-sse-text);
    order: 1;
    border-bottom: 1px solid var(--hc-sse-border);
    position: relative;
    z-index: 2;
  }

  .hc-sse__visual-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--hc-sse-bg);
    order: 2;
  }

  .hc-sse__tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hc-sse-accent);
    margin-bottom: 1.5rem;
  }

  .hc-sse__heading {
    font-size: 2rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.15;
    font-family: var(--font-heading-family, inherit);
    color: var(--hc-sse-text);
  }

  .hc-sse__desc {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    max-width: 32rem;
    color: var(--hc-sse-desc);
    white-space: pre-line;
  }

  .hc-sse__desc p {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    color: inherit;
    white-space: inherit;
  }

  /* Visual card */
  .hc-sse__visual-inner {
    width: 100%;
    max-width: 36rem;
  }

  .hc-sse__card {
    background-color: var(--hc-sse-card-bg);
    padding: 2rem;
    border: 1px solid var(--hc-sse-card-border);
    width: 100%;
    max-width: 42rem;
    margin: 0 auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: var(--hc-sse-text);
  }

  .hc-sse__badges {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .hc-sse__badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hc-sse__badge-ring {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 1px solid var(--hc-sse-ring-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    transition: border-color 0.3s;
  }

  .hc-sse__badge:hover .hc-sse__badge-ring {
    border-color: var(--hc-sse-accent);
  }

  .hc-sse__badge-icon {
    width: 2rem;
    height: 2rem;
    color: var(--hc-sse-accent);
  }

  .hc-sse__badge-label {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--hc-sse-text);
  }

  @media (min-width: 768px) {
    .hc-sse__text-col {
      padding: 6rem;
    }

    .hc-sse__visual-col {
      padding: 3rem;
    }

    .hc-sse__heading {
      font-size: 3rem;
    }

    .hc-sse__card {
      padding: 4rem;
    }

    .hc-sse__badges {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .hc-sse__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hc-sse__text-col {
      border-bottom: none;
    }

    .hc-sse__grid--default .hc-sse__text-col {
      order: 1;
      border-right: 1px solid var(--hc-sse-border);
    }

    .hc-sse__grid--default .hc-sse__visual-col {
      order: 2;
    }

    .hc-sse__grid--reversed .hc-sse__text-col {
      order: 2;
      border-left: 1px solid var(--hc-sse-border);
    }

    .hc-sse__grid--reversed .hc-sse__visual-col {
      order: 1;
    }
  }
{%- endstyle -%}

<section
  id="{{ sse_section_id }}"
  class="hc-sse{% if block.settings.enable_animation %} animate-fade-in-up{% endif %}"
  {{ block.shopify_attributes }}
>
  <div class="hc-sse__grid {% if is_reversed %}hc-sse__grid--reversed{% else %}hc-sse__grid--default{% endif %}">

    <div class="hc-sse__text-col">
      {%- if block.settings.tag != blank -%}
        <span class="hc-sse__tag">{{ block.settings.tag }}</span>
      {%- endif -%}

      <h3 class="hc-sse__heading">{{ block.settings.heading | default: 'Sterile Sleep Environment' }}</h3>

      <div class="hc-sse__desc">{{ block.settings.description }}</div>
    </div>

    <div class="hc-sse__visual-col">
      <div class="hc-sse__visual-inner">
        <div class="hc-sse__card">
          <div class="hc-sse__badges">

            <div class="hc-sse__badge">
              <div class="hc-sse__badge-ring">
                <svg
                  class="hc-sse__badge-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                  <path d="m9 12 2 2 4-4"></path>
                </svg>
              </div>
              <span class="hc-sse__badge-label">{{ block.settings.badge_1_label | default: 'Anti Bacterial' }}</span>
            </div>

            <div class="hc-sse__badge">
              <div class="hc-sse__badge-ring">
                <svg
                  class="hc-sse__badge-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path>
                  <path d="M20 2v4"></path>
                  <path d="M22 4h-4"></path>
                  <circle cx="4" cy="20" r="2"></circle>
                </svg>
              </div>
              <span class="hc-sse__badge-label">{{ block.settings.badge_2_label | default: 'Hypoallergenic' }}</span>
            </div>

            <div class="hc-sse__badge">
              <div class="hc-sse__badge-ring">
                <svg
                  class="hc-sse__badge-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"></path>
                  <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"></path>
                </svg>
              </div>
              <span class="hc-sse__badge-label">{{ block.settings.badge_3_label | default: 'No Chemical Coating' }}</span>
            </div>

          </div>
        </div>
      </div>
    </div>

  </div>
</section>
