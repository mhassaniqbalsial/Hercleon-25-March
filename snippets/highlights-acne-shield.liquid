{%- liquid
  assign bg_color = block.settings.bg_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#000000'
  assign accent_color = block.settings.accent_color | default: '#B45309'
  assign desc_color = block.settings.desc_color | default: '#4b5563'
  assign is_reversed = block.settings.reverse_layout
  assign as_tooltip_x = block.settings.tooltip_position | default: 'center'
  assign style_preset = block.settings.style_preset | default: 'default'
  assign html_id_setting = block.settings.html_id | default: '' | strip
  if html_id_setting != blank
    assign as_section_id = html_id_setting
  else
    assign as_section_id = 'acne-shield'
  endif
  assign as_tooltip_template_id = 'hc-as-tooltip-template-' | append: block.id
-%}

<style>
  .hc-as {
    --hc-as-bg: {{ bg_color }};
    --hc-as-text: {{ text_color }};
    --hc-as-accent: {{ accent_color }};
    --hc-as-desc: {{ desc_color }};

    background-color: var(--hc-as-bg);
    border-bottom: 1px solid #000;
    overflow: visible;
  }

  .hc-as__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 30vh;
    overflow: visible;
  }

  .hc-as__text-col {
    padding: 2rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--hc-as-text);
    order: 2;
    border-top: 1px solid #000;
    overflow: visible;
    position: relative;
    z-index: 2;
  }

  .hc-as__visual-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    background-color: var(--hc-as-bg);
    order: 1;
    overflow: visible;
  }

  .hc-as__tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hc-as-accent);
    margin-bottom: 1.5rem;
  }

  .hc-as__heading {
    font-size: 2rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.15;
    font-family: var(--font-heading-family, inherit);
    color: var(--hc-as-text);
  }

  .hc-as__desc {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    max-width: 32rem;
    color: var(--hc-as-desc);
    white-space: pre-line;
    overflow: visible;
    position: relative;
  }

  .hc-as__desc strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s;
  }

  .hc-as__desc strong:hover {
    color: var(--hc-as-accent);
  }

  /* Tooltip */
  .hc-as__tooltip-trigger {
    position: relative;
    display: inline-block;
    overflow: visible;
    z-index: 3;
  }

  .hc-as__tooltip-trigger strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s;
  }

  .hc-as__tooltip-trigger:hover strong {
    color: var(--hc-as-accent);
  }

  .hc-as__tooltip {
    position: absolute;
    bottom: 100%;
    top: auto;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 0.65rem;
    margin-top: 0;
    width: min(100vw - 2rem, 20rem);
    max-width: calc(100vw - 2rem);
    z-index: 99999;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
  }

  .hc-as[data-tooltip-x='align_start'] .hc-as__tooltip {
    left: 0;
    right: auto;
    transform: none;
  }

  .hc-as__tooltip-trigger:hover .hc-as__tooltip,
  .hc-as__tooltip-trigger:focus-within .hc-as__tooltip {
    opacity: 1;
    visibility: visible;
  }

  .hc-as__tooltip-box {
    background-color: #fff;
    color: #000;
    padding: 1.75rem 1.5rem 1.75rem;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.08),
      0 20px 40px -12px rgba(0, 0, 0, 0.22);
    border: 1px solid #000;
    position: relative;
    display: block;
    overflow: visible;
    max-height: none;
    text-align: left;
  }

  .hc-as__tooltip-content {
    display: block;
  }

  .hc-as__tooltip-p {
    display: block;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 1rem;
  }

  .hc-as__tooltip-p:last-child {
    margin-bottom: 0;
  }

  .hc-as__tooltip-p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--hc-as-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-as__tooltip-p strong:hover {
    color: var(--hc-as-accent);
  }

  .hc-as__tooltip-content p {
    display: block;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 1rem;
  }

  .hc-as__tooltip-content p:last-child {
    margin-bottom: 0;
  }

  .hc-as__tooltip-content p:has(strong):not(:first-child) {
    margin-top: 1.25rem;
  }

  .hc-as__tooltip-content p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--hc-as-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-as__tooltip-arrow {
    position: absolute;
    bottom: -0.5rem;
    top: auto;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 0.75rem;
    height: 0.75rem;
    background-color: #fff;
    border-right: 1px solid #000;
    border-bottom: 1px solid #000;
    box-sizing: border-box;
  }

  .hc-as__tooltip--flip .hc-as__tooltip-arrow {
    bottom: auto;
    top: -0.5rem;
    border-right: none;
    border-bottom: none;
    border-left: 1px solid #000;
    border-top: 1px solid #000;
  }

  @media (min-width: 768px) {
    .hc-as__tooltip {
      width: min(100vw - 3rem, 28rem);
      max-width: calc(100vw - 3rem);
    }
  }

  /* Visual card */
  .hc-as__visual-inner {
    width: 100%;
    max-width: 36rem;
  }

  .hc-as__card {
    background-color: #fff;
    color: #000;
    border: 1px solid #f3f4f6;
    padding: 1rem 1.5rem;
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .hc-as__card-title {
    text-align: center;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
    color: #9ca3af;
  }

  .hc-as__card-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hc-as__stat-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1rem 1.5rem;
    border: 1px solid #f3f4f6;
    background-color: rgba(249, 250, 251, 0.5);
    width: 100%;
    max-width: 28rem;
  }

  .hc-as__ring-wrap {
    position: relative;
    width: 8rem;
    height: 8rem;
    margin-bottom: 1.5rem;
  }

  .hc-as__ring-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .hc-as__ring-bg {
    fill: none;
    stroke: #eee;
    stroke-width: 6;
  }

  .hc-as__ring-fill {
    fill: none;
    stroke: var(--hc-as-accent);
    stroke-width: 6;
    stroke-dasharray: 282.7;
    stroke-dashoffset: 0.28;
    filter: drop-shadow(0 0 15px rgba(180, 83, 9, 0.6));
  }

  .hc-as__ring-label {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hc-as__ring-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--hc-as-text);
  }

  .hc-as__ring-unit {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--hc-as-accent);
    margin-top: 0.5rem;
    font-weight: 700;
  }

  .hc-as__stat-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .hc-as__stat-desc {
    font-size: 0.75rem;
    color: #4b5563;
    line-height: 1.6;
    max-width: 280px;
  }

  @media (min-width: 768px) {
    .hc-as__text-col {
      padding: 3rem 6rem;
    }

    .hc-as__visual-col {
      padding: 2rem 3rem;
    }

    .hc-as__heading {
      font-size: 3rem;
    }

    .hc-as__card {
      padding: 1.5rem;
    }

    .hc-as__card-title {
      font-size: 0.75rem;
    }

    .hc-as__stat-box {
      padding: 1.5rem;
    }

    .hc-as__ring-wrap {
      width: 10rem;
      height: 10rem;
    }

    .hc-as__ring-value {
      font-size: 2.25rem;
    }

    .hc-as__ring-unit {
      font-size: 0.75rem;
    }

    .hc-as__stat-title {
      font-size: 0.875rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-as__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hc-as__text-col {
      border-top: none;
    }

    .hc-as__grid--default .hc-as__text-col {
      order: 2;
      border-left: 1px solid #000;
    }

    .hc-as__grid--default .hc-as__visual-col {
      order: 1;
    }

    .hc-as__grid--reversed .hc-as__text-col {
      order: 1;
      border-right: 1px solid #000;
    }

    .hc-as__grid--reversed .hc-as__visual-col {
      order: 2;
    }
  }

  /* Dark “ion recovery” preset — matches towel_ion_recovery-style layout; opt-in via theme setting */
  .hc-as--style-ion .hc-as__text-col {
    padding: 1rem 3rem;
    border-color: #1f2937;
  }

  .hc-as--style-ion .hc-as__visual-col {
    padding: 0.5rem 2rem;
  }

  .hc-as--style-ion .hc-as__visual-inner {
    max-width: 28rem;
  }

  .hc-as--style-ion .hc-as__card {
    background-color: #000000;
    color: #ffffff;
    border-color: #000000;
  }

  .hc-as--style-ion .hc-as__card-title {
    color: #6b7280;
  }

  .hc-as--style-ion .hc-as__stat-box {
    border-color: #111827;
    background-color: rgba(3, 7, 18, 0.5);
  }

  .hc-as--style-ion .hc-as__ring-bg {
    stroke: #111111;
  }

  .hc-as--style-ion .hc-as__ring-value {
    color: #ffffff;
  }

  .hc-as--style-ion .hc-as__stat-title {
    color: #ffffff;
  }

  .hc-as--style-ion .hc-as__stat-desc {
    color: #6b7280;
  }

  @media (min-width: 768px) {
    .hc-as--style-ion .hc-as__text-col {
      padding: 1.5rem 6rem;
    }

    .hc-as--style-ion .hc-as__visual-col {
      padding: 1rem 3rem;
    }
  }
</style>

<section
  id="{{ as_section_id }}"
  class="hc-as{% if style_preset == 'ion_recovery' %} hc-as--style-ion{% endif %}{% if block.settings.enable_section_animation %} animate-fade-in-up{% endif %}"
  data-tooltip-x="{{ as_tooltip_x }}"
  {{ block.shopify_attributes }}
>
  <div class="hc-as__grid {% if is_reversed %}hc-as__grid--reversed{% else %}hc-as__grid--default{% endif %}">

    <div class="hc-as__text-col">
      {%- if block.settings.tag != blank -%}
        <span class="hc-as__tag">{{ block.settings.tag }}</span>
      {%- endif -%}

      <h3 class="hc-as__heading">
        {{ block.settings.heading | default: 'THE ANTI-ACNE SHIELD' }}
      </h3>

      <div class="hc-as__desc">
        {%- if block.settings.tooltip_trigger != blank and block.settings.tooltip_content != blank -%}
          {%- assign as_trigger_html = '<strong>' | append: block.settings.tooltip_trigger | append: '</strong>' -%}
          {%- capture as_tooltip_html -%}<span class="hc-as__tooltip-trigger"><strong>{{ block.settings.tooltip_trigger }}</strong><span class="hc-as__tooltip"><span class="hc-as__tooltip-box"><span class="hc-as__tooltip-content">{{ block.settings.tooltip_content | replace: '<p>', '<span class="hc-as__tooltip-p">' | replace: '</p>', '</span>' }}</span><span class="hc-as__tooltip-arrow"></span></span></span></span>{%- endcapture -%}
          {{ block.settings.description | replace: as_trigger_html, as_tooltip_html }}
        {%- else -%}
          {{ block.settings.description }}
        {%- endif -%}
      </div>
    </div>

    <div class="hc-as__visual-col">
      <div class="hc-as__visual-inner">
        <div class="hc-as__card">
          <h4 class="hc-as__card-title">{{ block.settings.card_title | default: 'MICROBIOME PROTECTION' }}</h4>
          <div class="hc-as__card-body">
            <div class="hc-as__stat-box">
              <div class="hc-as__ring-wrap">
                <svg class="hc-as__ring-svg" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="45" class="hc-as__ring-bg"></circle>
                  <circle cx="50" cy="50" r="45" class="hc-as__ring-fill"></circle>
                </svg>
                <div class="hc-as__ring-label">
                  <span class="hc-as__ring-value">{{ block.settings.stat_value | default: '99.9%' }}</span>
                  <span class="hc-as__ring-unit">{{ block.settings.stat_unit | default: 'Kill Rate' }}</span>
                </div>
              </div>
              <span class="hc-as__stat-title">{{ block.settings.stat_title | default: 'Bacteria Neutralization' }}</span>
              <p class="hc-as__stat-desc">{{ block.settings.stat_desc | default: 'Destroys acne-causing microbes every 180 seconds.' }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

{%- if block.settings.tooltip_trigger != blank and block.settings.tooltip_content != blank -%}
  <template id="{{ as_tooltip_template_id }}">
    <span class="hc-as__tooltip">
      <span class="hc-as__tooltip-box">
        <span class="hc-as__tooltip-content">{{ block.settings.tooltip_content }}</span>
      </span>
      <span class="hc-as__tooltip-arrow"></span>
    </span>
  </template>

  <script>
    (function () {
      var sectionId = {{ as_section_id | json }};
      var tmplId = {{ as_tooltip_template_id | json }};
      var gap = 10;

      function bindAsTooltipFixedPosition(section) {
        if (!section || section.hasAttribute('data-as-tip-pos-bound')) return;
        section.setAttribute('data-as-tip-pos-bound', '1');

        var scheduled = false;
        function schedulePlace() {
          if (scheduled) return;
          scheduled = true;
          requestAnimationFrame(function () {
            scheduled = false;
            section.querySelectorAll('.hc-as__tooltip-trigger').forEach(placeOne);
          });
        }

        function wrapIsActive(wrap) {
          return wrap.matches(':hover') || wrap.matches(':focus-within');
        }

        function placeOne(wrap) {
          var tip = wrap.querySelector('.hc-as__tooltip');
          if (!tip || !wrapIsActive(wrap)) return;

          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              if (!wrapIsActive(wrap)) return;
              var alignX = section.getAttribute('data-tooltip-x') || 'center';
              var wrapR = wrap.getBoundingClientRect();
              var maxW = Math.min(448, window.innerWidth - 24);
              tip.style.boxSizing = 'border-box';
              tip.style.width = maxW + 'px';
              tip.style.position = 'fixed';
              tip.style.right = 'auto';
              tip.style.bottom = 'auto';
              tip.style.transform = 'none';
              tip.style.margin = '0';
              tip.style.zIndex = '2147483646';

              var tw = tip.getBoundingClientRect().width;
              var th = tip.getBoundingClientRect().height;
              var left =
                alignX === 'align_start'
                  ? wrapR.left
                  : wrapR.left + wrapR.width / 2 - tw / 2;
              left = Math.max(12, Math.min(left, window.innerWidth - tw - 12));

              var top = wrapR.top - th - gap;
              tip.classList.remove('hc-as__tooltip--flip');
              if (top < 8) {
                top = wrapR.bottom + gap;
                tip.classList.add('hc-as__tooltip--flip');
              }

              tip.style.left = Math.round(left) + 'px';
              tip.style.top = Math.round(top) + 'px';

              var arrow = tip.querySelector('.hc-as__tooltip-arrow');
              if (arrow) {
                var anchorX = wrapR.left + wrapR.width / 2;
                var arrowLeft = anchorX - left;
                arrowLeft = Math.max(14, Math.min(arrowLeft, tw - 14));
                arrow.style.left = Math.round(arrowLeft) + 'px';
                arrow.style.transform = 'translateX(-50%) rotate(45deg)';
              }
            });
          });
        }

        function clearTip(wrap) {
          var tip = wrap.querySelector('.hc-as__tooltip');
          if (!tip) return;
          tip.style.cssText = '';
          tip.classList.remove('hc-as__tooltip--flip');
          var arrow = tip.querySelector('.hc-as__tooltip-arrow');
          if (arrow) arrow.style.cssText = '';
        }

        section.querySelectorAll('.hc-as__tooltip-trigger').forEach(function (wrap) {
          wrap.addEventListener('mouseenter', schedulePlace);
          wrap.addEventListener('mouseleave', function () {
            clearTip(wrap);
          });
          wrap.addEventListener('focusin', schedulePlace);
          wrap.addEventListener('focusout', function () {
            clearTip(wrap);
          });
        });

        document.addEventListener('scroll', schedulePlace, true);
        window.addEventListener('resize', schedulePlace);
      }

      function initHcAsTooltip() {
        var section = document.getElementById(sectionId);
        if (!section) return;
        var descEl = section.querySelector('.hc-as__desc');
        if (!descEl) return;
        var trigger = {{ block.settings.tooltip_trigger | json }};
        descEl.querySelectorAll('strong').forEach(function (el) {
          if (el.textContent.trim().toLowerCase() !== String(trigger).trim().toLowerCase()) return;
          if (el.closest('.hc-as__tooltip-trigger')) return;
          var wrapper = document.createElement('span');
          wrapper.className = 'hc-as__tooltip-trigger';
          el.parentNode.insertBefore(wrapper, el);
          wrapper.appendChild(el);
          var tmpl = document.getElementById(tmplId);
          if (tmpl) wrapper.appendChild(tmpl.content.cloneNode(true));
        });
        bindAsTooltipFixedPosition(section);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initHcAsTooltip);
      } else {
        initHcAsTooltip();
      }
      document.addEventListener('shopify:section:load', initHcAsTooltip);
    })();
  </script>
{%- endif -%}
