{% comment %}
  Travel - Chore List Block
{% endcomment %}

<style>
  .hc-travel-chore-block {
    border-bottom: 1px solid #000;
    background-color: #fff;
    animation: hc-fade-in-up 0.6s ease forwards;
  }

  .hc-travel-chore-block__grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    min-height: 60vh;
  }

  .hc-travel-chore-eyebrow {
    margin-bottom: 1.5rem; /* mb-6 */
  }

  .hc-travel-chore-eyebrow__text {
    font-size: 0.75rem; /* text-xs */
    font-weight: 700; /* font-bold */
    text-transform: uppercase; /* uppercase */
    letter-spacing: 0.2em; /* tracking-[0.2em] */
    color: #B45309; /* text-[#B45309] */
    display: inline-block;
  }

  @media (min-width: 1024px) {
    .hc-travel-chore-block__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .hc-travel-chore-block__content {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #000;
  }

  @media (min-width: 768px) {
    .hc-travel-chore-block__content {
      padding: 6rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-travel-chore-block__content {
      border-right: 1px solid #000;
    }
  }

  .hc-travel-chore-block__title {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.2;
    color: #000;
  }

  @media (min-width: 768px) {
    .hc-travel-chore-block__title {
      font-size: 3rem;
    }
  }

  .hc-travel-chore-block__description {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    max-width: 32rem;
    color: #4b5563;
    white-space: pre-line;
  }

  .hc-travel-chore-block__comparison-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: #fff;
  }

  @media (min-width: 768px) {
    .hc-travel-chore-block__comparison-wrapper {
      padding: 3rem;
    }
  }

  .hc-travel-chore-block__comparison-container {
    width: 100%;
    max-width: 36rem;
  }

  .hc-travel-chore-block__comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .hc-travel-chore-block__card {
    padding: 1.5rem;
  }

  .hc-travel-chore-block__card--standard {
    background-color: #f3f4f6;
    opacity: 0.6;
    color: #000;
  }

  .hc-travel-chore-block__card--hero {
    background-color: #B45309;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hc-travel-chore-block__card-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
    border-bottom: 1px solid #d1d5db;
    padding-bottom: 0.5rem;
  }

  .hc-travel-chore-block__card--hero .hc-travel-chore-block__card-title {
    border-bottom-color: rgba(255, 255, 255, 0.2);
  }

  .hc-travel-chore-block__checklist {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #6b7280;
  }

  .hc-travel-chore-block__zero-chores {
    padding: 1rem 0;
    margin: auto 0;
    text-align: center;
  }

  .hc-travel-chore-block__zero-text {
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1;
  }

  @media (min-width: 768px) {
    .hc-travel-chore-block__zero-text {
      font-size: 2.25rem;
    }
  }

  @keyframes hc-fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  } 

@media screen and (max-width: 1024px) {
  .hc-travel-chore-block__content {
    padding: 32px 20px;
}
.hc-travel-chore-block__comparison-wrapper {
    padding: 32px 20px;
}
}

</style>

<section class="hc-travel-chore-block" {{ block.shopify_attributes }}>
  <div class="hc-travel-chore-block__grid">
    
    {%- comment -%} Left Content {%- endcomment -%}
    <div class="hc-travel-chore-block__content">
      <div class="hc-travel-chore-eyebrow">
  <span class="hc-travel-chore-eyebrow__text">
    {{ block.settings.eyebrow_text}}
  </span>
</div>
      <h3 class="hc-travel-chore-block__title">
        {{ block.settings.title | default: 'Travel without the chore list.' }}
      </h3>
      <div class="hc-travel-chore-block__description">
        {{ block.settings.description }}
      </div>
    </div>

    {%- comment -%} Right Comparison {%- endcomment -%}
    <div class="hc-travel-chore-block__comparison-wrapper">
      <div class="hc-travel-chore-block__comparison-container">
        <div class="hc-travel-chore-block__comparison-grid">
          
          {%- comment -%} Standard Requirements {%- endcomment -%}
          <div class="hc-travel-chore-block__card hc-travel-chore-block__card--standard">
            <p class="hc-travel-chore-block__card-title">
              {{ block.settings.standard_title | default: 'Standard Requirements' }}
            </p>
            <ul class="hc-travel-chore-block__checklist">
              <li>{{ block.settings.standard_item_1 | default: '[ ] Laundry Machine' }}</li>
              <li>{{ block.settings.standard_item_2 | default: '[ ] Detergent' }}</li>
              <li>{{ block.settings.standard_item_3 | default: '[ ] Drying Rack' }}</li>
              <li>{{ block.settings.standard_item_4 | default: '[ ] Iron / Steamer' }}</li>
              <li>{{ block.settings.standard_item_5 | default: '[ ] Spare Coins' }}</li>
              <li>{{ block.settings.standard_item_6 | default: '[ ] 2 Hours Wait' }}</li>
            </ul>
          </div>

          {%- comment -%} HercLeon Requirements {%- endcomment -%}
          <div class="hc-travel-chore-block__card hc-travel-chore-block__card--hero">
            <p class="hc-travel-chore-block__card-title">
              {{ block.settings.hercleon_title | default: 'HercLeon Requirements' }}
            </p>
            <div class="hc-travel-chore-block__zero-chores">
              <p class="hc-travel-chore-block__zero-text">
                {{ block.settings.hercleon_message | default: 'ZERO<br>CHORES' }}
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>
