{%- liquid
  assign bg_color = block.settings.bg_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#000000'
  assign accent_color = block.settings.accent_color | default: '#B45309'
  assign desc_color = block.settings.desc_color | default: '#4b5563'
  assign is_reversed = block.settings.reverse_layout
  assign as_tooltip_x = block.settings.tooltip_position | default: 'center'
  assign min_h = block.settings.min_height | default: '60vh'
  assign html_id_setting = block.settings.html_id | default: '' | strip
  if html_id_setting != blank
    assign sec_id = html_id_setting
  else
    assign sec_id = 'inhospitable-germs'
  endif
  assign tmpl_id = 'hc-ig-tooltip-template-' | append: block.id
  assign ig_tooltip_trigger = block.settings.tooltip_trigger | default: '' | strip

  assign bar_track = block.settings.bar_track_color | default: '#f3f4f6'
  assign bar_fill = block.settings.bar_fill_color | default: '#000000'
  assign card_title_c = block.settings.card_heading_color | default: '#9ca3af'
  assign card_border = block.settings.card_border_color | default: '#000000'

  assign w1 = block.settings.row1_width | default: '99.9%'
  assign w2 = block.settings.row2_width | default: '99.7%'
  assign w3 = block.settings.row3_width | default: '99.1%'
  unless w1 contains '%'
    assign w1 = w1 | append: '%'
  endunless
  unless w2 contains '%'
    assign w2 = w2 | append: '%'
  endunless
  unless w3 contains '%'
    assign w3 = w3 | append: '%'
  endunless
-%}

<style>
  .hc-ig {
    --hc-ig-bg: {{ bg_color }};
    --hc-ig-text: {{ text_color }};
    --hc-ig-accent: {{ accent_color }};
    --hc-ig-desc: {{ desc_color }};
    --hc-ig-min-h: {{ min_h }};
    --hc-ig-bar-track: {{ bar_track }};
    --hc-ig-bar-fill: {{ bar_fill }};
    --hc-ig-card-title: {{ card_title_c }};
    --hc-ig-card-border: {{ card_border }};

    background-color: var(--hc-ig-bg);
    border-bottom: 1px solid #000;
    overflow: visible;
  }

  .hc-ig__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: var(--hc-ig-min-h);
    overflow: visible;
  }

  .hc-ig__text-col {
    padding: 3rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--hc-ig-text);
    order: 2;
    border-top: 1px solid #000;
    overflow: visible;
    position: relative;
    z-index: 2;
  }

  .hc-ig__visual-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 3rem;
    background-color: var(--hc-ig-bg);
    order: 1;
    overflow: visible;
  }

  .hc-ig__tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hc-ig-accent);
    margin-bottom: 1.5rem;
  }

  .hc-ig__heading {
    font-size: 2rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.15;
    font-family: var(--font-heading-family, inherit);
    color: var(--hc-ig-text);
  }

  .hc-ig__desc {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    max-width: 32rem;
    color: var(--hc-ig-desc);
    white-space: pre-line;
    overflow: visible;
    position: relative;
  }

  .hc-ig__desc strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s;
  }

  .hc-ig__desc strong:hover {
    color: var(--hc-ig-accent);
  }

  .hc-ig__tooltip-trigger {
    position: relative;
    display: inline-block;
    overflow: visible;
    z-index: 3;
  }

  .hc-ig__tooltip-trigger strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s;
  }

  .hc-ig__tooltip-trigger:hover strong {
    color: var(--hc-ig-accent);
  }

  .hc-ig__tooltip {
    position: absolute;
    bottom: 100%;
    top: auto;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 0.65rem;
    margin-top: 0;
    width: min(100vw - 2rem, 20rem);
    max-width: calc(100vw - 2rem);
    z-index: 99999;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
  }

  .hc-ig[data-tooltip-x='align_start'] .hc-ig__tooltip {
    left: 0;
    right: auto;
    transform: none;
  }

  .hc-ig__tooltip-trigger:hover .hc-ig__tooltip,
  .hc-ig__tooltip-trigger:focus-within .hc-ig__tooltip {
    opacity: 1;
    visibility: visible;
  }

  .hc-ig__tooltip-box {
    background-color: #fff;
    color: #000;
    padding: 1.75rem 1.5rem 1.75rem;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.08),
      0 20px 40px -12px rgba(0, 0, 0, 0.22);
    border: 1px solid #000;
    position: relative;
    display: block;
    overflow: visible;
    max-height: none;
    text-align: left;
  }

  .hc-ig__tooltip-content {
    display: block;
  }

  .hc-ig__tooltip-p {
    display: block;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 1rem;
  }

  .hc-ig__tooltip-p:last-child {
    margin-bottom: 0;
  }

  .hc-ig__tooltip-p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--hc-ig-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-ig__tooltip-p strong:hover {
    color: var(--hc-ig-accent);
  }

  .hc-ig__tooltip-content p {
    display: block;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 1rem;
  }

  .hc-ig__tooltip-content p:last-child {
    margin-bottom: 0;
  }

  .hc-ig__tooltip-content p:has(strong):not(:first-child) {
    margin-top: 1.25rem;
  }

  .hc-ig__tooltip-content p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--hc-ig-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-ig__tooltip-arrow {
    position: absolute;
    bottom: -0.5rem;
    top: auto;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 0.75rem;
    height: 0.75rem;
    background-color: #fff;
    border-right: 1px solid #000;
    border-bottom: 1px solid #000;
    box-sizing: border-box;
  }

  .hc-ig__tooltip--flip .hc-ig__tooltip-arrow {
    bottom: auto;
    top: -0.5rem;
    border-right: none;
    border-bottom: none;
    border-left: 1px solid #000;
    border-top: 1px solid #000;
  }

  @media (min-width: 768px) {
    .hc-ig__tooltip {
      width: min(100vw - 3rem, 28rem);
      max-width: calc(100vw - 3rem);
    }
  }

  .hc-ig__visual-inner {
    width: 100%;
    max-width: 36rem;
  }

  .hc-ig__card {
    background-color: var(--hc-ig-bg);
    color: var(--hc-ig-text);
    border: 1px solid var(--hc-ig-card-border);
    padding: 2rem 2rem;
    width: 100%;
    max-width: 42rem;
    margin: 0 auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .hc-ig__card-title {
    text-align: center;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 3rem;
    color: var(--hc-ig-card-title);
  }

  .hc-ig__rows {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hc-ig__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: center;
  }

  .hc-ig__row-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--hc-ig-text);
  }

  .hc-ig__bar-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hc-ig__bar-track {
    height: 0.5rem;
    flex: 1;
    background-color: var(--hc-ig-bar-track);
    min-width: 0;
  }

  .hc-ig__bar-fill {
    display: flex !important;
    height: 100%;
    background-color: var(--hc-ig-bar-fill);
    max-width: 100%;
}

  .hc-ig__bar-pct {
    font-size: 0.625rem;
    font-weight: 700;
    flex-shrink: 0;
    color: var(--hc-ig-text);
  }

  .hc-ig__footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--hc-ig-bar-track);
    text-align: center;
  }

  .hc-ig__footer p {
    margin: 0;
    font-size: 0.5625rem;
    color: var(--hc-ig-card-title);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .hc-ig__text-col {
      padding: 6rem 6rem;
    }

    .hc-ig__heading {
      font-size: 3rem;
    }

    .hc-ig__card {
      padding: 3rem 3rem;
    }

    .hc-ig__card-title {
      font-size: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-ig__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hc-ig__text-col {
      border-top: none;
    }

    .hc-ig__grid--default .hc-ig__text-col {
      order: 2;
      border-left: 1px solid #000;
    }

    .hc-ig__grid--default .hc-ig__visual-col {
      order: 1;
    }

    .hc-ig__grid--reversed .hc-ig__text-col {
      order: 1;
      border-right: 1px solid #000;
    }

    .hc-ig__grid--reversed .hc-ig__visual-col {
      order: 2;
    }
  }
</style>

<section
  id="{{ sec_id }}"
  class="hc-ig{% if block.settings.enable_section_animation %} animate-fade-in-up{% endif %}"
  data-tooltip-x="{{ as_tooltip_x }}"
  {{ block.shopify_attributes }}
>
  <div class="hc-ig__grid {% if is_reversed %}hc-ig__grid--reversed{% else %}hc-ig__grid--default{% endif %}">
    <div class="hc-ig__text-col">
      {%- if block.settings.tag != blank -%}
        <span class="hc-ig__tag">{{ block.settings.tag }}</span>
      {%- endif -%}
      <h3 class="hc-ig__heading">{{ block.settings.heading | default: 'Inhospitable for Germs' }}</h3>
      <div class="hc-ig__desc">
        {%- if ig_tooltip_trigger != blank and block.settings.tooltip_content != blank -%}
          {%- assign ig_trigger_html = '<strong>' | append: ig_tooltip_trigger | append: '</strong>' -%}
          {%- capture ig_tooltip_html -%}
            <span class="hc-ig__tooltip-trigger"><strong>{{ ig_tooltip_trigger }}</strong><span class="hc-ig__tooltip"><span class="hc-ig__tooltip-box"><span class="hc-ig__tooltip-content">{{ block.settings.tooltip_content | replace: '<p>', '<span class="hc-ig__tooltip-p">' | replace: '</p>', '</span>' }}</span><span class="hc-ig__tooltip-arrow"></span></span></span></span>
          {%- endcapture -%}
          {{ block.settings.description | replace: ig_trigger_html, ig_tooltip_html }}
        {%- else -%}
          {{ block.settings.description }}
        {%- endif -%}
      </div>
    </div>

    <div class="hc-ig__visual-col">
      <div class="hc-ig__visual-inner">
        <div class="hc-ig__card">
          <h4 class="hc-ig__card-title">{{ block.settings.card_title | default: 'MICROBIAL BARRIER ANALYSIS' }}</h4>
          <div class="hc-ig__rows">
            <div class="hc-ig__row">
              <span class="hc-ig__row-label">{{ block.settings.row1_label | default: 'Staphylococcus' }}</span>
              <div class="hc-ig__bar-wrap">
                <div class="hc-ig__bar-track">
                  <div class="hc-ig__bar-fill" style="width: {{ w1 }};"></div>
                </div>
                <span class="hc-ig__bar-pct">{{ block.settings.row1_label_right | default: '99.9%' }}</span>
              </div>
            </div>
            <div class="hc-ig__row">
              <span class="hc-ig__row-label">{{ block.settings.row2_label | default: 'E. Coli' }}</span>
              <div class="hc-ig__bar-wrap">
                <div class="hc-ig__bar-track">
                  <div class="hc-ig__bar-fill" style="width: {{ w2 }};"></div>
                </div>
                <span class="hc-ig__bar-pct">{{ block.settings.row2_label_right | default: '99.7%' }}</span>
              </div>
            </div>
            <div class="hc-ig__row">
              <span class="hc-ig__row-label">{{ block.settings.row3_label | default: 'Candida' }}</span>
              <div class="hc-ig__bar-wrap">
                <div class="hc-ig__bar-track">
                  <div class="hc-ig__bar-fill" style="width: {{ w3 }};"></div>
                </div>
                <span class="hc-ig__bar-pct">{{ block.settings.row3_label_right | default: '99.1%' }}</span>
              </div>
            </div>
          </div>
          {%- if block.settings.footer_note != blank -%}
            <div class="hc-ig__footer">
              <p>{{ block.settings.footer_note }}</p>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{%- if ig_tooltip_trigger != blank and block.settings.tooltip_content != blank -%}
  <template id="{{ tmpl_id }}">
    <span class="hc-ig__tooltip">
      <span class="hc-ig__tooltip-box">
        <span class="hc-ig__tooltip-content">{{ block.settings.tooltip_content }}</span>
      </span>
      <span class="hc-ig__tooltip-arrow"></span>
    </span>
  </template>

  <script>
    (function () {
      var sectionId = {{ sec_id | json }};
      var tmplId = {{ tmpl_id | json }};
      var gap = 10;

      function bindIgTooltip(section) {
        if (!section || section.hasAttribute('data-ig-tip-bound')) return;
        section.setAttribute('data-ig-tip-bound', '1');
        var scheduled = false;
        function schedulePlace() {
          if (scheduled) return;
          scheduled = true;
          requestAnimationFrame(function () {
            scheduled = false;
            section.querySelectorAll('.hc-ig__tooltip-trigger').forEach(placeOne);
          });
        }
        function wrapIsActive(wrap) {
          return wrap.matches(':hover') || wrap.matches(':focus-within');
        }
        function placeOne(wrap) {
          var tip = wrap.querySelector('.hc-ig__tooltip');
          if (!tip || !wrapIsActive(wrap)) return;
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              if (!wrapIsActive(wrap)) return;
              var alignX = section.getAttribute('data-tooltip-x') || 'center';
              var wrapR = wrap.getBoundingClientRect();
              var maxW = Math.min(448, window.innerWidth - 24);
              tip.style.boxSizing = 'border-box';
              tip.style.width = maxW + 'px';
              tip.style.position = 'fixed';
              tip.style.right = 'auto';
              tip.style.bottom = 'auto';
              tip.style.transform = 'none';
              tip.style.margin = '0';
              tip.style.zIndex = '2147483646';
              var tw = tip.getBoundingClientRect().width;
              var th = tip.getBoundingClientRect().height;
              var left =
                alignX === 'align_start'
                  ? wrapR.left
                  : wrapR.left + wrapR.width / 2 - tw / 2;
              left = Math.max(12, Math.min(left, window.innerWidth - tw - 12));
              var top = wrapR.top - th - gap;
              tip.classList.remove('hc-ig__tooltip--flip');
              if (top < 8) {
                top = wrapR.bottom + gap;
                tip.classList.add('hc-ig__tooltip--flip');
              }
              tip.style.left = Math.round(left) + 'px';
              tip.style.top = Math.round(top) + 'px';
              var arrow = tip.querySelector('.hc-ig__tooltip-arrow');
              if (arrow) {
                var anchorX = wrapR.left + wrapR.width / 2;
                var arrowLeft = anchorX - left;
                arrowLeft = Math.max(14, Math.min(arrowLeft, tw - 14));
                arrow.style.left = Math.round(arrowLeft) + 'px';
                arrow.style.transform = 'translateX(-50%) rotate(45deg)';
              }
            });
          });
        }
        function clearTip(wrap) {
          var tip = wrap.querySelector('.hc-ig__tooltip');
          if (!tip) return;
          tip.style.cssText = '';
          tip.classList.remove('hc-ig__tooltip--flip');
          var arrow = tip.querySelector('.hc-ig__tooltip-arrow');
          if (arrow) arrow.style.cssText = '';
        }
        section.querySelectorAll('.hc-ig__tooltip-trigger').forEach(function (wrap) {
          wrap.addEventListener('mouseenter', schedulePlace);
          wrap.addEventListener('mouseleave', function () {
            clearTip(wrap);
          });
          wrap.addEventListener('focusin', schedulePlace);
          wrap.addEventListener('focusout', function () {
            clearTip(wrap);
          });
        });
        document.addEventListener('scroll', schedulePlace, true);
        window.addEventListener('resize', schedulePlace);
      }

      function initIgTooltip() {
        var section = document.getElementById(sectionId);
        if (!section) return;
        var descEl = section.querySelector('.hc-ig__desc');
        if (!descEl) return;
        var trigger = {{ ig_tooltip_trigger | json }};
        descEl.querySelectorAll('strong').forEach(function (el) {
          if (el.textContent.trim().toLowerCase() !== String(trigger).trim().toLowerCase()) return;
          if (el.closest('.hc-ig__tooltip-trigger')) return;
          var wrapper = document.createElement('span');
          wrapper.className = 'hc-ig__tooltip-trigger';
          el.parentNode.insertBefore(wrapper, el);
          wrapper.appendChild(el);
          var tmpl = document.getElementById(tmplId);
          if (tmpl) wrapper.appendChild(tmpl.content.cloneNode(true));
        });
        bindIgTooltip(section);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initIgTooltip);
      } else {
        initIgTooltip();
      }
      document.addEventListener('shopify:section:load', initIgTooltip);
    })();
  </script>
{%- endif -%}
