{%- liquid
  assign bg_color = block.settings.bg_color | default: '#ffffff'
  assign text_color = block.settings.text_color | default: '#000000'
  assign accent_color = block.settings.accent_color | default: '#B45309'
  assign desc_color = block.settings.desc_color | default: '#4b5563'
  assign is_reversed = block.settings.reverse_layout
-%}

<style>
  .hc-ld {
    --hc-ld-bg: {{ bg_color }};
    --hc-ld-text: {{ text_color }};
    --hc-ld-accent: {{ accent_color }};
    --hc-ld-desc: {{ desc_color }};

    background-color: var(--hc-ld-bg);
    border-bottom: 1px solid #000;
  }

  .hc-ld__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 60vh;
  }

  .hc-ld__text-col {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--hc-ld-text);
    order: 1;
    border-bottom: 1px solid #000;
  }

  .hc-ld__visual-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--hc-ld-bg);
    order: 2;
  }

  .hc-ld__tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hc-ld-accent);
    margin-bottom: 1.5rem;
  }

  .hc-ld__heading {
    font-size: 2rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.15;
    font-family: var(--font-heading-family, inherit);
    color: var(--hc-ld-text);
  }

  .hc-ld__desc {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    max-width: 32rem;
    color: var(--hc-ld-desc);
    white-space: pre-line;
  }

  .hc-ld__desc strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s;
  }

  .hc-ld__desc strong:hover {
    color: var(--hc-ld-accent);
  }

  /* Tooltip */
  .hc-ld__tooltip-trigger {
    position: relative;
    display: inline-block;
  }

  .hc-ld__tooltip-trigger strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s;
  }

  .hc-ld__tooltip-trigger:hover strong {
    color: var(--hc-ld-accent);
  }

  .hc-ld__tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 1rem;
    width: 320px;
    z-index: 1000;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
  }

  .hc-ld__tooltip-trigger:hover .hc-ld__tooltip {
    opacity: 1;
    visibility: visible;
  }

  .hc-ld__tooltip-box {
    background-color: #fff;
    color: #000;
    padding: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    border: 1px solid #000;
    position: relative;
    display: block;
  }

  .hc-ld__tooltip-content {
    display: block;
  }

  .hc-ld__tooltip-p {
    display: block;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 1rem;
  }

  .hc-ld__tooltip-p:last-child {
    margin-bottom: 0;
  }

  .hc-ld__tooltip-p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--hc-ld-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-ld__tooltip-p strong:hover {
    color: var(--hc-ld-accent);
  }

  .hc-ld__tooltip-arrow {
    position: absolute;
    bottom: -0.5rem;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 1rem;
    height: 1rem;
    background-color: #fff;
    border-right: 1px solid #000;
    border-bottom: 1px solid #000;
  }

  @media (min-width: 768px) {
    .hc-ld__tooltip {
      width: 450px;
    }
  }

  /* Visual card */
  .hc-ld__visual-inner {
    width: 100%;
    max-width: 36rem;
  }

  .hc-ld__card {
    background-color: #fff;
    padding: 2rem;
    border: 1px solid #000;
    width: 100%;
    max-width: 42rem;
    margin: 0 auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: #000;
  }

  .hc-ld__card-title {
    text-align: center;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    margin-bottom: 2rem;
  }

  .hc-ld__bars {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hc-ld__bar-row-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.625rem;
    margin-bottom: 0.5rem;
  }

  .hc-ld__bar-label {
    font-weight: 700;
    text-transform: uppercase;
  }

  .hc-ld__bar-value {
    color: #6b7280;
  }

  .hc-ld__bar-label--accent {
    color: var(--hc-ld-accent);
  }

  .hc-ld__bar-value--accent {
    color: var(--hc-ld-accent);
    font-weight: 700;
  }

  .hc-ld__bar-track {
    width: 100%;
    height: 1rem;
    background-color: #f3f4f6;
    border-radius: 9999px;
    overflow: hidden;
  }

  .hc-ld__bar-fill {
    display: flex !important;
    height: 100%;
    border-radius: 9999px;
}

  .hc-ld__bar-fill--standard {
    width: 30%;
    background-color: #9ca3af;
  }

  .hc-ld__bar-fill--jax {
    width: 100%;
    background-color: var(--hc-ld-accent);
  }

  .hc-ld__stat {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hc-ld__stat-value {
    font-size: 3.75rem;
    font-weight: 700;
    color: var(--hc-ld-accent);
    line-height: 1;
  }

  .hc-ld__stat-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #9ca3af;
    margin-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .hc-ld__text-col {
      padding: 6rem;
    }

    .hc-ld__visual-col {
      padding: 3rem;
    }

    .hc-ld__heading {
      font-size: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-ld__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hc-ld__text-col {
      border-bottom: none;
    }

    .hc-ld__grid--default .hc-ld__text-col {
      order: 1;
      border-right: 1px solid #000;
    }

    .hc-ld__grid--default .hc-ld__visual-col {
      order: 2;
    }

    .hc-ld__grid--reversed .hc-ld__text-col {
      order: 2;
      border-left: 1px solid #000;
    }

    .hc-ld__grid--reversed .hc-ld__visual-col {
      order: 1;
    }
  }
</style>

<section id="longevity-designed" class="hc-ld" {{ block.shopify_attributes }}>
  <div class="hc-ld__grid {% if is_reversed %}hc-ld__grid--reversed{% else %}hc-ld__grid--default{% endif %}">

    <div class="hc-ld__text-col">
      {%- if block.settings.tag != blank -%}
        <span class="hc-ld__tag">{{ block.settings.tag }}</span>
      {%- endif -%}

      <h3 class="hc-ld__heading">
        {{ block.settings.heading | default: 'DESIGNED FOR LONGEVITY' }}
      </h3>

      <div class="hc-ld__desc">
        {%- if block.settings.tooltip_trigger != blank and block.settings.tooltip_content != blank -%}
          {%- assign ld_trigger_html = '<strong>' | append: block.settings.tooltip_trigger | append: '</strong>' -%}
          {%- capture ld_tooltip_html -%}<span class="hc-ld__tooltip-trigger"><strong>{{ block.settings.tooltip_trigger }}</strong><span class="hc-ld__tooltip"><span class="hc-ld__tooltip-box"><span class="hc-ld__tooltip-content">{{ block.settings.tooltip_content | replace: '<p>', '<span class="hc-ld__tooltip-p">' | replace: '</p>', '</span>' }}</span><span class="hc-ld__tooltip-arrow"></span></span></span></span>{%- endcapture -%}
          {{ block.settings.description | replace: ld_trigger_html, ld_tooltip_html }}
        {%- else -%}
          {{ block.settings.description }}
        {%- endif -%}
      </div>
    </div>

    <div class="hc-ld__visual-col">
      <div class="hc-ld__visual-inner">
        <div class="hc-ld__card">
          <div style="display:flex;flex-direction:column;align-items:center;">
            <h4 class="hc-ld__card-title">{{ block.settings.card_title | default: 'AVERAGE SHEET LIFESPAN' }}</h4>

            <div class="hc-ld__bars">
              <div>
                <div class="hc-ld__bar-row-header">
                  <span class="hc-ld__bar-label">{{ block.settings.standard_label | default: 'TRADITIONAL COTTON / LINEN / POLY' }}</span>
                  <span class="hc-ld__bar-value">{{ block.settings.standard_value | default: '2 - 3 YEARS' }}</span>
                </div>
                <div class="hc-ld__bar-track">
                  <div class="hc-ld__bar-fill hc-ld__bar-fill--standard"></div>
                </div>
              </div>

              <div>
                <div class="hc-ld__bar-row-header">
                  <span class="hc-ld__bar-label hc-ld__bar-label--accent">{{ block.settings.jax_label | default: 'JAX SHEETS' }}</span>
                  <span class="hc-ld__bar-value hc-ld__bar-value--accent">{{ block.settings.jax_value | default: 'UP TO 10 YEARS' }}</span>
                </div>
                <div class="hc-ld__bar-track">
                  <div class="hc-ld__bar-fill hc-ld__bar-fill--jax"></div>
                </div>
              </div>
            </div>

            <div class="hc-ld__stat">
              <span class="hc-ld__stat-value">{{ block.settings.stat_value | default: '5x' }}</span>
              <span class="hc-ld__stat-label">{{ block.settings.stat_label | default: 'Durability Factor' }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
