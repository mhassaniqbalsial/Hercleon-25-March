{% comment %}
  Briefing - Washing & Pollution Block
{% endcomment %}

<style>
  .hc-briefing-washing-block {
    background-color: #fff;
    color: #000;
    padding: 8rem 1.5rem;
    border-bottom: 1px solid #000;
  }

  @media (min-width: 768px) {
    .hc-briefing-washing-block {
      padding: 8rem 1.5rem;
    }
  }

  .hc-briefing-washing-block__container {
    max-width: 56rem;
    margin: 0 auto;
  }

  .hc-briefing-washing-block__title {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 3rem;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .hc-briefing-washing-block__title {
      font-size: 3.75rem;
    }
  }

  .hc-briefing-washing-block__content p {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.75;
    color: #4b5563;
    max-width: none;
    white-space: pre-wrap;
    margin-bottom: 10px;
}

  @keyframes hc-fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

@media screen and (max-width: 1024px) {
.hc-briefing-washing-block {
    padding: 40px 20px;
}
}

</style>

<section class="hc-briefing-washing-block" {{ block.shopify_attributes }}>
  <div class="hc-briefing-washing-block__container">
    <h2 class="hc-briefing-washing-block__title">
      {{ block.settings.title | default: 'Odor Drives Washing. Washing Drives Pollution. HercLeón Stops Both.' }}
    </h2>
    <div class="hc-briefing-washing-block__content">
      {{ block.settings.content }}
    </div>
  </div>
</section>
