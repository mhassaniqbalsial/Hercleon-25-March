{% comment %}
  Highlights — Instant Evaporation (hyper-wicking technology)
{% endcomment %}

{%- liquid
  assign ie_bg          = block.settings.bg_color | default: '#ffffff'
  assign ie_text        = block.settings.text_color | default: '#000000'
  assign ie_accent      = block.settings.accent_color | default: '#B45309'
  assign ie_desc        = block.settings.desc_color | default: '#4b5563'
  assign ie_border      = block.settings.border_color | default: '#000000'
  assign ie_card_bg     = block.settings.card_bg_color | default: '#ffffff'
  assign ie_card_border = block.settings.card_border_color | default: '#f3f4f6'
  assign ie_row_bg      = block.settings.row_bg_color | default: '#f9fafb'
  assign ie_row_border  = block.settings.row_border_color | default: '#e5e7eb'
  assign is_reversed    = block.settings.reverse_layout
  assign ie_section_id  = block.settings.section_id | default: 'instant-evaporation' | handleize
  assign ie_desc_rendered = block.settings.description
-%}

{%- if block.settings.tooltip_1_trigger != blank and block.settings.tooltip_1_content != blank -%}
  {%- assign ie_t1 = '<strong>' | append: block.settings.tooltip_1_trigger | append: '</strong>' -%}
  {%- capture ie_w1 -%}<span class="hc-ie__tooltip-trigger"><strong>{{ block.settings.tooltip_1_trigger }}</strong><span class="hc-ie__tooltip"><span class="hc-ie__tooltip-box"><span class="hc-ie__tooltip-content">{{ block.settings.tooltip_1_content | replace: '<p>', '<span class="hc-ie__tooltip-p">' | replace: '</p>', '</span>' }}</span><span class="hc-ie__tooltip-arrow"></span></span></span></span>{%- endcapture -%}
  {%- assign ie_desc_rendered = ie_desc_rendered | replace: ie_t1, ie_w1 -%}
{%- endif -%}

{%- style -%}
  .hc-ie {
    --hc-ie-bg: {{ ie_bg }};
    --hc-ie-text: {{ ie_text }};
    --hc-ie-accent: {{ ie_accent }};
    --hc-ie-desc: {{ ie_desc }};
    --hc-ie-border: {{ ie_border }};
    --hc-ie-card-bg: {{ ie_card_bg }};
    --hc-ie-card-border: {{ ie_card_border }};
    --hc-ie-row-bg: {{ ie_row_bg }};
    --hc-ie-row-border: {{ ie_row_border }};

    background-color: var(--hc-ie-bg);
    border-bottom: 1px solid #000;
    overflow: visible;
  }

  .hc-ie__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 60vh;
    overflow: visible;
  }

  .hc-ie__text-col {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--hc-ie-text);
    order: 1;
    border-bottom: 1px solid var(--hc-ie-border);
    overflow: visible;
    position: relative;
    z-index: 2;
  }

  .hc-ie__visual-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--hc-ie-bg);
    order: 2;
  }

  .hc-ie__tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hc-ie-accent);
    margin-bottom: 1.5rem;
  }

  .hc-ie__heading {
    font-size: 2rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.15;
    font-family: var(--font-heading-family, inherit);
    color: var(--hc-ie-text);
  }

  .hc-ie__desc {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    max-width: 32rem;
    color: var(--hc-ie-desc);
    white-space: pre-line;
    overflow: visible;
    position: relative;
  }

  .hc-ie__desc p {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    color: inherit;
    white-space: inherit;
  }

  /* Tooltip */
  .hc-ie__tooltip-trigger {
    position: relative;
    display: inline-flex;
    overflow: visible;
    z-index: 3;
  }

  .hc-ie__tooltip-trigger strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s;
  }

  .hc-ie__tooltip-trigger:hover strong {
    color: var(--hc-ie-accent);
  }

  .hc-ie__tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 1rem;
    width: 320px;
    z-index: 1000;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
  }

  .hc-ie__tooltip-trigger:hover .hc-ie__tooltip,
  .hc-ie__tooltip-trigger:focus-within .hc-ie__tooltip {
    opacity: 1;
    visibility: visible;
  }

  .hc-ie__tooltip-box {
    background-color: #fff;
    color: #000;
    padding: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    border: 1px solid #000;
    position: relative;
    display: block;
  }

  .hc-ie__tooltip-content {
    display: block;
  }

  .hc-ie__tooltip-p {
    display: block;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 1rem;
  }

  .hc-ie__tooltip-p:last-child {
    margin-bottom: 0;
  }

  .hc-ie__tooltip-p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--hc-ie-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-ie__tooltip-content p {
    display: block;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 1rem;
  }

  .hc-ie__tooltip-content p:last-child {
    margin-bottom: 0;
  }

  .hc-ie__tooltip-content p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--hc-ie-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-ie__tooltip-arrow {
    position: absolute;
    bottom: -0.5rem;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 1rem;
    height: 1rem;
    background-color: #fff;
    border-right: 1px solid #000;
    border-bottom: 1px solid #000;
  }

  @media (max-width: 479px) {
    .hc-ie__tooltip {
      width: 240px;
    }
  }

  @media (min-width: 768px) {
    .hc-ie__tooltip {
      width: 450px;
    }
  }

  /* Visual card */
  .hc-ie__visual-inner {
    width: 100%;
    max-width: 36rem;
  }

  .hc-ie__card {
    background-color: var(--hc-ie-card-bg);
    padding: 2rem;
    border: 1px solid var(--hc-ie-card-border);
    width: 100%;
    max-width: 42rem;
    margin: 0 auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: var(--hc-ie-text);
  }

  .hc-ie__rows {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hc-ie__row {
    border: 1px solid var(--hc-ie-row-border);
    background-color: var(--hc-ie-row-bg);
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: border-color 0.3s;
  }

  .hc-ie__row:hover {
    border-color: var(--hc-ie-accent);
  }

  .hc-ie__row-icon-wrap {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.25rem;
    background-color: color-mix(in srgb, var(--hc-ie-accent) 20%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  @supports not (color: color-mix(in srgb, red, blue)) {
    .hc-ie__row-icon-wrap {
      background-color: rgba(180, 83, 9, 0.2);
    }
  }

  .hc-ie__row-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--hc-ie-accent);
  }

  .hc-ie__row-label {
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--hc-ie-text);
  }

  @media (min-width: 768px) {
    .hc-ie__text-col {
      padding: 6rem;
    }

    .hc-ie__visual-col {
      padding: 3rem;
    }

    .hc-ie__heading {
      font-size: 3rem;
    }

    .hc-ie__card {
      padding: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-ie__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hc-ie__text-col {
      border-bottom: none;
    }

    .hc-ie__grid--default .hc-ie__text-col {
      order: 1;
      border-right: 1px solid var(--hc-ie-border);
    }

    .hc-ie__grid--default .hc-ie__visual-col {
      order: 2;
    }

    .hc-ie__grid--reversed .hc-ie__text-col {
      order: 2;
      border-left: 1px solid var(--hc-ie-border);
    }

    .hc-ie__grid--reversed .hc-ie__visual-col {
      order: 1;
    }
  }
{%- endstyle -%}

<section
  id="{{ ie_section_id }}"
  class="hc-ie{% if block.settings.enable_animation %} animate-fade-in-up{% endif %}"
  {{ block.shopify_attributes }}
>
  <div class="hc-ie__grid {% if is_reversed %}hc-ie__grid--reversed{% else %}hc-ie__grid--default{% endif %}">

    <div class="hc-ie__text-col">
      {%- if block.settings.tag != blank -%}
        <span class="hc-ie__tag">{{ block.settings.tag }}</span>
      {%- endif -%}

      <h3 class="hc-ie__heading">{{ block.settings.heading | default: 'Instant Evaporation' }}</h3>

      <div class="hc-ie__desc">{{ ie_desc_rendered }}</div>
    </div>

    <div class="hc-ie__visual-col">
      <div class="hc-ie__visual-inner">
        <div class="hc-ie__card">
          <div class="hc-ie__rows">

            <div class="hc-ie__row">
              <div class="hc-ie__row-icon-wrap">
                <svg class="hc-ie__row-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"></path>
                  <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"></path>
                </svg>
              </div>
              <span class="hc-ie__row-label">{{ block.settings.row_1_label | default: 'Fast Absorption' }}</span>
            </div>

            <div class="hc-ie__row">
              <div class="hc-ie__row-icon-wrap">
                <svg class="hc-ie__row-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12.8 19.6A2 2 0 1 0 14 16H2"></path>
                  <path d="M17.5 8a2.5 2.5 0 1 1 2 4H2"></path>
                  <path d="M9.8 4.4A2 2 0 1 1 11 8H2"></path>
                </svg>
              </div>
              <span class="hc-ie__row-label">{{ block.settings.row_2_label | default: 'Fast Evaporation' }}</span>
            </div>

            <div class="hc-ie__row">
              <div class="hc-ie__row-icon-wrap">
                <svg class="hc-ie__row-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path>
                  <path d="M20 2v4"></path>
                  <path d="M22 4h-4"></path>
                  <circle cx="4" cy="20" r="2"></circle>
                </svg>
              </div>
              <span class="hc-ie__row-label">{{ block.settings.row_3_label | default: 'Extra Surface Dryness' }}</span>
            </div>

          </div>
        </div>
      </div>
    </div>

  </div>
</section>
