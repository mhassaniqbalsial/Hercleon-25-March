{% comment %}
  Highlights — Always the Cool Side (thermal / temp stat block)
{% endcomment %}

{%- liquid
  assign ac_bg = block.settings.bg_color | default: '#ffffff'
  assign ac_card_bg = block.settings.card_bg_color | default: '#ffffff'
  assign ac_border = block.settings.border_color | default: '#000000'
  assign ac_accent = block.settings.accent_color | default: '#B45309'
  assign ac_heading = block.settings.heading_text_color | default: '#000000'
  assign ac_body = block.settings.body_text_color | default: '#4b5563'
  assign ac_card_border = block.settings.card_border_color | default: '#f3f4f6'
  assign ac_stat = block.settings.stat_value_color | default: '#2563eb'
  assign ac_stat_muted = block.settings.stat_label_color | default: '#60a5fa'
  assign ac_dial_pulse = block.settings.dial_pulse_ring_color | default: '#eff6ff'
  assign ac_dial_ring = block.settings.dial_ring_color | default: '#dbeafe'
  assign ac_dial_fill = block.settings.dial_fill_color | default: '#eff6ff'
  assign ac_dial_fill_a = ac_dial_fill | color_modify: 'alpha', 0.3
  assign is_reversed = block.settings.reverse_layout
  assign ac_section_id = block.settings.section_id | default: 'always-cool' | handleize
-%}

{%- style -%}
  @keyframes hc-always-cool-fade-in-up {
    from {
      opacity: 0;
      transform: translateY(1.25rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hc-always-cool-pulse-ring {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.45;
    }
  }

  .hc-always-cool {
    --ac-bg: {{ ac_bg }};
    --ac-card-bg: {{ ac_card_bg }};
    --ac-border: {{ ac_border }};
    --ac-accent: {{ ac_accent }};
    --ac-heading: {{ ac_heading }};
    --ac-body: {{ ac_body }};
    --ac-card-border: {{ ac_card_border }};
    --ac-stat: {{ ac_stat }};
    --ac-stat-muted: {{ ac_stat_muted }};
    --ac-dial-pulse: {{ ac_dial_pulse }};
    --ac-dial-ring: {{ ac_dial_ring }};
    --ac-dial-fill: {{ ac_dial_fill_a }};

    background-color: var(--ac-bg);
    border-bottom: 1px solid var(--ac-border);
    animation: hc-always-cool-fade-in-up 0.6s ease forwards;
  }

  .hc-always-cool__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 60vh;
  }

  .hc-always-cool__text-col {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--ac-heading);
    order: 1;
    border-bottom: 1px solid var(--ac-border);
  }

  @media (min-width: 768px) {
    .hc-always-cool__text-col {
      padding: 6rem;
    }
  }

  .hc-always-cool__tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ac-accent);
    margin-bottom: 1.5rem;
  }

  .hc-always-cool__heading {
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.15;
    font-family: var(--font-heading-family, inherit);
    color: var(--ac-heading);
  }

  @media (min-width: 768px) {
    .hc-always-cool__heading {
      font-size: 3rem;
    }
  }

  .hc-always-cool__desc {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.625;
    max-width: 32rem;
    color: var(--ac-body);
    white-space: pre-line;
  }

  .hc-always-cool__desc p {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    color: inherit;
    white-space: inherit;
  }

  .hc-always-cool__desc strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s ease;
  }

  .hc-always-cool__desc strong:hover,
  .hc-always-cool__desc strong:focus-visible {
    color: var(--ac-accent);
  }

  .hc-always-cool-tooltip-trigger {
    position: relative;
    display: inline-block;
    overflow: visible;
    z-index: 3;
  }

  .hc-always-cool-tooltip-trigger strong {
    font-weight: 700;
    border-bottom: 1px dotted currentColor;
    cursor: help;
    transition: color 0.3s ease;
  }

  .hc-always-cool-tooltip-trigger:hover strong,
  .hc-always-cool-tooltip-trigger:focus-within strong {
    color: var(--ac-accent);
  }

  .hc-always-cool-tooltip {
    position: absolute;
    bottom: 100%;
    top: auto;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 0.65rem;
    width: min(100vw - 2rem, 22rem);
    max-width: calc(100vw - 2rem);
    z-index: 99999;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
  }

  .hc-always-cool-tooltip-trigger:hover .hc-always-cool-tooltip,
  .hc-always-cool-tooltip-trigger:focus-within .hc-always-cool-tooltip {
    opacity: 1;
    visibility: visible;
  }

  .hc-always-cool-tooltip-box {
    background-color: #fff;
    color: #111;
    padding: 1.75rem 1.5rem;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.08),
      0 20px 40px -12px rgba(0, 0, 0, 0.22);
    border: 1px solid #000;
    position: relative;
    display: block;
    text-align: left;
    overflow: visible;
  }

  .hc-always-cool-tooltip-content {
    display: block;
    font-family: var(--font-body-family, var(--font-heading-family, ui-sans-serif, system-ui, sans-serif));
  }

  .hc-always-cool-tooltip-content p {
    display: block;
    font-size: 0.8125rem;
    line-height: 1.65;
    font-weight: 400;
    margin: 0 0 0.75rem;
    color: #111;
  }

  .hc-always-cool-tooltip-content p:last-child {
    margin-bottom: 0;
  }

  .hc-always-cool-tooltip-content p:has(strong):not(:first-child) {
    margin-top: 1.25rem;
  }

  .hc-always-cool-tooltip-content p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.35;
    margin-bottom: 0.45rem;
    color: var(--ac-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-always-cool-tooltip-p {
    display: block;
    font-size: 0.8125rem;
    line-height: 1.65;
    font-weight: 400;
    margin: 0 0 0.75rem;
    color: #111;
  }

  .hc-always-cool-tooltip-p:last-child {
    margin-bottom: 0;
  }

  .hc-always-cool-tooltip-p:has(strong):not(:first-child) {
    margin-top: 1.25rem;
  }

  .hc-always-cool-tooltip-p strong {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.35;
    margin-bottom: 0.45rem;
    color: var(--ac-accent);
    border-bottom: none;
    cursor: default;
  }

  .hc-always-cool-tooltip-arrow {
    position: absolute;
    bottom: -0.5rem;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 0.75rem;
    height: 0.75rem;
    background-color: #fff;
    border-right: 1px solid #000;
    border-bottom: 1px solid #000;
    box-sizing: border-box;
  }

  .hc-always-cool-tooltip--flip .hc-always-cool-tooltip-arrow {
    bottom: auto;
    top: -0.5rem;
    border-right: none;
    border-bottom: none;
    border-left: 1px solid #000;
    border-top: 1px solid #000;
  }

  @media (min-width: 768px) {
    .hc-always-cool-tooltip {
      width: min(100vw - 3rem, 30rem);
      max-width: calc(100vw - 3rem);
    }
  }

  .hc-always-cool__visual-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--ac-bg);
    order: 2;
  }

  @media (min-width: 768px) {
    .hc-always-cool__visual-col {
      padding: 3rem;
    }
  }

  .hc-always-cool__visual-inner {
    width: 100%;
    max-width: 36rem;
  }

  .hc-always-cool__card {
    background-color: var(--ac-card-bg);
    padding: 2rem;
    border: 1px solid var(--ac-card-border);
    width: 100%;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: var(--ac-heading);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hc-always-cool__card {
      padding: 4rem;
    }
  }

  .hc-always-cool__dial {
    position: relative;
    width: 12rem;
    height: 12rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hc-always-cool__dial {
      width: 16rem;
      height: 16rem;
    }
  }

  .hc-always-cool__dial-pulse {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    border: 4px solid var(--ac-dial-pulse);
    animation: hc-always-cool-pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    pointer-events: none;
  }

  .hc-always-cool__dial-face {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    border: 2px solid var(--ac-dial-ring);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--ac-dial-fill);
    box-sizing: border-box;
  }

  .hc-always-cool__stat-value {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    color: var(--ac-stat);
    line-height: 1;
  }

  .hc-always-cool__stat-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--ac-stat-muted);
    margin-top: 0.5rem;
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .hc-always-cool__stat-label {
      font-size: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .hc-always-cool__grid {
      grid-template-columns: 1fr 1fr;
    }

    .hc-always-cool__text-col {
      border-bottom: none;
    }

    .hc-always-cool__grid--default .hc-always-cool__text-col {
      order: 1;
      border-right: 1px solid var(--ac-border);
    }

    .hc-always-cool__grid--default .hc-always-cool__visual-col {
      order: 2;
    }

    .hc-always-cool__grid--reversed .hc-always-cool__text-col {
      order: 2;
      border-left: 1px solid var(--ac-border);
      border-right: none;
    }

    .hc-always-cool__grid--reversed .hc-always-cool__visual-col {
      order: 1;
    }
  }
{%- endstyle -%}

<section
  id="{{ ac_section_id }}"
  class="hc-always-cool"
  {{ block.shopify_attributes }}
>
  <div class="hc-always-cool__grid {% if is_reversed %}hc-always-cool__grid--reversed{% else %}hc-always-cool__grid--default{% endif %}">
    <div class="hc-always-cool__text-col">
      {%- if block.settings.tag != blank -%}
        <span class="hc-always-cool__tag">{{ block.settings.tag }}</span>
      {%- endif -%}

      <h3 class="hc-always-cool__heading">
        {{ block.settings.heading | default: 'Always the Cool Side' }}
      </h3>

      <div class="hc-always-cool__desc">
        {{ block.settings.description }}
      </div>
    </div>

    <div class="hc-always-cool__visual-col">
      <div class="hc-always-cool__visual-inner">
        <div class="hc-always-cool__card">
          <div class="hc-always-cool__dial" aria-hidden="true">
            <div class="hc-always-cool__dial-pulse"></div>
            <div class="hc-always-cool__dial-face">
              <span class="hc-always-cool__stat-value">{{ block.settings.stat_value | default: '-3°C' }}</span>
              <span class="hc-always-cool__stat-label">{{ block.settings.stat_label | default: 'Temp Drop' }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{%- liquid
  assign ac_tip_1 = false
  assign ac_tip_2 = false
  if block.settings.tooltip_1_trigger != blank and block.settings.tooltip_1_content != blank
    assign ac_tip_1 = true
  endif
  if block.settings.tooltip_2_trigger != blank and block.settings.tooltip_2_content != blank
    assign ac_tip_2 = true
  endif
-%}

{%- if ac_tip_1 -%}
  <template id="hc-always-cool-tooltip-template-1">
    <span class="hc-always-cool-tooltip">
      <span class="hc-always-cool-tooltip-box">
        <span class="hc-always-cool-tooltip-content">
          {{- block.settings.tooltip_1_content | replace: '<p>', '<span class="hc-always-cool-tooltip-p">' | replace: '</p>', '</span>' -}}
        </span>
        <span class="hc-always-cool-tooltip-arrow"></span>
      </span>
    </span>
  </template>
{%- endif -%}

{%- if ac_tip_2 -%}
  <template id="hc-always-cool-tooltip-template-2">
    <span class="hc-always-cool-tooltip">
      <span class="hc-always-cool-tooltip-box">
        <span class="hc-always-cool-tooltip-content">
          {{- block.settings.tooltip_2_content | replace: '<p>', '<span class="hc-always-cool-tooltip-p">' | replace: '</p>', '</span>' -}}
        </span>
        <span class="hc-always-cool-tooltip-arrow"></span>
      </span>
    </span>
  </template>
{%- endif -%}

{%- if ac_tip_1 or ac_tip_2 -%}
  <script>
    (function () {
      var sectionId = {{ ac_section_id | json }};
      var gap = 10;
      var configs = [].concat(
        {% if ac_tip_1 %}
          [{ trigger: {{ block.settings.tooltip_1_trigger | json }}, templateId: 'hc-always-cool-tooltip-template-1' }],
        {% else %}
          [],
        {% endif %}
        {% if ac_tip_2 %}
          [{ trigger: {{ block.settings.tooltip_2_trigger | json }}, templateId: 'hc-always-cool-tooltip-template-2' }]
        {% else %}
          []
        {% endif %}
      );

      function bindAcAlwaysCoolTooltips(section) {
        if (!section || section.hasAttribute('data-ac-tip-pos-bound')) return;
        section.setAttribute('data-ac-tip-pos-bound', '1');

        var scheduled = false;
        function schedulePlace() {
          if (scheduled) return;
          scheduled = true;
          requestAnimationFrame(function () {
            scheduled = false;
            section.querySelectorAll('.hc-always-cool-tooltip-trigger').forEach(placeOne);
          });
        }

        function wrapIsActive(wrap) {
          return wrap.matches(':hover') || wrap.matches(':focus-within');
        }

        function placeOne(wrap) {
          var tip = wrap.querySelector('.hc-always-cool-tooltip');
          if (!tip || !wrapIsActive(wrap)) return;

          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              if (!wrapIsActive(wrap)) return;
              var wrapR = wrap.getBoundingClientRect();
              var maxW = Math.min(480, window.innerWidth - 24);
              tip.style.boxSizing = 'border-box';
              tip.style.width = maxW + 'px';
              tip.style.position = 'fixed';
              tip.style.right = 'auto';
              tip.style.bottom = 'auto';
              tip.style.transform = 'none';
              tip.style.margin = '0';
              tip.style.zIndex = '2147483646';

              var th = tip.getBoundingClientRect().height;
              var tw = tip.getBoundingClientRect().width;
              var left = wrapR.left + wrapR.width / 2 - tw / 2;
              left = Math.max(12, Math.min(left, window.innerWidth - tw - 12));

              var top = wrapR.top - th - gap;
              tip.classList.remove('hc-always-cool-tooltip--flip');
              if (top < 8) {
                top = wrapR.bottom + gap;
                tip.classList.add('hc-always-cool-tooltip--flip');
              }

              tip.style.left = Math.round(left) + 'px';
              tip.style.top = Math.round(top) + 'px';
            });
          });
        }

        function clearTip(wrap) {
          var tip = wrap.querySelector('.hc-always-cool-tooltip');
          if (!tip) return;
          tip.style.cssText = '';
          tip.classList.remove('hc-always-cool-tooltip--flip');
        }

        section.querySelectorAll('.hc-always-cool-tooltip-trigger').forEach(function (wrap) {
          wrap.addEventListener('mouseenter', schedulePlace);
          wrap.addEventListener('mouseleave', function () {
            clearTip(wrap);
          });
          wrap.addEventListener('focusin', schedulePlace);
          wrap.addEventListener('focusout', function () {
            clearTip(wrap);
          });
        });

        document.addEventListener('scroll', schedulePlace, true);
        window.addEventListener('resize', schedulePlace);
      }

      function initHcAlwaysCoolTooltips() {
        var section = document.getElementById(sectionId);
        if (!section) return;
        var descEl = section.querySelector('.hc-always-cool__desc');
        if (!descEl) return;

        configs.forEach(function (cfg) {
          if (!cfg || !cfg.trigger) return;
          var triggerNorm = String(cfg.trigger).trim().toLowerCase();
          descEl.querySelectorAll('strong').forEach(function (el) {
            if (el.textContent.trim().toLowerCase() !== triggerNorm) return;
            if (el.closest('.hc-always-cool-tooltip-trigger')) return;
            var wrapper = document.createElement('span');
            wrapper.className = 'hc-always-cool-tooltip-trigger';
            el.parentNode.insertBefore(wrapper, el);
            wrapper.appendChild(el);
            var tmpl = document.getElementById(cfg.templateId);
            if (tmpl) wrapper.appendChild(tmpl.content.cloneNode(true));
          });
        });

        bindAcAlwaysCoolTooltips(section);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initHcAlwaysCoolTooltips);
      } else {
        initHcAlwaysCoolTooltips();
      }
      document.addEventListener('shopify:section:load', initHcAlwaysCoolTooltips);
    })();
  </script>
{%- endif -%}
