    "hc_tab_content_highlights_WrjdeC": {
      "type": "hc-tab-content-highlights",
      "blocks": {
        "micron_finish_zkxa9N": {
          "type": "micron-finish",
          "settings": {
            "tag": "01 — Softer Than Silk, Stronger Than Cotton",
            "heading": "10 Micron Finish",
            "description": "<p>Jax Sheets are engineered with 10-<strong>micron</strong> ultra-fine fibers—roughly 1/10th the thickness of a human hair. This microscopic precision creates a surface that is noticeably softer than traditional silk while maintaining the structural strength of high-performance gear. Unlike standard cotton, which features microscopic \"hooks\" that can cause texture changes over time, Jax fibers are designed for long-term smoothness.</p>",
            "card_title": "SURFACE FRICTION COEFFICIENT",
            "bar_1_label": "Cotton",
            "bar_2_label": "Silk",
            "bar_3_label": "HercLeón",
            "chart_footer": "Lower value indicates smoother surface & less skin irritation",
            "reverse_layout": false,
            "tooltip_trigger": "micron",
            "tooltip_content": "<p><strong>What is a micron?</strong></p><p>A micron (micrometer) is one millionth of a meter. At 10 microns, each Jax fiber is roughly 1/10th the diameter of a human hair. This ultra-fine gauge allows the fibers to bend and drape with almost no resistance, producing a surface that feels remarkably smooth against skin.</p><p><strong>Why does it matter for sheets?</strong></p><p>Finer fibers create a denser, smoother weave with less surface friction. This means less irritation, less pilling, and a softer hand-feel that actually improves with use rather than degrading over time like conventional cotton.</p>",
            "bg_color": "#ffffff",
            "text_color": "#000000",
            "accent_color": "#b45309",
            "desc_color": "#4b5563"
          }
        }
      },
