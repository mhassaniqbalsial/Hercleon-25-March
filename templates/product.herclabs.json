    "hc_tab_content_durability_Dmgaht": {
      "type": "hc-tab-content-durability",
      "blocks": {
        "durability_lifespan_RJRypR": {
          "type": "durability-lifespan",
          "settings": {
            "eyebrow_text": "",
            "title": "Less Washing = Longer Lifespan",
            "description": "Most clothing wears out early because it has to be washed constantly. Every wash breaks the fibers down a little more through heat, chemicals, and friction. Odor is what forces those washes — which means smell is actually the root cause of clothing death.\nHercLeón eliminates that problem at the source.\nOur gear stays fresh for days and even weeks, so it's washed a fraction of the time. That dramatically reduces fabric stress, preserves softness, and lets our garments last years — even decades — longer than traditional apparel.\nWhen your clothes don’t smell, they don’t need washing.\nAnd when they don’t need washing, they last.",
            "comparison_title": "HercFiber™ is more durable than others by:",
            "comparison_1_value": "1.9x",
            "comparison_1_label": "Cotton",
            "comparison_2_value": "2x",
            "comparison_2_label": "Viscose",
            "comparison_3_value": "3x",
            "comparison_3_label": "Merino Wool",
            "table_title": "HercFiber Is Durable In Every Way",
            "header_category": "Category",
            "header_meaning": "Meaning",
            "header_cotton": "Cot",
            "header_merino": "Mer",
            "header_herc": "Herc",
            "row_1_category": "Tensile Strength",
            "row_1_meaning": "Resistance to breaking",
            "row_1_cotton": "★★",
            "row_1_merino": "★",
            "row_1_herc": "★★★",
