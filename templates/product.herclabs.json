        },
        "comfort_softness_bWMg6h": {
          "type": "comfort-softness",
          "settings": {
            "eyebrow": "02 — Gear You Won't Want To Take Off",
            "title": "More Softness. Less Smell.",
            "description": "We engineered our fabric to be softer than cashmere and almost twice as soft as merino wool — not just for comfort, but for freshness. Softer fibers create less friction, trap less heat, and keep your skin cooler and drier, which prevents odor-causing bacteria from activating. By making HercFiber this soft, we made it even more anti-odor.",
            "chart_title": "Micron Count (Lower is Softer)",
