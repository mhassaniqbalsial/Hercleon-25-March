        "comfort_sweat_absorbed_mJfKf6": {
          "type": "comfort-sweat-absorbed",
          "settings": {
            "title": "Sweat Absorbed. Odor Stopped.",
            "description": "Most clothes fail because sweat sits on the surface, feeding bacteria and creating odor within hours. So we engineered HercLeon with a hyper-absorbent fiber system that pulls moisture away instantly — faster than cotton, polyester, or merino. By keeping your skin dry and starving bacteria of what they need to grow, the fabric stays clean and fresh all day long.\nThat's why you can board a flight, work all day, explore a new city, and head straight to dinner — in the same outfit — feeling and smelling as fresh as when you first put it on.",
            "stat_1_value": "300%",
            "stat_1_label": "More Absorbent (Cotton)",
            "stat_1_highlight": true,
            "stat_2_value": "1000%",
            "stat_2_label": "More Absorbent (Poly)",
            "stat_2_highlight": true,
            "stat_3_value": "130%",
