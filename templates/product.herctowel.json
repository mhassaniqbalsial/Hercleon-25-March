            "circle_border_color": "#000000",
            "circle_hover_tint": "rgba(239, 246, 255, 0.5)",
            "shimmer_line_color": "#f3f4f6"
          }
        },
        "lightweight_compact_eny7XB": {
          "type": "lightweight-compact",
          "settings": {
            "tag": "04 — Ultra-Compact Travel",
            "heading": "Lightweight Without Compromise",
            "description": "<p>The high density fiber blend of the Jax Towel delivers strong absorbency with up to 50% less bulk than a conventional towel, making it an ideal companion for the gym or a carry-on bag.</p>",
            "left_label": "High Density\nFibers",
            "right_label": "Ultra\nLightweight",
            "reverse_layout": true,
