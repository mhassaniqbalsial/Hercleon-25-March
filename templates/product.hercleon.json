          "type": "cleaner-planet",
          "settings": {
            "title_main": "BUILT FOR A CLEANER",
            "title_accent": "PLANET",
            "description": "The fashion industry is the second largest polluter in the world. By creating clothing that doesn't need to be washed nearly as often as regular clothing, HercLéon is a commitment to a cleaner future."
          }
        },
        "exp_laundry_zR3XCU": {
          "type": "exp-laundry",
          "settings": {
            "custom_class": "hc-briefing-washing",
            "eyebrow_text": "02 — reduced washing",
            "title": "Less washing means less waste.",
            "subtitle": "",
            "description": "Washing is one of the most resource-intensive parts of clothing. Water, energy, detergents, and chemicals all add up - especially when garments need frequent washing just to stay wearable.\n\nHercLéon gear stays fresher longer, which means it needs to be washed far less often. Fewer washes directly translate to less water used, lower energy consumption, and significantly reduced detergent and chemical pollution over time.",
