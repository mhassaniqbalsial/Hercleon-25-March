    "hc_tab_content_durability_Dmgaht": {
      "type": "hc-tab-content-durability",
      "blocks": {
        "durability_lifespan_RJRypR": {
          "type": "durability-lifespan",
          "settings": {
            "eyebrow_text": "01 — EXTENDED LIFESPAN",
            "title": "Less Washing = Longer Lifespan",
            "description": "Most clothing wears out early because it has to be washed constantly. Every wash breaks the fibers down a little more through heat, chemicals, and friction. Bacteria and odor are what forces those washes.\n\nHercLéon eliminates that problem at the source.\n\nOur anti-bacterial and anti-odor gear stays fresh for weeks, so it's washed far less often. That dramatically reduces fabric stress, preserves softness, and lets our garments last for years.",
