    "hc_tab_content_highlights_U6AUr3": {
      "type": "hc-tab-content-highlights",
      "blocks": {
        "backups_needed_UHfwiT": {
          "type": "backups-needed",
          "settings": {
            "title_accent": "no",
            "title_main": "backups needed",
            "description": "World's first antibacterial clothing to stay truly odorless. Made for people who want to move through life with less laundry, and more freedom."
          }
        },
        "travel_with_less_clothing_phMqVY": {
          "type": "travel-with-less-clothing",
          "settings": {
            "title": "Travel With 80% Less Clothing",
            "subtitle": "",
            "description": "Imagine traveling for weeks with just a backpack. No check-in fees. No waiting at baggage claim. No laundromats.\n\nBecause HercLéon stays fresh for extended wear, you only need a small rotation of our essentials. Fewer pieces also means fewer decisions. That results in a more minimal way of traveling, with less planning around clothes and more freedom to focus on the journey.",
            "comparison_title": "2 Weeks Long Trip",
            "tourist_label": "Standard Tourist",
            "tourist_weight": "~3.5kg Load",
            "tourist_items": 14,
            "tourist_note": "Requires 14 items OR Laundry",
            "hercleon_label": "HercLéon Operative",
            "hercleon_weight": "~0.1kg Load",
            "hercleon_items": 1,
            "hercleon_note": "Requires 1 Item. Zero Laundry."
          }
        },
        "bacteria_RR7hyd": {
          "type": "bacteria",
          "settings": {
            "custom_class": "hc-highlight-stop-bacteria",
            "eyebrow_text": "",
            "title": "COMPLETE ODOR ELIMINATION",
            "content": "<p>Our proprietary HercFiber is engineered using ultra-fine beechwood fibers blended with minerals such as copper, silver, zinc, and volcanic ash. It's designed to stop the entire odor cycle before it can begin.<br/><br/>Instead of letting sweat, bacteria, and environmental odors build up over time, HercFiber actively neutralizes them at the fiber level. That’s why our clothing stays fresh for weeks.</p>",
            "material_1_name": "Polyester",
            "material_1_mechanism": "No antibacterial abilities",
