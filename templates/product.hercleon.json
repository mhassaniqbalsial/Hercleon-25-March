            "material_4_name": "Silver-Infused",
            "material_4_mechanism": "Ions kill on contact",
            "material_4_reduction": "99.9%",
            "material_4_speed": "★★★☆☆",
            "material_4_highlight_speed": true,
            "material_5_name": "HercFiber™",
            "material_5_mechanism": "Multi-mineral matrix",
            "material_5_reduction": "99.9%",
            "material_5_speed": "★★★★★",
            "footer_text": "HercFiber Works 10-100x Faster Than Silver-Infused Clothing"
          }
        },
        "built_to_last_8BLBz3": {
          "type": "built-to-last",
          "settings": {
            "title": "Built to Last Years, Not Months",
            "subtitle": "",
            "description": "<p>Less washing means far less damage. Because HercLéon Gear requires 90% less washing, the fibers avoid the heat, friction, and chemicals that destroy ordinary fabric.<br/><br/>Its durability is engineered into the fabric itself. HercFiber is built with a tightly bonded fiber structure that resists pilling, prevents stretching, and holds its shape wear after wear. A HercShirt can last a decade.</p>",
            "comparison_title": "HercFiber™ is more durable than others by:",
            "comparison_1_value": "1.9x",
            "comparison_1_label": "Cotton",
