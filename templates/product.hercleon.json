        "build_to_last_NmAT7F": {
          "type": "build-to-last",
          "settings": {
            "eyebrow_text": "02 — STRUCTURAL INTEGRITY",
            "title": "BUILT TO LAST",
            "description": "Durability is not just about thicker fabric. It comes from how fibers are engineered, how they handle stress, and how well they recover after wear. HercLéon is built with a resilient fiber structure that resists stretching, sagging, and pilling, even after repeated use. The fibers maintain their shape under tension, snap back instead of breaking down, and stay smooth rather than fraying over time.\n\nThis structural integrity keeps the shirt looking sharp, holding its fit, and feeling new far longer than traditional fabrics.",
            "card_title": "Average Garment Lifespan",
            "row_1_label": "Cotton / Poly / Merino",
            "row_1_value": "6 - 18 Months",
            "row_1_bar_width": 15,
