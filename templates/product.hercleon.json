          }
        },
        "intelligent_investment_ymd9Xw": {
          "type": "intelligent-investment",
          "settings": {
            "eyebrow_text": "03 — FINANCIAL INTELLIGENCE",
            "title": "THE MOST INTELLIGENT INVESTMENT YOU CAN MAKE.",
            "description": "Smelly clothes are a liability. They require constant spending on detergent, water, electricity, and machine maintenance. Worse, frequent washing destroys the fabric, forcing you to buy replacements.\n\nHercLéon turns clothing into an asset. By staying fresh for weeks, we eliminate 90% of laundry costs and extend garment lifespan by years. Clothing that doesn't smell literally costs less to own.",
