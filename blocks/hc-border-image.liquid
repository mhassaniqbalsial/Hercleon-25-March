    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_vertical_mobile",
      "min": 15,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Vertical Padding (Mobile)",
      "default": 40
