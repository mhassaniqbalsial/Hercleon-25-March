      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Space Between Borders (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_overlap",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Border Overlap Amount",
      "default": 15
    },
    {
      "type": "range",
      "id": "border_overlap_mobile",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Border Overlap Amount (Mobile)",
      "default": 12
    },
    {
      "type": "header",
      "content": "Container Settings"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 150,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Minimum Height",
      "default": 300
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 100,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Minimum Height (Mobile)",
