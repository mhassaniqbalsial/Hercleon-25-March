<div class="hc-border-image-block" {{ block.shopify_attributes }}>
  <div class="hc-border-image-outer">
    <div class="hc-border-image-inner">
      <div class="hc-border-image-content">
        <p class="hc-border-image-text">{{ block.settings.text }}</p>
      </div>
    </div>
  </div>
</div>

<style>
  .hc-border-image-block {
    width: 100%;
  }

  .hc-border-image-outer {
    background-color: #f9fafb;
    border: 1px solid #d1d5db;
    padding: {{ block.settings.outer_padding }}px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hc-border-image-inner {
    background-color: #ffffff;
    border: 1px solid #d1d5db;
    margin: -{{ block.settings.border_overlap }}px;
  }

  .hc-border-image-content {
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: #f9fafb;
  }

  .hc-border-image-text {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {{ block.settings.text_transform }};
    margin: 0;
    padding: 0;
  }

  @media (max-width: 768px) {
    .hc-border-image-outer {
      padding: {{ block.settings.outer_padding_mobile }}px;
    }

    .hc-border-image-inner {
      margin: -{{ block.settings.border_overlap_mobile }}px;
    }

    .hc-border-image-content {
      padding: {{ block.settings.padding_vertical_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .hc-border-image-text {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "HC Border Image",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "[DESCRIBE WHAT SCHEMATIC]"
    },
    {
      "type": "header",
      "content": "Text Settings"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#d1d5db"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 14
